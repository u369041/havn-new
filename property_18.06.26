<!doctype html>
<html lang="en">
<head>
  <!-- Plausible Analytics -->
  <script defer data-domain="havn.ie" src="https://plausible.io/js/pa-jd8_FoqEzgCp-vGiLrEzC.js"></script>
  <script>
    window.plausible = window.plausible || function () {
      (window.plausible.q = window.plausible.q || []).push(arguments);
    };
  </script>

  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <title>HAVN.ie • Property</title>
  <meta name="description" content="View property details on HAVN.ie — Ireland’s curated property marketplace.">

  <meta property="og:type" content="website">
  <meta property="og:site_name" content="HAVN.ie">
  <meta property="og:title" content="HAVN.ie Property">
  <meta property="og:description" content="View this property on HAVN.ie">
  <meta property="og:image" content="https://havn.ie/og.png">
  <meta property="og:url" content="https://havn.ie/property.html">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="HAVN.ie Property">
  <meta name="twitter:description" content="View this property on HAVN.ie">
  <meta name="twitter:image" content="https://havn.ie/og.png">

  <link rel="preconnect" href="https://api.havn.ie" />
  <script src="/havn-auth.js?v=20260430-property-restore-stable-2"></script>

  <style>
    :root{
      --bg:#f6f8fc;
      --card:#ffffff;
      --ink:#0f172a;
      --muted:#64748b;
      --line:#e5e7eb;
      --shadow:0 12px 30px rgba(15,23,42,.08);
      --radius:18px;
      --maxW:1180px;
      --blue:#2563eb;
      --green:#16a34a;
      --red:#ef4444;
      --amber:#f59e0b;
    }

    *{box-sizing:border-box}

    html,body{height:100%}

    body{
      margin:0;
      font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;
      background:var(--bg);
      color:var(--ink);
      -webkit-font-smoothing:antialiased;
    }

    body.lbOpen{overflow:hidden}

    .wrap{
      max-width:var(--maxW);
      margin:18px auto;
      padding:0 16px 80px;
    }

    .topbar{
      background:#fff;
      border:1px solid var(--line);
      border-radius:999px;
      padding:10px 12px;
      display:flex;
      gap:10px;
      align-items:center;
      justify-content:space-between;
      box-shadow:var(--shadow);
    }

    .brand{
      display:flex;
      gap:10px;
      align-items:center;
    }

    .dot{
      width:28px;
      height:28px;
      border-radius:10px;
      background:linear-gradient(135deg,#2563eb,#1d4ed8);
    }

    .nav{
      display:flex;
      gap:8px;
      align-items:center;
      justify-content:center;
      flex:1;
      flex-wrap:wrap;
    }

    .nav a{
      text-decoration:none;
      font-weight:900;
      font-size:12px;
      color:rgba(15,23,42,.75);
      padding:8px 10px;
      border-radius:999px;
    }

    .nav a:hover{background:rgba(15,23,42,.05)}

    .actions{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
    }

    .pill{
      border:1px solid var(--line);
      background:#fff;
      padding:9px 12px;
      border-radius:999px;
      font-weight:900;
      font-size:12px;
      text-decoration:none;
      color:rgba(15,23,42,.85);
    }

    .pill.primary{
      background:linear-gradient(135deg,rgba(15,23,42,.96),rgba(15,23,42,.84));
      color:#fff;
      border-color:rgba(15,23,42,.22);
    }
    .propertyMobileMenuBtn{
      display:none;
      width:42px;
      height:42px;
      border-radius:14px;
      border:1px solid rgba(15,23,42,.10);
      background:#fff;
      color:rgba(15,23,42,.92);
      font-size:22px;
      font-weight:1000;
      align-items:center;
      justify-content:center;
      cursor:pointer;
      box-shadow:0 8px 18px rgba(15,23,42,.06);
      flex:0 0 auto;
    }

    .propertyMobileMenu{
      display:none;
      margin-top:10px;
      background:#fff;
      border:1px solid rgba(15,23,42,.10);
      border-radius:18px;
      box-shadow:var(--shadow);
      padding:10px;
    }

    .propertyMobileMenu.open{
      display:block;
    }

    .propertyMobileMenu a{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      text-decoration:none;
      color:rgba(15,23,42,.90);
      font-weight:950;
      font-size:14px;
      padding:13px 12px;
      border-radius:14px;
    }

    .propertyMobileMenu a:hover,
    .propertyMobileMenu a:focus{
      background:rgba(37,99,235,.06);
      outline:none;
    }

    .propertyMobileMenu .menuDivider{
      height:1px;
      background:rgba(15,23,42,.08);
      margin:6px 4px;
    }


    .panel{
      margin-top:12px;
      background:#fff;
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      padding:14px;
    }

    .err{
      border:1px solid rgba(239,68,68,.35);
      background:rgba(239,68,68,.08);
      color:rgba(127,29,29,.95);
    }

    .mono{
      font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace;
      font-size:12px;
      white-space:pre-wrap;
    }

    .hero{
      margin-top:12px;
      border-radius:var(--radius);
      overflow:hidden;
      border:1px solid rgba(15,23,42,.08);
      background:#e5e7eb;
      box-shadow:var(--shadow);
      position:relative;
      cursor:zoom-in;
      user-select:none;
      display:none;
    }

    .hero img{
      width:100%;
      height:clamp(340px,36vw,520px);
      object-fit:cover;
      display:block;
    }

    .heroScrim{
      position:absolute;
      inset:0;
      background:linear-gradient(180deg,rgba(2,6,23,0) 55%,rgba(2,6,23,.35) 100%);
      pointer-events:none;
    }

    .heroBadgeRow{
      position:absolute;
      left:12px;
      right:12px;
      bottom:12px;
      display:flex;
      justify-content:space-between;
      gap:10px;
      pointer-events:none;
    }

    .heroBadge,.heroCount{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 10px;
      border-radius:999px;
      background:rgba(2,6,23,.55);
      border:1px solid rgba(255,255,255,.18);
      color:rgba(255,255,255,.92);
      font-weight:1000;
      font-size:12px;
      box-shadow:0 12px 30px rgba(0,0,0,.28);
      backdrop-filter:blur(6px);
    }

    .galleryStrip{
      margin-top:10px;
      background:rgba(255,255,255,.92);
      border:1px solid rgba(15,23,42,.08);
      border-radius:16px;
      box-shadow:0 10px 22px rgba(15,23,42,.06);
      padding:10px;
      display:none;
    }

    .stripRow{
      display:flex;
      gap:10px;
      overflow:auto;
      padding-bottom:2px;
      scroll-behavior:smooth;
      -webkit-overflow-scrolling:touch;
    }

    .thumbBtn{
      flex:0 0 auto;
      width:96px;
      height:64px;
      border-radius:14px;
      border:1px solid rgba(15,23,42,.12);
      overflow:hidden;
      background:#eef2ff;
      cursor:pointer;
      padding:0;
    }

    .thumbBtn img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }

    .thumbBtn.active{
      border-color:rgba(37,99,235,.95);
      box-shadow:0 0 0 4px rgba(37,99,235,.14);
    }

    .stripHint{
      margin-top:8px;
      font-size:12px;
      font-weight:900;
      color:rgba(15,23,42,.55);
      display:flex;
      justify-content:space-between;
      gap:10px;
      flex-wrap:wrap;
    }

    .titleRow{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:12px;
      flex-wrap:wrap;
    }

    .h1{
      margin:0;
      font-size:22px;
      font-weight:1000;
      letter-spacing:-.02em;
      line-height:1.2;
    }

    .sub{
      margin:6px 0 0;
      color:var(--muted);
      font-weight:700;
      font-size:13px;
    }

    .ghostBtn{
      border:1px solid rgba(15,23,42,.10);
      background:#fff;
      padding:9px 12px;
      border-radius:999px;
      font-weight:1000;
      font-size:12px;
      color:rgba(15,23,42,.85);
      cursor:pointer;
    }

    .ghostBtn.saved{
      background:rgba(239,68,68,.08);
      border-color:rgba(239,68,68,.18);
      color:rgba(127,29,29,.95);
    }

    .meta{
      margin-top:10px;
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .tag{
      font-size:12px;
      font-weight:900;
      padding:6px 10px;
      border-radius:999px;
      border:1px solid var(--line);
      background:#fff;
    }

    .tag.soft{
      background:rgba(37,99,235,.06);
      border-color:rgba(37,99,235,.14);
    }

    .grid{
      margin-top:12px;
      display:grid;
      grid-template-columns:1.2fr .8fr;
      gap:12px;
      align-items:start;
    }

    .sectionTitle{
      font-weight:900;
      font-size:14px;
      margin-bottom:10px;
      color:rgba(15,23,42,.92);
    }

    .desc{
      white-space:pre-wrap;
      font-size:15px;
      color:rgba(15,23,42,.84);
      line-height:1.8;
    }

    .featuresBlock{
      margin-top:12px;
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:18px;
      box-shadow:none;
      padding:14px;
      display:none;
    }
    
    .featuresGrid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px 18px;
    }
    
    .featureItem{
      display:flex;
      align-items:center;
      gap:9px;
      color:#334155;
      font-size:14px;
      line-height:1.45;
      font-weight:750;
    }
    
    .featureItem::before{
      content:"✓";
      width:18px;
      height:18px;
      border-radius:999px;
      display:grid;
      place-items:center;
      flex:0 0 auto;
      background:#dcfce7;
      color:#166534;
      font-size:12px;
      font-weight:900;
    }
    
    @media (max-width:680px){
      .featuresGrid{
        grid-template-columns:1fr;
      }
    }

    .kdTopRow{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:10px;
      margin-bottom:10px;
      flex-wrap:wrap;
    }

    .kdTitle{
      font-weight:1000;
      margin:0;
      font-size:13px;
    }

    .kdBadge{
      display:none;
      align-items:center;
      gap:8px;
      padding:7px 10px;
      border-radius:999px;
      border:1px solid rgba(15,23,42,.10);
      background:#fff;
      font-weight:1000;
      font-size:12px;
    }

    .kdBadgeDot{
      width:9px;
      height:9px;
      border-radius:50%;
      background:var(--green);
      box-shadow:0 0 0 4px rgba(22,163,74,.12);
    }

    .kdGrid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    .kdItem{
      border:1px solid rgba(15,23,42,.10);
      background:rgba(246,248,252,.65);
      border-radius:14px;
      padding:10px;
    }

    .kdLabel{
      font-size:12px;
      font-weight:950;
      color:rgba(15,23,42,.55);
      margin-bottom:4px;
    }

    .kdValue{
      font-size:13px;
      font-weight:1000;
      color:rgba(15,23,42,.92);
      word-break:break-word;
    }

    .kdValue.muted{
      color:rgba(15,23,42,.60);
      font-weight:950;
    }

    .mapBlock{
      margin-top:12px;
      border-top:1px solid rgba(15,23,42,.08);
      padding-top:12px;
      display:none;
    }

    .mapHdr{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin-bottom:8px;
    }

    .mapHdr .ttl{
      font-weight:1000;
      font-size:13px;
    }

    .mapActions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }

    .miniBtn{
      border:1px solid rgba(15,23,42,.12);
      background:#fff;
      padding:7px 10px;
      border-radius:999px;
      font-weight:1000;
      font-size:12px;
      cursor:pointer;
      text-decoration:none;
      color:rgba(15,23,42,.85);
    }

    .mapFrame{
      width:100%;
      height:340px;
      border-radius:16px;
      overflow:hidden;
      background:#e5e7eb;
      border:1px solid rgba(15,23,42,.10);
      box-shadow:0 12px 26px rgba(15,23,42,.08);
    }

    .mapFrame iframe{
      width:100%;
      height:100%;
      border:0;
      display:block;
    }

    .mapCaption{
      margin-top:8px;
      font-size:12px;
      font-weight:850;
      color:rgba(15,23,42,.55);
    }

    .contactCard{
      margin-top:12px;
      border:1px solid rgba(15,23,42,.10);
      background:linear-gradient(180deg,#fff,rgba(248,250,252,.96));
      border-radius:18px;
      box-shadow:0 12px 30px rgba(15,23,42,.06);
      padding:14px;
    }

    .contactTitle{
      margin:0;
      font-size:14px;
      font-weight:1000;
    }

    .contactSub{
      margin:4px 0 0;
      color:rgba(15,23,42,.58);
      font-size:12px;
      font-weight:800;
      line-height:1.35;
    }

    .contactTrust{
      display:flex;
      gap:6px;
      flex-wrap:wrap;
      margin:10px 0 12px;
    }

    .miniTrust{
      font-size:11px;
      font-weight:900;
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      padding:6px 8px;
      border-radius:999px;
      color:rgba(15,23,42,.72);
    }

    .formField{margin-bottom:10px}

    .formLabel{
      display:block;
      font-size:12px;
      font-weight:900;
      color:rgba(15,23,42,.72);
      margin-bottom:6px;
    }

    .formInput,.formTextarea{
      width:100%;
      border:1px solid rgba(15,23,42,.12);
      background:#fff;
      border-radius:14px;
      padding:12px;
      outline:none;
      font-size:14px;
      font-family:inherit;
      color:rgba(15,23,42,.92);
    }

    .formTextarea{
      min-height:120px;
      resize:vertical;
      line-height:1.5;
    }

    .contactActions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      margin-top:8px;
    }

    .contactBtn{
      border:1px solid rgba(15,23,42,.10);
      background:#fff;
      color:rgba(15,23,42,.88);
      border-radius:14px;
      padding:12px 14px;
      font-weight:1000;
      font-size:13px;
      cursor:pointer;
    }

    .contactBtn.primary{
      background:linear-gradient(135deg,rgba(37,99,235,.98),rgba(14,165,233,.98));
      color:#fff;
      border-color:rgba(37,99,235,.35);
    }

    .contactBtn[disabled]{
      opacity:.65;
      cursor:not-allowed;
    }

    .contactState{
      margin-top:10px;
      font-size:12px;
      font-weight:900;
      display:none;
      padding:10px 12px;
      border-radius:14px;
      border:1px solid rgba(15,23,42,.08);
    }

    .contactState.ok{
      display:block;
      background:rgba(22,163,74,.08);
      border-color:rgba(22,163,74,.18);
      color:rgba(20,83,45,.95);
    }

    .contactState.err{
      display:block;
      background:rgba(239,68,68,.08);
      border-color:rgba(239,68,68,.18);
      color:rgba(127,29,29,.95);
    }

    .cardsGrid{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:12px;
    }

    .miniCard{
      display:block;
      text-decoration:none;
      color:inherit;
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:18px;
      overflow:hidden;
      box-shadow:0 12px 30px rgba(15,23,42,.08);
    }

    .miniCardMedia{
      width:100%;
      height:170px;
      background:#e5e7eb;
      display:block;
      object-fit:cover;
    }

    .miniCardBody{padding:12px}

    .miniPrice{
      font-weight:1000;
      margin-bottom:6px;
      font-size:15px;
    }

    .miniTitle{
      font-weight:1000;
      line-height:1.25;
      margin-bottom:6px;
    }

    .miniMeta{
      color:#64748b;
      font-weight:800;
      font-size:12px;
      margin-bottom:10px;
    }

    .miniChips{
      display:flex;
      gap:6px;
      flex-wrap:wrap;
    }

    .miniChip{
      font-size:11px;
      font-weight:900;
      border:1px solid #e5e7eb;
      padding:4px 8px;
      border-radius:999px;
      background:#fff;
    }

    .emptyState{
      padding:14px;
      color:#64748b;
      font-weight:800;
      border:1px dashed rgba(15,23,42,.10);
      border-radius:16px;
      background:rgba(246,248,252,.75);
    }


    /* HAVN Property Detail V2 — world-class trust + conversion layer */
    .commandShell{
      margin-top:12px;
      display:grid;
      grid-template-columns:minmax(0,1.35fr) minmax(330px,.65fr);
      gap:12px;
      align-items:start;
    }

    .commandPanel{
      margin-top:0;
      padding:18px;
      border-radius:22px;
      background:linear-gradient(180deg,#ffffff,rgba(248,250,252,.98));
      border:1px solid rgba(15,23,42,.08);
      box-shadow:var(--shadow);
    }

    .commandEyebrow{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
      margin-bottom:12px;
    }

    .modeBadge,.verifiedBadge,.featuredBadge{
      display:inline-flex;
      align-items:center;
      gap:7px;
      border-radius:999px;
      padding:7px 10px;
      font-size:12px;
      font-weight:1000;
      border:1px solid rgba(15,23,42,.10);
      background:#fff;
      color:rgba(15,23,42,.86);
    }

    .verifiedBadge{
      background:rgba(22,163,74,.08);
      border-color:rgba(22,163,74,.18);
      color:rgba(20,83,45,.96);
    }

    .featuredBadge{
      background:rgba(245,158,11,.10);
      border-color:rgba(245,158,11,.22);
      color:rgba(120,53,15,.96);
      display:none;
    }

    .commandPrice{
      font-size:clamp(34px,4.05vw,50px);
      line-height:1.05;
      letter-spacing:-.032em;
      font-weight:650;
      color:#111827;
      margin:0 0 14px;
    }

    .commandTitle{
      font-size:clamp(20px,1.75vw,25px);
      line-height:1.28;
      letter-spacing:-.022em;
      font-weight:700;
      color:#111827;
      margin:0;
      max-width:760px;
    }

    .commandAddress{
      margin:7px 0 0;
      color:rgba(15,23,42,.58);
      font-size:14px;
      line-height:1.5;
      font-weight:650;
      max-width:760px;
    }

    .factsBar{
      margin-top:16px;
      display:grid;
      grid-template-columns:repeat(5,minmax(0,1fr));
      gap:10px;
    }

    .factTile{
      border:1px solid rgba(15,23,42,.08);
      background:rgba(246,248,252,.78);
      border-radius:18px;
      padding:12px;
      min-height:76px;
    }

    .factLabel{
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.06em;
      font-weight:1000;
      color:rgba(15,23,42,.48);
      margin-bottom:6px;
    }

    .factValue{
      font-size:16px;
      line-height:1.2;
      font-weight:1100;
      color:rgba(15,23,42,.94);
      word-break:break-word;
    }

    .trustStrip{
      margin-top:14px;
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:10px;
    }

    .trustTile{
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:16px;
      padding:11px;
    }

    .trustLabel{
      font-size:11px;
      font-weight:1000;
      color:rgba(15,23,42,.48);
      margin-bottom:4px;
      text-transform:uppercase;
      letter-spacing:.05em;
    }

    .trustValue{
      font-size:12px;
      line-height:1.35;
      font-weight:1000;
      color:rgba(15,23,42,.88);
    }

    .actionCard{
      margin-top:0;
      position:sticky;
      top:14px;
      border-radius:22px;
      border:1px solid rgba(15,23,42,.10);
      background:linear-gradient(180deg,#ffffff,rgba(248,250,252,.98));
      box-shadow:0 18px 44px rgba(15,23,42,.10);
      padding:16px;
      z-index:10;
    }

    .actionTitle{
      margin:0;
      font-size:17px;
      font-weight:1100;
      letter-spacing:-.025em;
    }

    .actionSub{
      margin:6px 0 14px;
      color:rgba(15,23,42,.58);
      font-size:13px;
      font-weight:800;
      line-height:1.45;
    }

    .bigAction{
      width:100%;
      border:1px solid rgba(37,99,235,.30);
      background:linear-gradient(135deg,#2563eb,#0ea5e9);
      color:#fff;
      border-radius:16px;
      padding:14px 16px;
      font-weight:1100;
      font-size:14px;
      cursor:pointer;
      box-shadow:0 14px 28px rgba(37,99,235,.20);
    }

    .secondaryActions{
      margin-top:10px;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:8px;
    }

    .secondaryActions .ghostBtn{
      border-radius:15px;
      padding:12px 10px;
      width:100%;
      background:#fff;
    }

    .actionTrustList{
      margin:14px 0 0;
      display:grid;
      gap:8px;
    }

    .actionTrustItem{
      display:flex;
      gap:9px;
      align-items:flex-start;
      font-size:12px;
      font-weight:900;
      color:rgba(15,23,42,.72);
      line-height:1.35;
    }

    .actionTrustItem .tick{
      width:18px;
      height:18px;
      border-radius:999px;
      display:grid;
      place-items:center;
      background:rgba(22,163,74,.10);
      color:#166534;
      flex:0 0 auto;
      font-size:12px;
      font-weight:1100;
    }

    .reportBtn{
      margin-top:12px;
      width:100%;
      border:1px solid rgba(239,68,68,.18);
      background:rgba(239,68,68,.06);
      color:rgba(127,29,29,.95);
      border-radius:15px;
      padding:11px 12px;
      font-weight:1000;
      font-size:12px;
      cursor:pointer;
    }

    .contentGridV2{
      margin-top:12px;
      display:grid;
      grid-template-columns:minmax(0,1.35fr) minmax(330px,.65fr);
      gap:12px;
      align-items:start;
    }

    .propertyIntelligenceFull{
      margin-top:12px;
    }

    .propertyIntelligenceFull .mapFrame{
      height:430px;
    }

    .propertyIntelligenceFull .locationIntelGrid{
      grid-template-columns:repeat(4,minmax(0,1fr));
    }

    @media (max-width:980px){
      .propertyIntelligenceFull .mapFrame{
        height:340px;
      }
    }

    .sectionCard{
      margin-top:12px;
      background:#fff;
      border:1px solid rgba(15,23,42,.08);
      border-radius:22px;
      box-shadow:var(--shadow);
      padding:16px;
    }

    .sectionCard:first-child{margin-top:0}

    .sectionHeader{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:10px;
      margin-bottom:12px;
    }

    .sectionHeader h2{
      margin:0;
      font-size:16px;
      letter-spacing:-.025em;
      font-weight:1100;
      color:rgba(15,23,42,.94);
    }

    .sectionNote{
      margin:4px 0 0;
      color:rgba(15,23,42,.55);
      font-size:12px;
      font-weight:800;
      line-height:1.4;
    }

    .insightGrid{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:10px;
    }

    .insightTile{
      border:1px solid rgba(15,23,42,.08);
      background:linear-gradient(180deg,rgba(248,250,252,.96),#fff);
      border-radius:18px;
      padding:13px;
    }

    .insightLabel{
      font-size:11px;
      font-weight:1000;
      color:rgba(15,23,42,.48);
      text-transform:uppercase;
      letter-spacing:.05em;
      margin-bottom:5px;
    }

    .insightValue{
      font-size:18px;
      line-height:1.18;
      font-weight:1100;
      color:rgba(15,23,42,.94);
    }

    .insightSmall{
      margin-top:5px;
      font-size:11px;
      font-weight:800;
      color:rgba(15,23,42,.52);
      line-height:1.35;
    }

    .detailGroup{
      margin-top:12px;
    }

    .detailGroup:first-child{margin-top:0}

    .detailGroupTitle{
      margin:0 0 8px;
      font-size:13px;
      font-weight:1100;
      color:rgba(15,23,42,.88);
    }

    .detailGridV2{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:10px;
    }

    .detailItemV2{
      border:1px solid rgba(15,23,42,.08);
      background:rgba(246,248,252,.70);
      border-radius:16px;
      padding:11px;
    }

    .detailLabelV2{
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.045em;
      font-weight:1000;
      color:rgba(15,23,42,.48);
      margin-bottom:5px;
    }

    .detailValueV2{
      font-size:13px;
      line-height:1.35;
      font-weight:1000;
      color:rgba(15,23,42,.90);
      word-break:break-word;
    }

    .locationIntelGrid{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:10px;
      margin-top:12px;
    }

    .intelLink{
      text-decoration:none;
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:16px;
      padding:12px;
      color:rgba(15,23,42,.88);
      font-weight:1000;
      font-size:13px;
      line-height:1.25;
      box-shadow:0 8px 18px rgba(15,23,42,.04);
    }

    .intelLink span{
      display:block;
      margin-top:4px;
      color:rgba(15,23,42,.52);
      font-weight:800;
      font-size:11px;
    }
    
    .intelFullPanel{
        grid-column:1/-1;
        margin-top:6px;
        display:grid;
        grid-template-columns:repeat(2,minmax(0,1fr));
        gap:12px;
    }

    .intelDataCard{
      border:1px solid rgba(15,23,42,.08);
      background:linear-gradient(180deg,rgba(248,250,252,.96),#fff);
      border-radius:18px;
      padding:14px;
    }
    
    .intelDataCard h3{
      margin:0 0 10px;
      font-size:14px;
      font-weight:1100;
    }
    
    .intelDataRow{
      display:flex;
      justify-content:space-between;
      gap:12px;
      border-top:1px solid rgba(15,23,42,.06);
      padding-top:8px;
      margin-top:8px;
      font-size:12px;
      font-weight:900;
    }
    
    .intelDataRow:first-of-type{
      border-top:0;
      margin-top:0;
      padding-top:0;
    }
    
    .intelDataRow span:first-child{
      color:rgba(15,23,42,.78);
    }
    
    .intelDataRow span:last-child{
      color:rgba(15,23,42,.52);
      white-space:nowrap;
    }
    
    .intelScorePanel{
      grid-column:1/-1;
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:10px;
    }
    
    .intelScoreCard{
      border:1px solid rgba(37,99,235,.12);
      background:rgba(37,99,235,.05);
      border-radius:16px;
      padding:12px;
    }
    
    .intelScoreCard strong{
      display:block;
      font-size:22px;
      font-weight:1100;
      color:#1d4ed8;
    }
    
    .intelScoreCard span{
      display:block;
      margin-top:4px;
      font-size:11px;
      font-weight:950;
      color:rgba(15,23,42,.58);
    }
    
    .intelInsightBox{
      grid-column:1/-1;
      border:1px solid rgba(22,163,74,.16);
      background:linear-gradient(180deg,rgba(240,253,244,.95),#fff);
      border-radius:18px;
      padding:14px;
      color:rgba(15,23,42,.82);
      font-size:13px;
      font-weight:850;
      line-height:1.55;
    }
    

    /* HAVN Area Intelligence V1 — explainable location scoring */
    .areaIntelShell{
      grid-column:1/-1;
      border:1px solid rgba(15,23,42,.08);
      background:linear-gradient(180deg,#ffffff,rgba(248,250,252,.98));
      border-radius:22px;
      padding:16px;
      box-shadow:0 14px 30px rgba(15,23,42,.06);
    }

    .areaIntelHeader{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:12px;
      flex-wrap:wrap;
      margin-bottom:14px;
    }

    .areaIntelHeader h3{
      margin:0;
      font-size:18px;
      letter-spacing:-.025em;
      font-weight:1100;
      color:#0f172a;
    }

    .areaIntelHeader p{
      margin:5px 0 0;
      color:rgba(15,23,42,.56);
      font-size:12px;
      line-height:1.45;
      font-weight:850;
      max-width:720px;
    }

    .areaIntelMethodBadge{
      display:inline-flex;
      align-items:center;
      gap:7px;
      border:1px solid rgba(37,99,235,.14);
      background:rgba(37,99,235,.06);
      color:#1d4ed8;
      padding:7px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:1000;
      white-space:nowrap;
    }

    .areaIntelGrid{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:10px;
    }

    .areaIntelCard{
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:18px;
      padding:13px;
      cursor:pointer;
      text-align:left;
      font-family:inherit;
      color:inherit;
      box-shadow:0 10px 22px rgba(15,23,42,.04);
      transition:transform .15s ease, border-color .15s ease, box-shadow .15s ease;
    }

    .areaIntelCard:hover,
    .areaIntelCard:focus{
      transform:translateY(-1px);
      border-color:rgba(37,99,235,.30);
      box-shadow:0 14px 28px rgba(15,23,42,.08);
      outline:none;
    }

    .areaIntelTop{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:10px;
      margin-bottom:10px;
    }

    .areaIntelIcon{
      width:38px;
      height:38px;
      border-radius:15px;
      display:grid;
      place-items:center;
      background:rgba(37,99,235,.08);
      border:1px solid rgba(37,99,235,.12);
      font-size:19px;
      flex:0 0 auto;
    }

    .areaIntelScore{
      text-align:right;
      color:#0f172a;
      font-weight:1100;
      line-height:1;
      font-size:30px;
      letter-spacing:-.04em;
    }

    .areaIntelScore span{
      font-size:12px;
      letter-spacing:0;
      color:rgba(15,23,42,.45);
      margin-left:2px;
    }

    .areaIntelName{
      font-size:13px;
      font-weight:1100;
      color:#0f172a;
      margin-bottom:5px;
    }

    .areaIntelLabel{
      display:inline-flex;
      align-items:center;
      border-radius:999px;
      padding:5px 8px;
      font-size:11px;
      font-weight:1000;
      border:1px solid rgba(15,23,42,.08);
      background:rgba(248,250,252,.94);
      color:rgba(15,23,42,.72);
      margin-bottom:8px;
    }

    .areaIntelLabel.excellent{
      background:rgba(22,163,74,.08);
      border-color:rgba(22,163,74,.18);
      color:#166534;
    }

    .areaIntelLabel.strong{
      background:rgba(37,99,235,.08);
      border-color:rgba(37,99,235,.16);
      color:#1d4ed8;
    }

    .areaIntelLabel.good{
      background:rgba(245,158,11,.10);
      border-color:rgba(245,158,11,.20);
      color:#92400e;
    }

    .areaIntelLabel.limited{
      background:rgba(239,68,68,.07);
      border-color:rgba(239,68,68,.16);
      color:#991b1b;
    }

    .areaIntelSummary{
      margin:0;
      color:rgba(15,23,42,.55);
      font-size:11px;
      line-height:1.4;
      font-weight:850;
    }

    .areaIntelPanels{
      margin-top:12px;
      display:grid;
      gap:10px;
    }

    .areaIntelBreakdown{
      display:none;
      border:1px solid rgba(37,99,235,.14);
      background:linear-gradient(180deg,rgba(37,99,235,.045),#fff);
      border-radius:18px;
      padding:14px;
    }

    .areaIntelBreakdown.open{
      display:block;
    }

    .areaIntelBreakdownHead{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:12px;
      margin-bottom:10px;
      flex-wrap:wrap;
    }

    .areaIntelBreakdownHead strong{
      display:block;
      font-size:14px;
      font-weight:1100;
      color:#0f172a;
    }

    .areaIntelBreakdownHead span{
      display:block;
      margin-top:3px;
      font-size:12px;
      line-height:1.4;
      font-weight:850;
      color:rgba(15,23,42,.56);
    }

    .areaIntelBreakdownScore{
      font-size:13px;
      font-weight:1100;
      color:#1d4ed8;
      white-space:nowrap;
    }

    .areaIntelRows{
      display:grid;
      gap:8px;
    }

    .areaIntelRow{
      display:grid;
      grid-template-columns:180px minmax(140px,1fr) auto;
      gap:12px;
      align-items:center;
      padding-top:8px;
      border-top:1px solid rgba(15,23,42,.07);
    }

    .areaIntelRow:first-child{
      border-top:0;
      padding-top:0;
    }

    .areaIntelRowLabel{
      font-size:12px;
      font-weight:1000;
      color:rgba(15,23,42,.80);
    }

    .areaIntelBarTrack{
      height:8px;
      border-radius:999px;
      background:rgba(15,23,42,.08);
      overflow:hidden;
    }

    .areaIntelBarFill{
      height:100%;
      border-radius:999px;
      background:linear-gradient(90deg,#2563eb,#0ea5e9);
    }

    .areaIntelRowScore{
      font-size:12px;
      font-weight:1100;
      color:#0f172a;
      white-space:nowrap;
      text-align:right;
    }

    .areaIntelReason{
      grid-column:2 / -1;
      margin-top:-3px;
      color:rgba(15,23,42,.52);
      font-size:11px;
      line-height:1.35;
      font-weight:800;
    }

    @media (max-width:980px){
      .areaIntelGrid{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }

      .areaIntelRow{
        grid-template-columns:150px minmax(120px,1fr) auto;
      }
    }

    @media (max-width:680px){
      .areaIntelShell{
        padding:14px;
        border-radius:20px;
      }

      .areaIntelGrid{
        grid-template-columns:1fr;
      }

      .areaIntelRow{
        grid-template-columns:1fr auto;
        gap:6px 10px;
      }

      .areaIntelBarTrack{
        grid-column:1/-1;
      }

      .areaIntelReason{
        grid-column:1/-1;
        margin-top:0;
      }
    }




    /* HAVN Schools UX V12 — grouped family intelligence */
    .schoolsV12Shell{display:grid;gap:14px;}
    .schoolsV12Intro{border:1px solid rgba(22,163,74,.16);background:linear-gradient(135deg,rgba(240,253,244,.96),#fff);border-radius:18px;padding:14px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;}
    .schoolsV12Intro strong{display:block;font-size:15px;line-height:1.25;font-weight:1100;color:#0f172a;}
    .schoolsV12Intro span{display:block;margin-top:4px;font-size:12px;line-height:1.45;font-weight:850;color:rgba(15,23,42,.60);}
    .schoolsV12Score{min-width:96px;text-align:center;border:1px solid rgba(37,99,235,.12);background:rgba(37,99,235,.06);color:#1d4ed8;border-radius:16px;padding:10px 12px;font-size:12px;font-weight:1000;}
    .schoolsV12Score strong{color:#1d4ed8;font-size:28px;line-height:1;letter-spacing:-.035em;}
    .schoolsV12Grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;}
    .schoolsV12Group{border:1px solid rgba(15,23,42,.08);background:linear-gradient(180deg,#fff,rgba(248,250,252,.96));border-radius:20px;padding:14px;box-shadow:0 10px 24px rgba(15,23,42,.05);min-width:0;}
    .schoolsV12Head{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:12px;}
    .schoolsV12Icon{width:40px;height:40px;border-radius:16px;display:grid;place-items:center;background:rgba(37,99,235,.08);border:1px solid rgba(37,99,235,.12);font-size:20px;flex:0 0 auto;}
    .schoolsV12Title{margin:0;font-size:14px;line-height:1.22;font-weight:1100;color:#0f172a;}
    .schoolsV12Count{margin-top:4px;color:rgba(15,23,42,.52);font-size:11px;font-weight:950;line-height:1.35;}
    .schoolsV12Nearest{margin-bottom:12px;border:1px solid rgba(22,163,74,.14);background:rgba(240,253,244,.70);border-radius:15px;padding:10px;}
    .schoolsV12NearestLabel{font-size:10px;text-transform:uppercase;letter-spacing:.06em;font-weight:1000;color:rgba(20,83,45,.72);margin-bottom:4px;}
    .schoolsV12NearestName{font-size:13px;line-height:1.25;font-weight:1100;color:#0f172a;}
    .schoolsV12NearestDistance{margin-top:3px;font-size:12px;font-weight:1000;color:#16a34a;}
    .schoolsV12Rows{display:grid;gap:7px;}
    .schoolsV12Row{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:10px;align-items:start;padding:9px 10px;border:1px solid rgba(15,23,42,.07);background:rgba(248,250,252,.78);border-radius:13px;}
    .schoolsV12Row strong{display:block;color:rgba(15,23,42,.86);font-size:12px;line-height:1.28;font-weight:1050;}
    .schoolsV12Row span{display:block;margin-top:3px;color:rgba(15,23,42,.50);font-size:11px;font-weight:850;line-height:1.3;}
    .schoolsV12Row em{font-style:normal;color:#2563eb;font-size:12px;font-weight:1100;white-space:nowrap;}
    .schoolsV12Empty{border:1px dashed rgba(15,23,42,.14);background:rgba(248,250,252,.72);border-radius:14px;padding:12px;color:rgba(15,23,42,.58);font-size:12px;font-weight:900;line-height:1.4;}
    @media (max-width:980px){.schoolsV12Grid{grid-template-columns:1fr;}}


    /* HAVN Transport UX — premium grouped transport intelligence */
    .transportPremiumShell{
      display:grid;
      gap:12px;
    }

    .transportSummaryGrid{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:10px;
    }

    .transportSummaryCard{
      border:1px solid rgba(15,23,42,.08);
      background:linear-gradient(180deg,#ffffff,rgba(248,250,252,.96));
      border-radius:18px;
      padding:14px;
      box-shadow:0 10px 22px rgba(15,23,42,.04);
      min-height:132px;
    }

    .transportSummaryTop{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:10px;
      margin-bottom:10px;
    }

    .transportIcon{
      width:38px;
      height:38px;
      border-radius:15px;
      display:grid;
      place-items:center;
      background:rgba(37,99,235,.08);
      border:1px solid rgba(37,99,235,.12);
      font-size:20px;
      flex:0 0 auto;
    }

    .transportCount{
      text-align:right;
      font-size:12px;
      font-weight:1100;
      color:#1d4ed8;
      white-space:nowrap;
    }

    .transportName{
      font-size:14px;
      line-height:1.25;
      font-weight:1100;
      color:#0f172a;
      margin-bottom:6px;
    }

    .transportNearestLabel{
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.05em;
      font-weight:1000;
      color:rgba(15,23,42,.45);
      margin-bottom:3px;
    }

    .transportNearestValue{
      font-size:12px;
      line-height:1.35;
      font-weight:950;
      color:rgba(15,23,42,.74);
    }

    .transportNearestValue strong{
      color:rgba(15,23,42,.92);
      font-weight:1100;
    }

    .transportDetailToggle{
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:18px;
      overflow:hidden;
    }

    .transportDetailToggle summary{
      list-style:none;
      cursor:pointer;
      padding:13px 14px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      font-size:13px;
      font-weight:1100;
      color:#0f172a;
      user-select:none;
    }

    .transportDetailToggle summary::-webkit-details-marker{
      display:none;
    }

    .transportDetailToggle summary span:last-child{
      color:#2563eb;
      font-size:12px;
      white-space:nowrap;
    }

    .transportDetailToggle[open] summary{
      border-bottom:1px solid rgba(15,23,42,.08);
    }

    .transportGroupBlock{
      padding:13px 14px;
      border-top:1px solid rgba(15,23,42,.06);
    }

    .transportGroupBlock:first-of-type{
      border-top:0;
    }

    .transportGroupHeader{
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:flex-start;
      margin-bottom:8px;
    }

    .transportGroupTitle{
      font-size:13px;
      font-weight:1100;
      color:#0f172a;
      line-height:1.25;
    }

    .transportGroupSub{
      margin-top:3px;
      font-size:12px;
      font-weight:850;
      color:rgba(15,23,42,.55);
      line-height:1.35;
    }

    .transportGroupBadge{
      font-size:11px;
      font-weight:1100;
      color:#1d4ed8;
      background:rgba(37,99,235,.07);
      border:1px solid rgba(37,99,235,.12);
      border-radius:999px;
      padding:6px 8px;
      white-space:nowrap;
    }

    .transportRouteGrid{
      display:grid;
      gap:8px;
    }

    .transportRouteRow{
      display:grid;
      grid-template-columns:1fr auto;
      gap:12px;
      align-items:start;
      border:1px solid rgba(15,23,42,.06);
      background:rgba(248,250,252,.70);
      border-radius:14px;
      padding:10px 11px;
    }

    .transportRouteMain{
      min-width:0;
    }

    .transportRouteTitle{
      font-size:12px;
      font-weight:1100;
      color:rgba(15,23,42,.88);
      line-height:1.25;
    }

    .transportRouteSub{
      margin-top:3px;
      font-size:11px;
      font-weight:850;
      color:rgba(15,23,42,.54);
      line-height:1.35;
    }

    .transportDistance{
      font-size:12px;
      font-weight:1100;
      color:rgba(15,23,42,.52);
      white-space:nowrap;
    }

    .transportMoreHint{
      margin-top:9px;
      font-size:11px;
      font-weight:900;
      color:rgba(15,23,42,.46);
    }

    @media (max-width:980px){
      .transportSummaryGrid{
        grid-template-columns:1fr;
      }
    }

    @media (max-width:680px){
      .intelFullPanel,
      .intelScorePanel{
        grid-template-columns:1fr;
      }
    }



    /* HAVN Transport UX V2 — commuter decision engine */
    .transportV2Shell{
      display:grid;
      gap:14px;
    }

    .transportV2MainCard,
    .transportV2ConnectionSection,
    .transportV2NearbySection,
    .transportV2Additional,
    .transportV2Advanced{
      border:1px solid rgba(15,23,42,.08);
      background:linear-gradient(180deg,#fff,rgba(248,250,252,.96));
      border-radius:20px;
      box-shadow:0 10px 26px rgba(15,23,42,.05);
    }

    .transportV2MainCard{
      padding:16px;
    }

    .transportV2Header{
      display:flex;
      gap:12px;
      align-items:flex-start;
      margin-bottom:14px;
    }

    .transportV2HeaderIcon,
    .transportV2Icon,
    .transportV2NearbyIcon{
      width:42px;
      height:42px;
      border-radius:16px;
      display:grid;
      place-items:center;
      background:rgba(37,99,235,.08);
      border:1px solid rgba(37,99,235,.14);
      font-size:21px;
      flex:0 0 auto;
    }

    .transportV2Header h3,
    .transportV2ConnectionSection h3,
    .transportV2NearbySection h3,
    .transportV2Additional h4{
      margin:0;
      font-size:16px;
      line-height:1.22;
      font-weight:1100;
      color:#0f172a;
      letter-spacing:-.02em;
    }

    .transportV2Header p{
      margin:4px 0 0;
      color:rgba(15,23,42,.58);
      font-size:13px;
      font-weight:850;
      line-height:1.45;
    }

    .transportV2OverviewGrid{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:12px;
    }

    .transportV2OverviewCard{
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:18px;
      padding:14px;
      min-height:198px;
      box-shadow:0 10px 22px rgba(15,23,42,.04);
      display:flex;
      flex-direction:column;
      align-items:flex-start;
    }

    .transportV2Provider{
      margin-top:12px;
      font-size:13px;
      font-weight:950;
      color:#0f172a;
      line-height:1.25;
    }

    .transportV2Count{
      margin-top:4px;
      font-size:22px;
      line-height:1.1;
      font-weight:1100;
      color:#0f172a;
      letter-spacing:-.035em;
    }

    .transportV2Label{
      margin-top:14px;
      color:rgba(15,23,42,.48);
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.06em;
      font-weight:1000;
    }

    .transportV2Nearest{
      margin-top:4px;
      font-size:13px;
      line-height:1.25;
      font-weight:1100;
      color:#0f172a;
    }

    .transportV2Distance{
      margin-top:3px;
      font-size:12px;
      font-weight:1000;
      color:#2563eb;
    }

    .transportV2MiniBadge{
      margin-top:auto;
      display:inline-flex;
      align-items:center;
      border:1px solid rgba(37,99,235,.12);
      background:rgba(37,99,235,.06);
      color:#1d4ed8;
      border-radius:999px;
      padding:7px 9px;
      font-size:11px;
      font-weight:1000;
      line-height:1;
    }

    .transportV2ScoreBand{
      margin-top:14px;
      border:1px solid rgba(22,163,74,.16);
      background:linear-gradient(135deg,rgba(240,253,244,.98),rgba(255,255,255,.98));
      border-radius:18px;
      padding:14px;
      display:flex;
      justify-content:space-between;
      gap:14px;
      align-items:center;
    }

    .transportV2ScoreText{
      display:flex;
      gap:12px;
      align-items:flex-start;
      min-width:0;
    }

    .transportV2ScoreText > span{
      width:34px;
      height:34px;
      border-radius:14px;
      display:grid;
      place-items:center;
      background:#16a34a;
      color:#fff;
      font-weight:1100;
      flex:0 0 auto;
    }

    .transportV2ScoreText strong{
      display:block;
      font-size:15px;
      font-weight:1100;
      color:#0f172a;
      line-height:1.25;
    }

    .transportV2ScoreText p{
      margin:4px 0 0;
      color:rgba(15,23,42,.64);
      font-size:13px;
      font-weight:850;
      line-height:1.45;
    }

    .transportV2ScoreDial{
      text-align:center;
      min-width:104px;
    }

    .transportV2ScoreDial strong{
      font-size:34px;
      line-height:1;
      font-weight:1100;
      color:#16a34a;
      letter-spacing:-.04em;
    }

    .transportV2ScoreDial span{
      font-size:16px;
      font-weight:1000;
      color:rgba(15,23,42,.52);
    }

    .transportV2ScoreDial small{
      display:block;
      margin-top:3px;
      font-size:11px;
      font-weight:1000;
      color:rgba(15,23,42,.52);
    }

    .transportV2ConnectionSection,
    .transportV2NearbySection,
    .transportV2Additional{
      padding:16px;
    }

    .transportV2ConnectionsGrid{
      margin-top:12px;
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:8px;
    }

    .transportV2ConnectionCard{
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:16px;
      padding:11px 9px;
      text-align:center;
      min-height:104px;
      display:flex;
      flex-direction:column;
      justify-content:center;
      gap:4px;
    }

    .transportV2ConnectionIcon{
      font-size:19px;
    }

    .transportV2ConnectionName{
      font-size:12px;
      line-height:1.2;
      font-weight:1100;
      color:#0f172a;
    }

    .transportV2ConnectionDirect{
      font-size:11px;
      font-weight:1100;
      color:#16a34a;
    }

    .transportV2ConnectionMethod{
      font-size:10px;
      line-height:1.25;
      font-weight:850;
      color:rgba(15,23,42,.50);
    }

    .transportV2NearbyGrid{
      margin-top:12px;
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:12px;
    }

    .transportV2NearbyCard{
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:18px;
      padding:14px;
      box-shadow:0 10px 22px rgba(15,23,42,.04);
      min-width:0;
    }

    .transportV2NearbyHead{
      display:flex;
      align-items:center;
      gap:10px;
      margin-bottom:12px;
    }

    .transportV2NearbyHead h4{
      margin:0;
      color:#0f172a;
      font-size:14px;
      font-weight:1100;
      line-height:1.2;
    }

    .transportV2NearbyHead p{
      margin:3px 0 0;
      color:rgba(15,23,42,.52);
      font-size:11px;
      font-weight:900;
    }

    .transportV2StopRow{
      display:flex;
      justify-content:space-between;
      gap:10px;
      align-items:flex-start;
      margin-bottom:12px;
    }

    .transportV2StopRow strong{
      color:#0f172a;
      font-size:14px;
      line-height:1.3;
      font-weight:1100;
    }

    .transportV2StopRow span{
      color:#2563eb;
      font-size:13px;
      font-weight:1100;
      white-space:nowrap;
    }

    .transportV2DestinationList{
      display:grid;
      gap:8px;
    }

    .transportV2DestinationRow{
      display:grid;
      grid-template-columns:18px 1fr auto;
      align-items:center;
      gap:7px;
      font-size:12px;
      line-height:1.25;
    }

    .transportV2DestinationRow span{
      width:18px;
      height:18px;
      border-radius:999px;
      display:grid;
      place-items:center;
      background:rgba(22,163,74,.10);
      color:#16a34a;
      font-size:11px;
      font-weight:1100;
    }

    .transportV2DestinationRow strong{
      color:rgba(15,23,42,.78);
      font-weight:950;
    }

    .transportV2DestinationRow em{
      font-style:normal;
      color:#2563eb;
      background:rgba(37,99,235,.06);
      border:1px solid rgba(37,99,235,.10);
      border-radius:999px;
      padding:4px 7px;
      font-size:10px;
      font-weight:1000;
    }

    .transportV2CardButton{
      margin-top:14px;
      border:1px solid rgba(37,99,235,.13);
      background:rgba(37,99,235,.06);
      color:#1d4ed8;
      border-radius:999px;
      padding:10px 12px;
      text-align:center;
      font-size:12px;
      font-weight:1100;
      cursor:pointer;
      user-select:none;
    }

    .transportV2InlineDetails{
      margin-top:14px;
    }

    .transportV2InlineDetails summary{
      list-style:none;
      cursor:pointer;
    }

    .transportV2InlineDetails summary::-webkit-details-marker{
      display:none;
    }

    .transportV2InlineDetails[open] .transportV2CardButton{
      background:rgba(15,23,42,.04);
      color:rgba(15,23,42,.74);
      border-color:rgba(15,23,42,.10);
    }

    .transportV2InlineDetails[open] .transportOpenLabel{
      display:none !important;
    }

    .transportV2InlineDetails[open] .transportCloseLabel{
      display:inline !important;
    }

    .transportV2InlineRows{
      margin-top:10px;
      display:grid;
      gap:7px;
      border-top:1px solid rgba(15,23,42,.08);
      padding-top:10px;
    }

    .transportV2InlineRow{
      display:grid;
      grid-template-columns:minmax(0,1fr) auto;
      gap:8px;
      align-items:start;
      padding:8px 9px;
      border:1px solid rgba(15,23,42,.07);
      background:rgba(248,250,252,.78);
      border-radius:12px;
      font-size:11px;
      line-height:1.3;
    }

    .transportV2InlineRow strong{
      display:block;
      color:rgba(15,23,42,.88);
      font-weight:1050;
    }

    .transportV2InlineRow span{
      display:block;
      margin-top:3px;
      color:rgba(15,23,42,.56);
      font-weight:850;
    }

    .transportV2InlineRow em{
      font-style:normal;
      color:#2563eb;
      font-weight:1000;
      white-space:nowrap;
    }

    .transportV2AdditionalGrid{
      margin-top:12px;
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px;
    }

    .transportV2AdditionalCard{
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:16px;
      padding:12px;
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:flex-start;
    }

    .transportV2AdditionalCard strong,
    .transportV2AdditionalCard span,
    .transportV2AdditionalCard p{
      display:block;
    }

    .transportV2AdditionalCard strong{
      font-size:13px;
      font-weight:1100;
      color:#0f172a;
    }

    .transportV2AdditionalCard span{
      margin-top:3px;
      font-size:11px;
      font-weight:900;
      color:rgba(15,23,42,.52);
    }

    .transportV2AdditionalCard p{
      margin:8px 0 0;
      font-size:12px;
      font-weight:850;
      line-height:1.35;
      color:rgba(15,23,42,.66);
    }

    .transportV2AdditionalCard em{
      font-style:normal;
      font-size:12px;
      color:#2563eb;
      font-weight:1100;
      white-space:nowrap;
    }

    .transportV2AdditionalDetails{
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:16px;
      overflow:hidden;
    }

    .transportV2AdditionalDetails summary{
      list-style:none;
      cursor:pointer;
    }

    .transportV2AdditionalDetails summary::-webkit-details-marker{
      display:none;
    }

    .transportV2AdditionalDetails .transportV2AdditionalCard{
      border:0;
      border-radius:0;
    }

    .transportV2AdditionalDetails[open] .transportV2AdditionalCard{
      border-bottom:1px solid rgba(15,23,42,.08);
    }

    .transportV2AdditionalRouteRows{
      display:grid;
      gap:7px;
      padding:10px 12px 12px;
      background:rgba(248,250,252,.72);
    }

    .transportV2Advanced{
      overflow:hidden;
    }

    .transportV2Advanced summary{
      list-style:none;
      cursor:pointer;
      display:flex;
      justify-content:center;
      gap:10px;
      align-items:center;
      padding:15px;
      color:#2563eb;
      font-size:13px;
      font-weight:1100;
      user-select:none;
    }

    .transportV2Advanced summary::-webkit-details-marker{
      display:none;
    }

    .transportV2Advanced summary strong{
      font-size:12px;
      font-weight:1100;
    }

    .transportV2Advanced[open] summary{
      border-bottom:1px solid rgba(15,23,42,.08);
    }

    .transportV2AdvancedBody{
      padding:14px;
      display:grid;
      gap:12px;
    }

    .transportV2DetailGroup{
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:16px;
      overflow:hidden;
    }

    .transportV2DetailHead{
      padding:12px;
      display:flex;
      justify-content:space-between;
      gap:10px;
      border-bottom:1px solid rgba(15,23,42,.06);
    }

    .transportV2DetailHead strong,
    .transportV2DetailHead span{
      display:block;
    }

    .transportV2DetailHead strong{
      font-size:13px;
      font-weight:1100;
      color:#0f172a;
    }

    .transportV2DetailHead span{
      margin-top:3px;
      font-size:11px;
      font-weight:850;
      color:rgba(15,23,42,.52);
    }

    .transportV2DetailHead em{
      font-style:normal;
      font-size:11px;
      font-weight:1100;
      color:#2563eb;
      background:rgba(37,99,235,.06);
      border:1px solid rgba(37,99,235,.10);
      border-radius:999px;
      padding:6px 8px;
      height:max-content;
      white-space:nowrap;
    }

    .transportV2DetailRows{
      display:grid;
      gap:0;
    }

    .transportV2DetailRow{
      display:grid;
      grid-template-columns:100px 1fr auto;
      gap:10px;
      padding:10px 12px;
      border-top:1px solid rgba(15,23,42,.05);
      align-items:center;
      font-size:12px;
    }

    .transportV2DetailRow:first-child{
      border-top:0;
    }

    .transportV2DetailRow span{
      color:#0f172a;
      font-weight:950;
    }

    .transportV2DetailRow strong{
      color:rgba(15,23,42,.64);
      font-weight:850;
      line-height:1.3;
    }

    .transportV2DetailRow em{
      font-style:normal;
      color:rgba(15,23,42,.52);
      font-weight:950;
      white-space:nowrap;
    }

    .transportV2EmptyLine{
      grid-column:1/-1;
      border:1px dashed rgba(15,23,42,.12);
      background:rgba(248,250,252,.75);
      border-radius:14px;
      padding:12px;
      color:rgba(15,23,42,.58);
      font-size:12px;
      font-weight:900;
      line-height:1.4;
    }

    @media (max-width:860px){
      .transportV2OverviewGrid,
      .transportV2NearbyGrid{
        grid-template-columns:1fr;
      }

      .transportV2ConnectionsGrid{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }
    }

    @media (max-width:680px){
      .transportV2MainCard,
      .transportV2ConnectionSection,
      .transportV2NearbySection,
      .transportV2Additional{
        padding:13px;
        border-radius:18px;
      }

      .transportV2ScoreBand{
        align-items:flex-start;
        flex-direction:column;
      }

      .transportV2ScoreDial{
        text-align:left;
      }

      .transportV2ConnectionsGrid,
      .transportV2AdditionalGrid{
        grid-template-columns:1fr;
      }

      .transportV2DetailRow{
        grid-template-columns:1fr;
        gap:4px;
      }

      .transportV2Advanced summary{
        flex-direction:column;
        gap:4px;
      }
    }

    .safetyCard{
      border:1px solid rgba(245,158,11,.22);
      background:linear-gradient(180deg,rgba(255,251,235,.96),#fff);
      border-radius:18px;
      padding:14px;
    }

    .safetyCard h3{
      margin:0 0 8px;
      font-size:14px;
      font-weight:1100;
      color:rgba(120,53,15,.98);
    }

    .safetyCard ul{
      margin:0;
      padding-left:18px;
      color:rgba(15,23,42,.72);
      font-size:12px;
      font-weight:850;
      line-height:1.55;
    }

    .advertiserCard{
      border:1px solid rgba(15,23,42,.08);
      background:#fff;
      border-radius:18px;
      padding:14px;
    }

    .avatarCircle{
      width:42px;
      height:42px;
      border-radius:16px;
      background:linear-gradient(135deg,#0f172a,#2563eb);
      color:#fff;
      display:grid;
      place-items:center;
      font-weight:1100;
      flex:0 0 auto;
    }

    .advertiserTop{
      display:flex;
      gap:10px;
      align-items:center;
      margin-bottom:12px;
    }

    .advertiserName{
      font-weight:1100;
      line-height:1.2;
    }

    .advertiserType{
      margin-top:2px;
      font-size:12px;
      font-weight:850;
      color:rgba(15,23,42,.55);
    }

    .sideStack{
      display:grid;
      gap:12px;
    }

    .contactCard{
      position:relative;
    }

    .stickyMobileBar{
      position:fixed;
      left:0;
      right:0;
      bottom:0;
      z-index:9998;
      display:none;
      gap:8px;
      padding:10px 12px calc(10px + env(safe-area-inset-bottom));
      background:rgba(255,255,255,.94);
      border-top:1px solid rgba(15,23,42,.10);
      box-shadow:0 -14px 30px rgba(15,23,42,.12);
      backdrop-filter:blur(10px);
    }

    .stickyMobileBar button{
      border:1px solid rgba(15,23,42,.10);
      border-radius:15px;
      padding:12px 10px;
      font-weight:1100;
      font-size:12px;
      background:#fff;
      color:rgba(15,23,42,.88);
      cursor:pointer;
    }

    .stickyMobileBar .mobilePrimary{
      flex:1.4;
      background:linear-gradient(135deg,#2563eb,#0ea5e9);
      color:#fff;
      border-color:rgba(37,99,235,.35);
    }

    .stickyMobileBar .mobileSecondary{
      flex:1;
    }

    @media (max-width:980px){
      .commandShell,
      .contentGridV2{
        grid-template-columns:1fr;
      }

      .actionCard{
        position:relative;
        top:auto;
      }

      .factsBar,
      .trustStrip{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }

      .insightGrid,
      .detailGridV2{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }

      .locationIntelGrid{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }
    }

    @media (max-width:680px){
      .wrap{
        padding-bottom:104px;
      }

      .commandPanel,
      .actionCard,
      .sectionCard{
        border-radius:20px;
        padding:14px;
      }

      .commandPrice{
        font-size:35px;
        line-height:1.07;
        letter-spacing:-.026em;
        font-weight:650;
      }

      .commandTitle{
        font-size:21px;
        line-height:1.3;
        font-weight:700;
      }

      .commandAddress{
        font-size:13px;
        line-height:1.48;
        font-weight:650;
      }

      .factsBar,
      .trustStrip,
      .insightGrid,
      .detailGridV2,
      .locationIntelGrid{
        grid-template-columns:1fr 1fr;
      }

      .factTile{
        min-height:70px;
        padding:11px;
      }

      .secondaryActions{
        grid-template-columns:1fr;
      }

      .stickyMobileBar{
        display:flex;
      }
    }


    /* HAVN credibility upgrade — gallery mosaic + price drop */
    .priceDropLine{
      display:none;
      align-items:center;
      gap:8px;
      margin:-6px 0 14px;
      color:#166534;
      font-size:14px;
      line-height:1.35;
      font-weight:1000;
    }

    .priceDropLine strong{
      font-weight:1100;
    }
    
    .priceHistoryBox{
  margin:0 0 14px;
  border:1px solid rgba(15,23,42,.08);
  background:#fff;
  border-radius:16px;
  overflow:hidden;
  display:none;
}

    .priceHistoryToggle{
      width:100%;
      border:0;
      background:#fff;
      padding:12px 14px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      cursor:pointer;
      font-family:inherit;
      font-size:13px;
      font-weight:1100;
      color:#0f172a;
    }
    
    .priceHistoryToggle span:last-child{
      color:rgba(15,23,42,.48);
    }
    
    .priceHistoryBody{
      display:none;
      border-top:1px solid rgba(15,23,42,.08);
      padding:10px 14px 12px;
    }
    
    .priceHistoryBox.open .priceHistoryBody{
      display:block;
    }
    
    .priceHistoryRow{
      display:grid;
      grid-template-columns:110px 1fr auto;
      gap:12px;
      align-items:center;
      padding:9px 0;
      font-size:12px;
      font-weight:900;
      color:rgba(15,23,42,.78);
    }
    
    .priceHistoryRow + .priceHistoryRow{
      border-top:1px solid rgba(15,23,42,.06);
    }
    
    .priceHistoryDate{
      color:rgba(15,23,42,.55);
    }
    
    .priceHistoryEvent{
      color:rgba(15,23,42,.82);
    }
    
    .priceHistoryPrice{
      color:#0f172a;
      font-weight:1100;
    }
    
    .marketTimingLine{
      display:none;
      gap:14px;
      flex-wrap:wrap;
      margin:-4px 0 14px;
      font-size:13px;
      font-weight:950;
      color:rgba(15,23,42,.70);
    }
    
    .marketTimingLine span{
      display:inline-flex;
      align-items:center;
      gap:6px;
    }
    
    @media (max-width:680px){
      .priceHistoryRow{
        grid-template-columns:1fr;
        gap:3px;
      }
    }

    .priceDropBadge{
      display:none;
      align-items:center;
      gap:7px;
      border-radius:999px;
      padding:7px 10px;
      font-size:12px;
      font-weight:1000;
      border:1px solid rgba(22,163,74,.20);
      background:rgba(22,163,74,.08);
      color:#166534;
    }


    .lb{
      position:fixed;
      inset:0;
      background:rgba(2,6,23,.82);
      z-index:99999;
      display:none;
      align-items:center;
      justify-content:center;
      padding:22px;
    }

    .lb.open{display:flex}

    .lbCard{
      width:min(1200px,calc(100vw - 24px));
      height:min(760px,calc(100vh - 24px));
      border-radius:22px;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.14);
      box-shadow:0 18px 60px rgba(0,0,0,.35);
      background:rgba(15,23,42,.65);
      display:flex;
      flex-direction:column;
    }

    .lbTop{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:10px 12px;
      background:rgba(15,23,42,.65);
      border-bottom:1px solid rgba(255,255,255,.10);
      color:rgba(255,255,255,.92);
      font-weight:900;
      font-size:12px;
    }

    .lbBtn{
      border:1px solid rgba(255,255,255,.18);
      background:rgba(255,255,255,.06);
      color:rgba(255,255,255,.92);
      font-weight:1000;
      font-size:12px;
      padding:8px 10px;
      border-radius:999px;
      cursor:pointer;
    }

    .lbMain{
      position:relative;
      flex:1;
      display:flex;
      align-items:center;
      justify-content:center;
      background:rgba(2,6,23,.35);
      overflow:hidden;
    }

    .lbImg{
      width:100%;
      height:100%;
      object-fit:contain;
      display:block;
      cursor:pointer;
    }

    .lbNav{
      position:absolute;
      top:50%;
      transform:translateY(-50%);
      width:46px;
      height:46px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.18);
      background:rgba(255,255,255,.08);
      color:#fff;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:1000;
      cursor:pointer;
      z-index:5;
    }

    .lbPrev{left:12px}
    .lbNext{right:12px}

    .lbStrip{
      padding:10px;
      background:rgba(15,23,42,.65);
      border-top:1px solid rgba(255,255,255,.10);
    }

    .lbStripRow{
      display:flex;
      gap:10px;
      overflow:auto;
    }

    .lbThumb{
      flex:0 0 auto;
      width:86px;
      height:58px;
      border-radius:12px;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.14);
      cursor:pointer;
      opacity:.85;
    }

    .lbThumb.active{
      border-color:rgba(37,99,235,.95);
      box-shadow:0 0 0 4px rgba(37,99,235,.16);
      opacity:1;
    }

    .lbThumb img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }

    @media (max-width:680px){
        .hero img{
          height:min(64vh,520px);
          min-height:360px;
          object-fit:contain;
          background:#020617;
        }
    
      .galleryStrip{
        padding:12px;
        border-radius:20px;
      }
    
      .stripRow{
        gap:12px;
        scroll-snap-type:x mandatory;
      }
    
      .thumbBtn{
        width:148px;
        height:96px;
        border-radius:16px;
        scroll-snap-align:start;
      }
    
      .thumbBtn.active{
        box-shadow:0 0 0 4px rgba(37,99,235,.18);
      }
    
      .lb{
        padding:0;
        background:rgba(2,6,23,.94);
      }
    
      .lbCard{
        width:100vw;
        height:100dvh;
        max-height:100dvh;
        border-radius:0;
        border:0;
        box-shadow:none;
      }
    
      .lbImg{
        max-height:calc(100dvh - 190px);
        object-fit:contain;
      }
    
      .lbNav{
        width:54px;
        height:54px;
        font-size:28px;
      }
    
      .lbThumb{
        width:112px;
        height:76px;
        border-radius:16px;
      }
    
      .lbThumb.active{
        box-shadow:0 0 0 4px rgba(37,99,235,.28);
      }
    }

    @media (max-width:980px){
      .grid{grid-template-columns:1fr}
      .nav{display:none}
      .cardsGrid{grid-template-columns:1fr 1fr}
    }

    @media (max-width:680px){
      .cardsGrid{grid-template-columns:1fr}

      .topbar{
        border-radius:18px;
        align-items:center;
        padding:10px;
        gap:10px;
      }

      .propertyMobileMenuBtn{
        display:flex;
      }

      .brand{
        flex:1;
        min-width:0;
      }

      .actions{
        justify-content:flex-end;
        flex:0 0 auto;
      }

      .actions .pill{
        display:none;
      }

      .actions .propMobileBrowse{
        display:inline-flex;
        padding:10px 13px;
        font-size:12px;
      }

      .dot{
        width:30px;
        height:30px;
      }
    }
  </style>
</head>

<body>
  <div class="wrap">
    <div class="topbar">
      <button class="propertyMobileMenuBtn" id="propertyMobileMenuBtn" type="button" aria-label="Open navigation menu" aria-expanded="false">☰</button>

      <div class="brand">
        <div class="dot" aria-hidden="true"></div>
        <div style="line-height:1.1">
          <div style="font-weight:1000;font-size:13px;">havn.ie</div>
          <div style="font-weight:850;font-size:11px;color:rgba(15,23,42,.55);">Property detail</div>
        </div>
      </div>

      <div class="nav">
        <a href="/properties.html?mode=buy">Buy</a>
        <a href="/properties.html?mode=rent">Rent</a>
        <a href="/properties.html?mode=share">Share</a>
        <a href="/properties.html">Browse</a>
      </div>

      <div class="actions">
        <a class="pill" href="/dashboard.html">Dashboard</a>
        <a class="pill propMobileBrowse" href="/properties.html">Browse</a>
        <a class="pill primary" href="/property-upload.html">List a property</a>
      </div>
    </div>

    <div class="propertyMobileMenu" id="propertyMobileMenu" aria-hidden="true">
      <a href="/dashboard.html">Dashboard <span>›</span></a>
      <a href="/properties.html">Browse listings <span>›</span></a>
      <a href="/property-upload.html">List a property <span>›</span></a>
      <div class="menuDivider"></div>
      <a href="/properties.html?mode=buy">Buy <span>›</span></a>
      <a href="/properties.html?mode=rent">Rent <span>›</span></a>
      <a href="/properties.html?mode=share">Share <span>›</span></a>
    </div>

    <div class="panel err" id="errBox" style="display:none;">
      <div style="font-weight:1000;margin-bottom:6px;">Couldn't load this property</div>
      <div class="mono" id="errText"></div>
    </div>

    <div class="hero" id="hero" title="Click to view full-screen">
      <img id="heroImg" alt="" />
      <div class="heroScrim" aria-hidden="true"></div>
      <div class="heroBadgeRow" aria-hidden="true">
        <div class="heroBadge">Click to view gallery</div>
        <div class="heroCount" id="heroCount" style="display:none;">—</div>
      </div>
    </div>

    <div class="galleryStrip" id="galleryStrip">
      <div class="stripRow" id="stripRow"></div>
      <div class="stripHint">
        <span>Click a thumbnail to change the hero.</span>
        <span>Click the hero to open full-screen.</span>
      </div>
    </div>

    <div id="main" style="display:none;">
      <div class="commandShell">
        <section class="commandPanel" aria-label="Property summary">
          <div class="commandEyebrow">
            <span class="modeBadge" id="commandMode">Property</span>
            <span class="verifiedBadge" id="verifiedBadge">✓ HAVN verified listing</span>
            <span class="featuredBadge" id="featuredBadge">Featured</span>
            <span class="priceDropBadge" id="priceDropBadge">↓ Price reduced</span>
          </div>

          <div class="commandPrice" id="commandPrice">—</div>
          <div class="priceDropLine" id="priceDropLine"></div>
          <div class="marketTimingLine" id="marketTimingLine"></div>

            <div class="priceHistoryBox" id="priceHistoryBox">
              <button class="priceHistoryToggle" id="priceHistoryToggle" type="button">
                <span>Price history</span>
                <span id="priceHistoryChevron">⌄</span>
              </button>
              <div class="priceHistoryBody" id="priceHistoryBody"></div>
            </div>
          <h1 class="commandTitle" id="title">—</h1>
          <div class="commandAddress" id="addr">—</div>

          <div class="factsBar" id="factsBar"></div>

          <div class="trustStrip">
            <div class="trustTile">
              <div class="trustLabel">Status</div>
              <div class="trustValue" id="trustStatus">Published on HAVN</div>
            </div>
            <div class="trustTile">
              <div class="trustLabel">Listed</div>
              <div class="trustValue" id="trustListed">—</div>
            </div>
            <div class="trustTile">
              <div class="trustLabel">Updated</div>
              <div class="trustValue" id="trustUpdated">—</div>
            </div>
            <div class="trustTile">
              <div class="trustLabel">Reference</div>
              <div class="trustValue" id="trustRef">—</div>
            </div>
          </div>

          <div class="meta" id="tags" style="display:none;"></div>
        </section>

        <aside class="actionCard" aria-label="Property actions">
          <h2 class="actionTitle" id="actionTitle">Arrange a viewing</h2>
          <p class="actionSub" id="actionSub">Send a direct enquiry about this property. Keep payments and deposits offline until you have viewed and verified the listing.</p>

          <button class="bigAction" id="topEnquiryBtn" type="button">Request viewing</button>

          <div class="secondaryActions">
            <button class="ghostBtn" id="saveBtn" type="button">♡ Save property</button>
            <button class="ghostBtn" id="shareBtn" type="button">↗ Share property</button>
          </div>

          <div class="actionTrustList">
            <div class="actionTrustItem"><span class="tick">✓</span><span id="actionVerifiedText">Published listing checked by HAVN before going live.</span></div>
            <div class="actionTrustItem"><span class="tick">✓</span><span id="actionRefText">Property reference: —</span></div>
            <div class="actionTrustItem"><span class="tick">✓</span><span>Direct enquiry sent securely through HAVN.</span></div>
          </div>

          <button class="reportBtn" id="reportBtn" type="button">Report this listing</button>
        </aside>
      </div>

      <div class="contentGridV2">
        <main>
          <section class="sectionCard" id="financialBlock">
            <div class="sectionHeader">
              <div>
                <h2 id="financialTitle">Financial snapshot</h2>
                <p class="sectionNote" id="financialNote">Helpful estimates for quick decision-making. Figures are indicative only.</p>
              </div>
            </div>
            <div class="insightGrid" id="financialGrid"></div>
          </section>

          <section class="sectionCard">
            <div class="sectionHeader">
              <div>
                <h2>Property details</h2>
                <p class="sectionNote">Mode-specific details organised so buyers, renters and sharers can make a faster decision.</p>
              </div>
              <div class="kdBadge" id="publicBadge">
                <span class="kdBadgeDot"></span>
                <span>Published</span>
              </div>
            </div>
            <div id="detailSections"></div>
            <div class="kdGrid" id="kdGrid" style="display:none;"></div>
          </section>

          <section class="sectionCard">
            <div class="sectionHeader">
              <div>
                <h2>Description</h2>
                <p class="sectionNote">Seller-provided description.</p>
              </div>
            </div>
            <div class="desc" id="desc">—</div>
          </section>

          <section class="featuresBlock" id="featuresBlock">
            <div class="sectionHeader">
              <div>
                <h2>Key features</h2>
                <p class="sectionNote">Highlights provided by the advertiser.</p>
              </div>
            </div>
            <div class="featuresGrid" id="featuresGrid"></div>
          </section>

        </main>

        <aside class="sideStack">
          <section class="contactCard" id="contactCard">
            <h3 class="contactTitle" id="contactTitle">Contact advertiser</h3>
            <p class="contactSub" id="contactSub">Ask a question, request a viewing, or register your interest in this property.</p>

            <div class="contactTrust">
              <span class="miniTrust">✓ Direct enquiry</span>
              <span class="miniTrust">✓ HAVN listing reference</span>
              <span class="miniTrust">✓ Safety-first guidance</span>
            </div>

            <div class="formField">
              <label class="formLabel" for="contactName">Name</label>
              <input id="contactName" class="formInput" type="text" placeholder="Your full name">
            </div>

            <div class="formField">
              <label class="formLabel" for="contactEmail">Email</label>
              <input id="contactEmail" class="formInput" type="email" placeholder="you@example.com">
            </div>

            <div class="formField">
              <label class="formLabel" for="contactPhone">Phone (optional)</label>
              <input id="contactPhone" class="formInput" type="text" placeholder="Phone number">
            </div>

            <div class="formField">
              <label class="formLabel" for="contactMessage">Message</label>
              <textarea id="contactMessage" class="formTextarea" placeholder="Hi, I'm interested in this property and would like to arrange a viewing."></textarea>
            </div>

            <div class="contactActions">
              <button class="contactBtn primary" id="contactSendBtn" type="button">Request viewing</button>
              <button class="contactBtn" id="contactAskBtn" type="button">Ask question</button>
            </div>

            <div class="contactState" id="contactState"></div>
          </section>

          <section class="advertiserCard">
            <div class="advertiserTop">
              <div class="avatarCircle" id="advertiserInitial">H</div>
              <div>
                <div class="advertiserName" id="advertiserName">HAVN advertiser</div>
                <div class="advertiserType" id="advertiserType">Listing contact</div>
              </div>
            </div>
            <div class="actionTrustList">
              <div class="actionTrustItem"><span class="tick">✓</span><span id="advertiserVerification">Advertiser details available through the enquiry form.</span></div>
              <div class="actionTrustItem"><span class="tick">✓</span><span id="advertiserModeHelp">Ask for viewing times, availability and supporting details before committing.</span></div>
            </div>
          </section>

          <section class="safetyCard">
            <h3>HAVN safety guidance</h3>
            <ul>
              <li>Never transfer rent, deposits or holding fees before viewing and verifying the listing.</li>
              <li>Be cautious of pressure tactics, unusually low prices or requests to move conversations off-platform.</li>
              <li>Use “Report this listing” if anything looks suspicious or inaccurate.</li>
            </ul>
          </section>
        </aside>
      </div>

      <section class="sectionCard propertyIntelligenceFull" id="propertyIntelligenceSection">
        <div class="sectionHeader">
          <div>
            <h2>Property Intelligence</h2>
            <p class="sectionNote" id="locationNote">Schools, transport, amenities, market context and HAVN decision signals.</p>
          </div>
        </div>

        <div class="mapBlock" id="mapBlock">
          <div class="mapHdr">
            <div class="ttl">Google Maps</div>
            <div class="mapActions">
              <a class="miniBtn" id="openMapsBtn" href="#" target="_blank" rel="noopener">Open</a>
              <a class="miniBtn" id="directionsBtn" href="#" target="_blank" rel="noopener">Directions</a>
              <button class="miniBtn" id="copyLocBtn" type="button">Copy</button>
            </div>
          </div>

          <div class="mapFrame">
            <iframe id="mapFrame" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
          </div>
          <div class="mapCaption" id="mapCaption"></div>
        </div>

        <div class="locationIntelGrid" id="locationIntelGrid"></div>
      </section>

      <section class="sectionCard">
        <div class="sectionHeader">
          <div>
            <h2 id="similarTitle">Similar properties</h2>
            <p class="sectionNote" id="similarNote">Closest available alternatives from published HAVN listings.</p>
          </div>
        </div>
        <div class="cardsGrid" id="similarGrid"></div>
        <div class="emptyState" id="similarEmpty" style="display:block;">Similar properties will appear here.</div>
      </section>

      <section class="sectionCard">
        <div class="sectionHeader">
          <div>
            <h2>Recently viewed</h2>
            <p class="sectionNote">Quickly return to homes you have already opened.</p>
          </div>
        </div>
        <div class="cardsGrid" id="recentGrid"></div>
        <div class="emptyState" id="recentEmpty" style="display:none;">Your recently viewed properties will appear here.</div>
      </section>
    </div>

    <div class="stickyMobileBar" id="stickyMobileBar">
      <button class="mobilePrimary" id="mobileEnquiryBtn" type="button">Request viewing</button>
      <button class="mobileSecondary" id="mobileSaveBtn" type="button">♡ Save</button>
      <button class="mobileSecondary" id="mobileShareBtn" type="button">Share</button>
    </div>

  <div class="lb" id="lb">
    <div class="lbCard" role="dialog" aria-modal="true" aria-label="Gallery">
      <div class="lbTop">
        <div id="lbTitle">Gallery</div>
        <button class="lbBtn" id="lbClose" type="button">Close</button>
      </div>
      <div class="lbMain" id="lbMain">
        <div class="lbNav lbPrev" id="lbPrev">‹</div>
        <img class="lbImg" id="lbImg" alt="" />
        <div class="lbNav lbNext" id="lbNext">›</div>
      </div>
      <div class="lbStrip">
        <div class="lbStripRow" id="lbStripRow"></div>
      </div>
    </div>
  </div>

  <script type="application/ld+json" id="propertySchema">
    {
      "@context": "https://schema.org",
      "@type": "Residence",
      "name": "HAVN.ie Property"
    }
  </script>

  <script>
    (function(){
      "use strict";

      const API = "https://api.havn.ie";
      const STORAGE_RECENT = "havn_recent_properties_v1";

      let PHOTOS = [];
      let ACTIVE = 0;
      let CURRENT_PROPERTY = null;
      let PROPERTY_VIEW_TRACKED = false;
      let currentPropertyController = null;

      const $ = (id) => document.getElementById(id);

      const errBox = $("errBox");
      const errText = $("errText");
      const hero = $("hero");
      const heroImg = $("heroImg");
      const heroCount = $("heroCount");
      const galleryStrip = $("galleryStrip");
      const stripRow = $("stripRow");
      const main = $("main");
      const title = $("title");
      const addr = $("addr");
      const tags = $("tags");
      const commandMode = $("commandMode");
      const featuredBadge = $("featuredBadge");
      const priceDropBadge = $("priceDropBadge");
      const priceDropLine = $("priceDropLine");
      const marketTimingLine = $("marketTimingLine");
      const priceHistoryBox = $("priceHistoryBox");
      const priceHistoryToggle = $("priceHistoryToggle");
      const priceHistoryChevron = $("priceHistoryChevron");
      const priceHistoryBody = $("priceHistoryBody");
      const verifiedBadge = $("verifiedBadge");
      const commandPrice = $("commandPrice");
      const factsBar = $("factsBar");
      const trustListed = $("trustListed");
      const trustUpdated = $("trustUpdated");
      const trustRef = $("trustRef");
      const trustStatus = $("trustStatus");
      const actionTitle = $("actionTitle");
      const actionSub = $("actionSub");
      const actionVerifiedText = $("actionVerifiedText");
      const actionRefText = $("actionRefText");
      const topEnquiryBtn = $("topEnquiryBtn");
      const reportBtn = $("reportBtn");
      const financialBlock = $("financialBlock");
      const financialTitle = $("financialTitle");
      const financialNote = $("financialNote");
      const financialGrid = $("financialGrid");
      const detailSections = $("detailSections");
      const locationIntelGrid = $("locationIntelGrid");
      const contactTitle = $("contactTitle");
      const contactSub = $("contactSub");
      const advertiserInitial = $("advertiserInitial");
      const advertiserName = $("advertiserName");
      const advertiserType = $("advertiserType");
      const advertiserVerification = $("advertiserVerification");
      const advertiserModeHelp = $("advertiserModeHelp");
      const mobileEnquiryBtn = $("mobileEnquiryBtn");
      const mobileSaveBtn = $("mobileSaveBtn");
      const mobileShareBtn = $("mobileShareBtn");
      const desc = $("desc");
      const featuresBlock = $("featuresBlock");
      const featuresGrid = $("featuresGrid");
      const saveBtn = $("saveBtn");
      const shareBtn = $("shareBtn");
      const kdGrid = $("kdGrid");
      const publicBadge = $("publicBadge");
      const mapBlock = $("mapBlock");
      const mapFrame = $("mapFrame");
      const openMapsBtn = $("openMapsBtn");
      const directionsBtn = $("directionsBtn");
      const copyLocBtn = $("copyLocBtn");
      const mapCaption = $("mapCaption");
      const recentGrid = $("recentGrid");
      const recentEmpty = $("recentEmpty");
      const similarGrid = $("similarGrid");
      const similarEmpty = $("similarEmpty");
      const similarTitle = $("similarTitle");
      const similarNote = $("similarNote");
      const contactName = $("contactName");
      const contactEmail = $("contactEmail");
      const contactPhone = $("contactPhone");
      const contactMessage = $("contactMessage");
      const contactSendBtn = $("contactSendBtn");
      const contactAskBtn = $("contactAskBtn");
      const contactState = $("contactState");
      const lb = $("lb");
      const lbImg = $("lbImg");
      const lbTitle = $("lbTitle");
      const lbClose = $("lbClose");
      const lbPrev = $("lbPrev");
      const lbNext = $("lbNext");
      const lbStripRow = $("lbStripRow");
      const propertyMobileMenuBtn = $("propertyMobileMenuBtn");
      const propertyMobileMenu = $("propertyMobileMenu");

      function qs(name){
        try{return new URL(location.href).searchParams.get(name)}
        catch{return null}
      }

      function esc(s){
        return String(s || "").replace(/[&<>"']/g, m => ({
          "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"
        }[m]));
      }

      function plausibleTrack(eventName, props){
        if(!window.plausible || typeof window.plausible !== "function") return;
        try{ window.plausible(eventName, props ? { props } : undefined); }catch{}
      }

      function showErr(msg){
        if(errBox) errBox.style.display = "block";
        if(errText) errText.textContent = msg;
        if(main) main.style.display = "none";
      }

      function hideErr(){
        if(errBox) errBox.style.display = "none";
      }

      async function getJson(res){
        const text = await res.text().catch(() => "");
        let json = null;
        try{ json = text ? JSON.parse(text) : null; }catch{}
        return { text, json };
      }

      function normalize(obj){
        if(!obj) return null;
        if(obj.item) return obj.item;
        if(obj.property) return obj.property;
        if(obj.listing) return obj.listing;
        if(obj.data && !Array.isArray(obj.data)) return obj.data;
        return obj;
      }

      function extractListFromPayload(data){
        if(!data) return [];
        if(Array.isArray(data)) return data;

        if(Array.isArray(data.items)) return data.items;
        if(Array.isArray(data.properties)) return data.properties;
        if(Array.isArray(data.listings)) return data.listings;
        if(Array.isArray(data.results)) return data.results;
        if(Array.isArray(data.rows)) return data.rows;
        if(Array.isArray(data.records)) return data.records;

        if(data.data && Array.isArray(data.data)) return data.data;
        if(data.data && Array.isArray(data.data.items)) return data.data.items;
        if(data.data && Array.isArray(data.data.properties)) return data.data.properties;
        if(data.data && Array.isArray(data.data.listings)) return data.data.listings;
        if(data.data && Array.isArray(data.data.results)) return data.data.results;
        if(data.data && Array.isArray(data.data.rows)) return data.data.rows;
        if(data.data && Array.isArray(data.data.records)) return data.data.records;

        if(data.payload && Array.isArray(data.payload)) return data.payload;
        if(data.payload && Array.isArray(data.payload.items)) return data.payload.items;
        if(data.payload && Array.isArray(data.payload.properties)) return data.payload.properties;
        if(data.payload && Array.isArray(data.payload.listings)) return data.payload.listings;
        if(data.payload && Array.isArray(data.payload.results)) return data.payload.results;
        if(data.payload && Array.isArray(data.payload.rows)) return data.payload.rows;
        if(data.payload && Array.isArray(data.payload.records)) return data.payload.records;

        return [];
      }

      function itemMatchesIdentifier(item, value){
        const wanted = String(value || "").trim().toLowerCase();
        if(!wanted || !item) return false;

        return [
          item.slug,
          item.publicSlug,
          item.propertySlug,
          item.listingSlug,
          item.seoSlug,
          item.id,
          item.propertyId,
          item.listingId,
          item.publicId,
          item.uuid,
          item._id
        ].some(v => String(v || "").trim().toLowerCase() === wanted);
      }

      function looksLikeProperty(p){
        if(!p || typeof p !== "object") return false;
        return !!(p.id || p.slug || p.title || p.address || p.price || p.photos || p.images);
      }

      function normalizePhotos(p){
        const raw = p.photos || p.images || p.imageUrls || p.pictures || [];
        const out = [];

        if(Array.isArray(raw)){
          for(const item of raw){
            if(!item) continue;
            if(typeof item === "string") out.push(item);
            else if(typeof item === "object"){
              const u = item.url || item.secure_url || item.src;
              if(u) out.push(u);
            }
          }
        }

        return Array.from(new Set(out.map(x => String(x).trim()).filter(Boolean)));
      }

      function pickCover(p){
        return normalizePhotos(p)[0] || p.cover || p.coverImage || p.image || "";
      }

      function euro(n){
        const num = Number(n);
        if(!Number.isFinite(num) || num <= 0) return "";
        return "€" + num.toLocaleString("en-IE");
      }

      function prettyMode(v){
        const s = String(v || "").toUpperCase();
        if(s === "BUY") return "For sale";
        if(s === "RENT") return "To rent";
        if(s === "SHARE") return "To share";
        return s;
      }

      function prettyType(v){
        const s = String(v || "").trim();
        return s ? s.charAt(0).toUpperCase() + s.slice(1) : "";
      }

      function daysOnHavn(iso){
        if(!iso) return "";
        const d = new Date(iso);
        if(Number.isNaN(d.getTime())) return "";
        const days = Math.max(0, Math.floor((Date.now() - d.getTime()) / 86400000));
        if(days === 0) return "Listed today";
        if(days === 1) return "Listed 1 day ago";
        return "Listed " + days + " days ago";
      }

      function safeReadJson(key){
        try{
          const raw = localStorage.getItem(key);
          if(!raw) return [];
          const parsed = JSON.parse(raw);
          return Array.isArray(parsed) ? parsed : [];
        }catch{
          return [];
        }
      }

      function safeWriteJson(key, value){
        try{ localStorage.setItem(key, JSON.stringify(value)); }catch{}
      }

      function getRecentKey(p, allowUrlFallback){
        const direct = String(
          (p && p.slug) ||
          (p && p.publicSlug) ||
          (p && p.propertySlug) ||
          (p && p.listingSlug) ||
          (p && p.seoSlug) ||
          (p && p.id) ||
          (p && p.propertyId) ||
          (p && p.listingId) ||
          ""
        ).trim();

        if(direct) return direct;

        if(allowUrlFallback){
          return String(qs("slug") || qs("id") || "").trim();
        }

        return "";
      }

      function compactProperty(p){
        const key = getRecentKey(p, true);

        return {
          id:p.id || "",
          slug:key,
          title:p.title || p.address || key || "Property",
          price:p.price ?? "",
          county:p.county || "",
          city:p.city || p.town || "",
          mode:p.mode || "",
          propertyType:p.propertyType || p.type || "",
          bedrooms:p.bedrooms,
          bathrooms:p.bathrooms,
          cover:pickCover(p),
          publishedAt:p.publishedAt || p.createdAt || "",
          address:p.address || p.address1 || "",
          status:p.status || "",
          listingStatus:p.listingStatus || "",
          publicStatus:p.publicStatus || ""
        };
      }

      let SAVED_PROPERTY_IDS = new Set();

      function getAuthToken(){
        try{
          return localStorage.getItem("token");
        }catch{
          return null;
        }
      }

      function getPropertyId(p){
        const id = Number(
          (p && p.id) ||
          (p && p.propertyId) ||
          (p && p.listingId) ||
          0
        );

        return Number.isFinite(id) && id > 0 ? id : null;
      }

      async function loadSavedPropertyIds(){
        const token = getAuthToken();

        if(!token){
          SAVED_PROPERTY_IDS = new Set();
          return;
        }

        try{
          const res = await fetch(API + "/api/auth/saved-properties", {
            method:"GET",
            headers:{
              "Accept":"application/json",
              "Authorization":"Bearer " + token
            },
            cache:"no-store"
          });

          const data = await res.json().catch(() => null);

          if(!res.ok || !data || !data.ok){
            SAVED_PROPERTY_IDS = new Set();
            return;
          }

          const rows = Array.isArray(data.savedProperties) ? data.savedProperties : [];

          SAVED_PROPERTY_IDS = new Set(
            rows
              .map(row => row && (row.propertyId || (row.property && row.property.id)))
              .map(Number)
              .filter(id => Number.isFinite(id) && id > 0)
          );
        }catch{
          SAVED_PROPERTY_IDS = new Set();
        }
      }

      function isSavedProperty(p){
        const id = getPropertyId(p);
        return !!id && SAVED_PROPERTY_IDS.has(id);
      }

      function updateSaveButtonForProperty(p){
        const saved = isSavedProperty(p);

        if(saveBtn){
          saveBtn.classList.toggle("saved", saved);
          saveBtn.textContent = saved ? "♥ Saved" : "♡ Save property";
        }

        if(mobileSaveBtn){
          mobileSaveBtn.classList.toggle("saved", saved);
          mobileSaveBtn.textContent = saved ? "♥ Saved" : "♡ Save";
        }
      }

      async function toggleSavedProperty(p){
        const token = getAuthToken();

        if(!token){
          const next = window.location.pathname + window.location.search;
          window.location.href = "/login.html?next=" + encodeURIComponent(next);
          return;
        }

        const propertyId = getPropertyId(p);
        const slug = getRecentKey(p, true);

        if(!propertyId){
          alert("Could not save this property yet. Missing property ID.");
          return;
        }

        const currentlySaved = SAVED_PROPERTY_IDS.has(propertyId);
        const originalText = saveBtn ? saveBtn.textContent : "";

        if(saveBtn){
          saveBtn.disabled = true;
          saveBtn.textContent = currentlySaved ? "Removing…" : "Saving…";
        }
        if(mobileSaveBtn){
          mobileSaveBtn.disabled = true;
          mobileSaveBtn.textContent = currentlySaved ? "Removing…" : "Saving…";
        }

        try{
          const res = await fetch(
            API + "/api/auth/saved-properties" + (currentlySaved ? "/" + encodeURIComponent(propertyId) : ""),
            {
              method: currentlySaved ? "DELETE" : "POST",
              headers:{
                "Content-Type":"application/json",
                "Accept":"application/json",
                "Authorization":"Bearer " + token
              },
              body: currentlySaved ? undefined : JSON.stringify({ propertyId })
            }
          );

          const data = await res.json().catch(() => null);

          if(!res.ok || !data || !data.ok){
            throw new Error((data && data.message) || "Could not update saved property");
          }

          if(currentlySaved){
            SAVED_PROPERTY_IDS.delete(propertyId);
            plausibleTrack("Save Property", { slug, propertyId:String(propertyId), action:"remove" });
          }else{
            SAVED_PROPERTY_IDS.add(propertyId);
            plausibleTrack("Save Property", { slug, propertyId:String(propertyId), action:"save" });
          }

          updateSaveButtonForProperty(p);
        }catch(err){
          console.error("Saved property failed:", err);
          alert(err.message || "Could not update saved property.");

          if(saveBtn){
            saveBtn.textContent = originalText;
          }
          if(mobileSaveBtn){
            mobileSaveBtn.textContent = currentlySaved ? "♥ Saved" : "♡ Save";
          }
        }finally{
          if(saveBtn){
            saveBtn.disabled = false;
          }
          if(mobileSaveBtn){
            mobileSaveBtn.disabled = false;
          }
        }
      }

      function updateSeo(p){
        if(!p) return;

        const titleText =
          p.title ||
          p.address ||
          "Property";

        const priceText =
          p.price ? euro(p.price) : "";

        const addressText = [
          p.address,
          p.city || p.town,
          p.county
        ].filter(Boolean).join(", ");

        const fullTitle =
          priceText
            ? titleText + " • " + priceText + " • HAVN.ie"
            : titleText + " • HAVN.ie";

        const descText =
          p.description ||
          (addressText ? titleText + " in " + addressText + " listed on HAVN.ie" : titleText + " listed on HAVN.ie");

        const image = pickCover(p) || "https://havn.ie/og.png";
        const canonical = window.location.href;

        document.title = fullTitle;

        const setMeta = (selector, value) => {
          const el = document.querySelector(selector);
          if(el && value != null){
            el.setAttribute("content", value);
          }
        };

        setMeta('meta[name="description"]', descText);

        setMeta('meta[property="og:title"]', fullTitle);
        setMeta('meta[property="og:description"]', descText);
        setMeta('meta[property="og:image"]', image);
        setMeta('meta[property="og:url"]', canonical);

        setMeta('meta[name="twitter:title"]', fullTitle);
        setMeta('meta[name="twitter:description"]', descText);
        setMeta('meta[name="twitter:image"]', image);

        const schemaEl = document.getElementById("propertySchema");

        if(schemaEl){
          const schema = {
            "@context":"https://schema.org",
            "@type":"Residence",
            "name": titleText,
            "description": descText,
            "image": image ? [image] : [],
            "url": canonical,
            "address":{
              "@type":"PostalAddress",
              "streetAddress": p.address || "",
              "addressLocality": p.city || p.town || "",
              "addressRegion": p.county || "",
              "postalCode": p.eircode || "",
              "addressCountry":"IE"
            }
          };

          if(p.price){
            schema.offers = {
              "@type":"Offer",
              "price": Number(p.price),
              "priceCurrency":"EUR",
              "availability":"https://schema.org/InStock"
            };
          }

          schemaEl.textContent = JSON.stringify(schema);
        }
      }

      function isRecentlyViewableProperty(p, allowUrlFallback){
        if(!p) return false;

        const key = getRecentKey(p, !!allowUrlFallback);
        if(!key) return false;

        const status = String(p.listingStatus || p.publicStatus || p.status || "").trim().toUpperCase();

        const blockedStatuses = [
          "CLOSED",
          "DELETED",
          "REJECTED",
          "DRAFT",
          "PENDING",
          "ARCHIVED",
          "INACTIVE",
          "UNPUBLISHED",
          "SOLD",
          "WITHDRAWN"
        ];

        return !blockedStatuses.includes(status);
      }

      function pushRecentlyViewed(p){
        if(!isRecentlyViewableProperty(p, true)) return;

        const key = getRecentKey(p, true);
        if(!key) return;

        let list = safeReadJson(STORAGE_RECENT);

        list = list
          .filter(x => isRecentlyViewableProperty(x, false))
          .filter(x => getRecentKey(x, false) !== key);

        safeWriteJson(STORAGE_RECENT, [compactProperty(p)].concat(list).slice(0,12));
      }

      function cardHtml(p){
        const cover = p.cover || pickCover(p);
        const slug = getRecentKey(p, false);
        const titleText = p.title || p.address || slug || "Property";
        const mode = String(p.mode || "").toUpperCase();
        const price = p.price !== "" && p.price != null? (mode === "RENT" || mode === "SHARE"? (euro(p.price) || ("€" + String(p.price))) + " pcm": (euro(p.price) || ("€" + String(p.price)))): "";
        const meta = [p.county,p.city].filter(Boolean).join(", ");
        const drop = getActivePriceDropData(p);
        const chips = [];

        if(p.mode) chips.push(String(p.mode).toUpperCase());
        if(p.propertyType) chips.push(String(p.propertyType));
        if(p.bedrooms != null && p.bedrooms !== "") chips.push(String(p.bedrooms) + " bed");
        if(p.bathrooms != null && p.bathrooms !== "") chips.push(String(p.bathrooms) + " bath");

        return `
          <a class="miniCard" href="/property.html?slug=${encodeURIComponent(slug)}">
            ${cover ? `<img class="miniCardMedia" src="${esc(cover)}" alt="">` : `<div class="miniCardMedia"></div>`}
            <div class="miniCardBody">
              <div class="miniPrice">${esc(price)}</div>
              ${drop ? `<div style="margin:-2px 0 6px;color:#166534;font-size:11px;font-weight:1000;">↓ Reduced from ${esc(euro(drop.previousPrice))}</div>` : ""}
              <div class="miniTitle">${esc(titleText)}</div>
              <div class="miniMeta">${esc(meta)}</div>
              <div class="miniChips">${chips.map(x => `<span class="miniChip">${esc(x)}</span>`).join("")}</div>
            </div>
          </a>`;
      }

      function renderRecentCards(currentSlug){
        if(!recentGrid || !recentEmpty) return;

        const currentKey = String(currentSlug || "").trim();

        const allItems = safeReadJson(STORAGE_RECENT)
          .filter(x => isRecentlyViewableProperty(x, false))
          .slice(0,12);

        safeWriteJson(STORAGE_RECENT, allItems);

        const displayItems = allItems
          .filter(x => getRecentKey(x, false) !== currentKey)
          .slice(0,12);

        if(!displayItems.length){
          recentGrid.innerHTML = "";
          recentEmpty.style.display = "block";
          return;
        }

        recentEmpty.style.display = "none";
        recentGrid.innerHTML = displayItems.map(cardHtml).join("");
      }

        function normalizeMatchValue(v){
          return String(v || "")
            .toLowerCase()
            .replace(/^co\.?\s+/i, "")
            .replace(/[^a-z0-9]+/g, " ")
            .trim();
        }
        
        function sameProperty(a, b){
          const aKey = getRecentKey(a, true);
          const bKey = getRecentKey(b, true);
        
          if(aKey && bKey && aKey === bKey) return true;
        
          const aId = String((a && (a.id || a.propertyId || a.listingId)) || "").trim();
          const bId = String((b && (b.id || b.propertyId || b.listingId)) || "").trim();
        
          return !!aId && !!bId && aId === bId;
        }
        
        function getLat(p){
          return Number(p.lat ?? p.latitude ?? p.geoLat ?? p.locationLat);
        }
        
        function getLng(p){
          return Number(p.lng ?? p.lon ?? p.longitude ?? p.geoLng ?? p.locationLng);
        }
        
        function distanceKm(a, b){
          const lat1 = getLat(a);
          const lon1 = getLng(a);
          const lat2 = getLat(b);
          const lon2 = getLng(b);
        
          if(!Number.isFinite(lat1) || !Number.isFinite(lon1) || !Number.isFinite(lat2) || !Number.isFinite(lon2)){
            return null;
          }
        
          const R = 6371;
          const toRad = deg => deg * Math.PI / 180;
          const dLat = toRad(lat2 - lat1);
          const dLon = toRad(lon2 - lon1);
        
          const x =
            Math.sin(dLat / 2) * Math.sin(dLat / 2) +
            Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
            Math.sin(dLon / 2) * Math.sin(dLon / 2);
        
          return R * 2 * Math.atan2(Math.sqrt(x), Math.sqrt(1 - x));
        }
        
        function isSimilarProperty(current, candidate){
          const currentMode = normalizeMatchValue(current.mode);
          const candidateMode = normalizeMatchValue(candidate.mode);
        
          const currentType = normalizeMatchValue(current.propertyType || current.type);
          const candidateType = normalizeMatchValue(candidate.propertyType || candidate.type);
        
          const currentBeds = Number(current.bedrooms);
          const candidateBeds = Number(candidate.bedrooms);
        
          const currentPrice = Number(current.price);
          const candidatePrice = Number(candidate.price);
        
          const currentCounty = normalizeMatchValue(current.county);
          const candidateCounty = normalizeMatchValue(candidate.county);
        
          const dist = distanceKm(current, candidate);
        
          if(!currentMode || !candidateMode || currentMode !== candidateMode) return false;
          if(!currentType || !candidateType || currentType !== candidateType) return false;
          if(!Number.isFinite(currentBeds) || !Number.isFinite(candidateBeds) || currentBeds !== candidateBeds) return false;
          if(
            !Number.isFinite(currentPrice) ||
            !Number.isFinite(candidatePrice)
            ){
        return false;
            }

            const basePrice = Math.max(currentPrice, candidatePrice);
            
            let toleranceRate = 0.10;
            
            if(basePrice >= 2000000){
              toleranceRate = 0.25;
            }else if(basePrice >= 1000000){
              toleranceRate = 0.15;
            }
            
            const priceTolerance = basePrice * toleranceRate;

            if(
            Math.abs(currentPrice - candidatePrice) > priceTolerance
            ){
             return false;
            }
        
          const sameCounty = currentCounty && candidateCounty && currentCounty === candidateCounty;
          const within20km = dist != null && dist <= 20;
        
          return sameCounty || within20km;
        }
        
        function getSimilarSortScore(current, candidate){
          const dist = distanceKm(current, candidate);
          const priceDiff = Math.abs(Number(current.price || 0) - Number(candidate.price || 0));
          const created = new Date(candidate.publishedAt || candidate.createdAt || 0).getTime() || 0;
        
          return {
            distance: dist == null ? 999999 : dist,
            priceDiff,
            created
          };
        }        
        
        async function loadSimilarProperties(current){
          if(!similarGrid || !similarEmpty || !current) return;
        
          const countyLabel = current.county || current.city || current.town || "";
        
          if(similarTitle){
            similarTitle.textContent = countyLabel
              ? "More properties near " + countyLabel
              : "Similar properties";
          }
        
          if(similarNote){
            similarNote.textContent = "Prioritising nearby homes, similar price, same property type and recently reduced listings.";
          }
        
          similarGrid.innerHTML = "";
          similarEmpty.style.display = "block";
          similarEmpty.textContent = "Finding the best nearby matches…";
        
          try{
            const out = await fetchJsonUrl(API + "/api/properties?limit=200&page=1");
        
            if(!out.response.ok){
              throw new Error("Could not load similar properties");
            }
        
            const rows = extractListFromPayload(out.result.json)
              .filter(item => item && typeof item === "object")
              .filter(item => String(item.listingStatus || item.publicStatus || item.status || "").toUpperCase() === "PUBLISHED")
              .filter(item => !sameProperty(current, item));
        
            const currentMode = normalizeMatchValue(current.mode);
            const currentCounty = normalizeMatchValue(current.county);
            const currentType = normalizeMatchValue(current.propertyType || current.type);
            const currentBeds = Number(current.bedrooms);
            const currentPrice = Number(current.price);
        
            const isShare = currentMode === "share";
            const isRent = currentMode === "rent";
        
            const priceTolerance = isShare || isRent ? 0.40 : 0.15;
        
            const candidates = rows
              .filter(item => {
                const itemMode = normalizeMatchValue(item.mode);
                const itemType = normalizeMatchValue(item.propertyType || item.type);
                const itemBeds = Number(item.bedrooms);
                const itemPrice = Number(item.price);
        
                if(itemMode !== currentMode) return false;
        
                if(!isShare){
                  if(itemType !== currentType) return false;
                  if(itemBeds !== currentBeds) return false;
                }
        
                if(
                  Number.isFinite(currentPrice) &&
                  Number.isFinite(itemPrice) &&
                  currentPrice > 0
                ){
                  const priceDiffPct = Math.abs(itemPrice - currentPrice) / currentPrice;
                  if(priceDiffPct > priceTolerance) return false;
                }
        
                const dist = distanceKm(current, item);
        
                if(!Number.isFinite(dist) || dist > 30){
                  return false;
                }
        
                return true;
              })
              .sort((a,b) => {
                const distA = distanceKm(current, a);
                const distB = distanceKm(current, b);
        
                if(distA !== distB){
                  return distA - distB;
                }
        
                if(isShare){
                  const shareFields = [
                    "roomType",
                    "ensuite",
                    "ownerOccupied",
                    "leaseLength",
                    "petsAllowed",
                    "couplesAllowed"
                  ];
        
                  const scoreShare = item => shareFields.reduce((score, field) => {
                    const currentValue = normalizeMatchValue(current[field]);
                    const itemValue = normalizeMatchValue(item[field]);
                    return score + (currentValue && itemValue && currentValue === itemValue ? 1 : 0);
                  }, 0);
        
                  const shareDiff = scoreShare(b) - scoreShare(a);
                  if(shareDiff !== 0) return shareDiff;
                }
        
                const aCountyMatch = normalizeMatchValue(a.county) === currentCounty ? 1 : 0;
                const bCountyMatch = normalizeMatchValue(b.county) === currentCounty ? 1 : 0;
        
                if(aCountyMatch !== bCountyMatch){
                  return bCountyMatch - aCountyMatch;
                }
        
                const aPriceDiff = Math.abs(Number(a.price || 0) - currentPrice);
                const bPriceDiff = Math.abs(Number(b.price || 0) - currentPrice);
        
                return aPriceDiff - bPriceDiff;
              })
              .slice(0, 6);
        
            if(!candidates.length){
              similarGrid.innerHTML = "";
              similarEmpty.textContent =
                "No nearby matching properties found within 30km. More recommendations will appear as HAVN inventory grows.";
              similarEmpty.style.display = "block";
              return;
            }
        
            similarEmpty.style.display = "none";
            similarGrid.innerHTML = candidates.map(cardHtml).join("");
          }catch(err){
            similarGrid.innerHTML = "";
            similarEmpty.textContent = "More published properties will appear here as HAVN inventory grows.";
            similarEmpty.style.display = "block";
          }
        }

      function addKd(label, value){
        if(!kdGrid) return;
        const v = value == null ? "" : String(value).trim();

        const item = document.createElement("div");
        item.className = "kdItem";

        const l = document.createElement("div");
        l.className = "kdLabel";
        l.textContent = label;

        const val = document.createElement("div");
        val.className = "kdValue" + (v ? "" : " muted");
        val.textContent = v || "—";

        item.appendChild(l);
        item.appendChild(val);
        kdGrid.appendChild(item);
      }

        function prettyRentalValue(value){
          const raw = String(value || "").trim();
          if(!raw) return "";
        
          return raw
            .replace(/-/g, " ")
            .replace(/\b\w/g, c => c.toUpperCase());
        }
        
        function prettyDate(value){
          if(!value) return "";
          const d = new Date(value);
          if(Number.isNaN(d.getTime())) return String(value);
          return d.toLocaleDateString("en-IE", {
            day:"numeric",
            month:"short",
            year:"numeric"
          });
        }


        function getSizeValue(p){
          return p.size || p.floorArea || p.areaSqm || p.sqm || p.squareMetres || "";
        }

        function priceLabel(p){
          const mode = String(p.mode || "").toUpperCase();
          if(p.price == null || p.price === "") return "Price on application";
          const base = euro(p.price) || ("€" + String(p.price));
          if(mode === "RENT") return base + " per month";
          if(mode === "SHARE") return base + " per month";
          return base;
        }

        function shortPriceLabel(p){
          const mode = String(p.mode || "").toUpperCase();
          if(p.price == null || p.price === "") return "Price on application";
          const base = euro(p.price) || ("€" + String(p.price));
          if(mode === "RENT" || mode === "SHARE") return base + " pcm";
          return base;
        }

        const PRICE_DROP_ACTIVE_MS = 14 * 24 * 60 * 60 * 1000;

        function getActivePriceDropData(p){
          if(!p) return null;

          const price = Number(p.price || 0);
          const previousPrice = Number(p.previousPrice || 0);
          const droppedAtRaw = p.priceDroppedAt;

          if(!Number.isFinite(price) || !Number.isFinite(previousPrice)) return null;
          if(price <= 0 || previousPrice <= 0 || previousPrice <= price) return null;
          if(!droppedAtRaw) return null;

          const droppedAt = new Date(droppedAtRaw).getTime();
          if(!Number.isFinite(droppedAt)) return null;
          if(Date.now() - droppedAt > PRICE_DROP_ACTIVE_MS) return null;

          return {
            previousPrice,
            newPrice:price,
            reduction:previousPrice - price,
            priceDroppedAt:new Date(droppedAt)
          };
        }

        function renderPriceDropLayer(p){
          const drop = getActivePriceDropData(p);

          if(priceDropBadge){
            priceDropBadge.style.display = drop ? "inline-flex" : "none";
          }

          if(!priceDropLine) return;

          if(!drop){
            priceDropLine.style.display = "none";
            priceDropLine.innerHTML = "";
            return;
          }

          priceDropLine.style.display = "flex";
          priceDropLine.innerHTML = `↓ Reduced from <strong>${esc(euro(drop.previousPrice))}</strong>`;
        }

        function daysAgoText(value, fallbackLabel){
          if(!value) return "";
          const d = new Date(value);
          if(Number.isNaN(d.getTime())) return "";
        
          const days = Math.max(0, Math.floor((Date.now() - d.getTime()) / 86400000));
        
          if(days === 0) return fallbackLabel + " today";
          if(days === 1) return fallbackLabel + " 1 day ago";
          return fallbackLabel + " " + days + " days ago";
        }
        
        function renderMarketTimingAndHistory(p){
          const listedDate = p.publishedAt || p.createdAt;
          const drop = getActivePriceDropData(p);
        
          if(marketTimingLine){
            const bits = [];
        
            const listedText = daysAgoText(listedDate, "Listed");
            if(listedText) bits.push("📅 " + listedText);
        
            if(drop && p.priceDroppedAt){
              const reducedText = daysAgoText(p.priceDroppedAt, "Reduced");
              if(reducedText) bits.push("🏷️ " + reducedText);
            }
        
            if(bits.length){
              marketTimingLine.innerHTML = bits.map(x => `<span>${esc(x)}</span>`).join("");
              marketTimingLine.style.display = "flex";
            }else{
              marketTimingLine.innerHTML = "";
              marketTimingLine.style.display = "none";
            }
          }
        
          if(!priceHistoryBox || !priceHistoryBody) return;
        
          if(!drop || !listedDate){
            priceHistoryBox.style.display = "none";
            priceHistoryBody.innerHTML = "";
            return;
          }
        
          const listedDisplay = prettyDate(listedDate) || "Listed";
          const reducedDisplay = prettyDate(p.priceDroppedAt) || "Reduced";
        
          priceHistoryBody.innerHTML = `
            <div class="priceHistoryRow">
              <div class="priceHistoryDate">${esc(listedDisplay)}</div>
              <div class="priceHistoryEvent">Listed</div>
              <div class="priceHistoryPrice">${esc(euro(drop.previousPrice))}</div>
            </div>
            <div class="priceHistoryRow">
              <div class="priceHistoryDate">${esc(reducedDisplay)}</div>
              <div class="priceHistoryEvent">Price reduced</div>
              <div class="priceHistoryPrice">${esc(euro(drop.newPrice))}</div>
            </div>
          `;
        
          priceHistoryBox.style.display = "block";
        }



        function propertyRef(p){
          const id = getPropertyId(p) || getRecentKey(p, true) || "listing";
          return "HAVN-" + String(id).replace(/[^a-zA-Z0-9]/g, "").slice(0,10).toUpperCase();
        }

        function hasValue(v){
          return v !== null && v !== undefined && String(v).trim() !== "";
        }

        function firstValue(){
          for(const v of arguments){
            if(hasValue(v)) return v;
          }
          return "";
        }

        function renderFact(label, value){
          return `
            <div class="factTile">
              <div class="factLabel">${esc(label)}</div>
              <div class="factValue">${esc(hasValue(value) ? value : "—")}</div>
            </div>`;
        }

        function renderFactsBar(p){
          if(!factsBar) return;

          const mode = String(p.mode || "").toUpperCase();
          const size = getSizeValue(p);

          const facts = [
            ["Beds", hasValue(p.bedrooms) ? String(p.bedrooms) : (mode === "SHARE" ? "Room" : "")],
            ["Baths", hasValue(p.bathrooms) ? String(p.bathrooms) : ""],
            ["BER", firstValue(p.ber, p.berRating)],
            ["Size", size ? String(size).replace(/\s*sq\s*m\s*$/i, "") + " sq m" : ""],
            ["Type", prettyType(p.propertyType || p.type)]
          ];

          factsBar.innerHTML = facts.map(row => renderFact(row[0], row[1])).join("");
        }

        function renderTrustLayer(p){
          const ref = propertyRef(p);

          if(trustRef) trustRef.textContent = ref;
          if(actionRefText) actionRefText.textContent = "Property reference: " + ref;

          if(trustListed) trustListed.textContent = prettyDate(p.publishedAt || p.createdAt) || daysOnHavn(p.publishedAt || p.createdAt) || "Published listing";
          if(trustUpdated) trustUpdated.textContent = prettyDate(p.updatedAt || p.modifiedAt || p.publishedAt || p.createdAt) || "Recently checked";
          if(trustStatus) trustStatus.textContent = "Published on HAVN";

          if(actionVerifiedText){
            actionVerifiedText.textContent = "Published listing checked by HAVN before going live.";
          }

          if(verifiedBadge){
            verifiedBadge.textContent = p.eircode ? "✓ Eircode location verified" : "✓ HAVN verified listing";
          }
        }

        function renderFinancialSnapshot(p){
          if(!financialGrid || !financialTitle || !financialNote || !financialBlock) return;

          const mode = String(p.mode || "").toUpperCase();
          const price = Number(p.price);
          const deposit = Number(p.deposit);
          const size = Number(String(getSizeValue(p)).replace(/[^0-9.]/g, ""));

          const tiles = [];

          function add(label, value, small){
            if(!hasValue(value)) return;
            tiles.push(`
              <div class="insightTile">
                <div class="insightLabel">${esc(label)}</div>
                <div class="insightValue">${esc(value)}</div>
                ${small ? `<div class="insightSmall">${esc(small)}</div>` : ""}
              </div>`);
          }

          if(mode === "BUY"){
            financialTitle.textContent = "Buyer financial snapshot";
            financialNote.textContent = "Indicative estimates only. Confirm affordability and lending terms with a qualified mortgage adviser.";

            if(Number.isFinite(price) && price > 0){
              add("Guide price", euro(price), "Advertised sale price.");
              add("10% deposit", euro(price * 0.10), "Indicative buyer deposit.");
              if(Number.isFinite(size) && size > 0){
                add("Price per sq m", euro(price / size) + " / sqm", "Useful for comparing similar properties.");
              }

              const principal = price * 0.90;
              const annualRate = 0.04;
              const months = 30 * 12;
              const monthlyRate = annualRate / 12;
              const repayment = principal * monthlyRate / (1 - Math.pow(1 + monthlyRate, -months));
              if(Number.isFinite(repayment) && repayment > 0){
                add("Mortgage estimate", euro(repayment) + " / month", "Assumes 90% loan, 30 years, 4% indicative rate.");
              }
            }
          }else if(mode === "RENT"){
            financialTitle.textContent = "Rental cost snapshot";
            financialNote.textContent = "Indicative move-in figures based on the listing price and deposit fields.";

            if(Number.isFinite(price) && price > 0){
              add("Monthly rent", euro(price), "Advertised monthly rent.");
              add("Deposit", Number.isFinite(deposit) && deposit > 0 ? euro(deposit) : "Confirm with advertiser", "Always verify deposit requirements.");
              add("Estimated move-in", euro(price + (Number.isFinite(deposit) && deposit > 0 ? deposit : price)), "First month plus deposit estimate.");
            }
          }else if(mode === "SHARE"){
            financialTitle.textContent = "Share cost snapshot";
            financialNote.textContent = "Room-share costs should always be confirmed with the advertiser before sending money.";

            if(Number.isFinite(price) && price > 0){
              add("Monthly room rent", euro(price), "Advertised monthly room rent.");
              add("Deposit", Number.isFinite(deposit) && deposit > 0 ? euro(deposit) : "Confirm with advertiser", "Ask what is refundable and when.");
              add("Estimated upfront", euro(price + (Number.isFinite(deposit) && deposit > 0 ? deposit : price)), "First month plus deposit estimate.");
            }
          }else{
            financialTitle.textContent = "Financial snapshot";
            financialNote.textContent = "Helpful estimates appear when price and listing mode are available.";
          }

          if(!tiles.length){
            financialBlock.style.display = "none";
            financialGrid.innerHTML = "";
            return;
          }

          financialBlock.style.display = "block";
          financialGrid.innerHTML = tiles.join("");
        }

        function addDetailItem(container, label, value){
          const v = hasValue(value) ? String(value) : "—";
          const item = document.createElement("div");
          item.className = "detailItemV2";
          item.innerHTML = `
            <div class="detailLabelV2">${esc(label)}</div>
            <div class="detailValueV2">${esc(v)}</div>
          `;
          container.appendChild(item);
        }

        function addDetailGroup(titleText, rows){
          if(!detailSections) return;

          const filtered = rows.filter(row => hasValue(row[1]));
          if(!filtered.length) return;

          const group = document.createElement("div");
          group.className = "detailGroup";

          const titleEl = document.createElement("h3");
          titleEl.className = "detailGroupTitle";
          titleEl.textContent = titleText;

          const grid = document.createElement("div");
          grid.className = "detailGridV2";

          filtered.forEach(row => addDetailItem(grid, row[0], row[1]));

          group.appendChild(titleEl);
          group.appendChild(grid);
          detailSections.appendChild(group);
        }

        function buildDetailSections(p){
          if(!detailSections) return;

          detailSections.innerHTML = "";

          const mode = String(p.mode || "").toUpperCase();
          const isRental = mode === "RENT" || mode === "SHARE";
          const size = getSizeValue(p);

          addDetailGroup("At a glance", [
            ["Market", prettyMode(p.mode)],
            ["Property type", prettyType(p.propertyType || p.type)],
            ["Bedrooms", p.bedrooms],
            ["Bathrooms", p.bathrooms],
            ["BER", firstValue(p.ber, p.berRating)],
            ["Floor area", size ? String(size).replace(/\s*sq\s*m\s*$/i, "") + " sq m" : ""],
            ["City / Town", firstValue(p.city, p.town)],
            ["County", p.county]
          ]);

          if(mode === "BUY"){
            addDetailGroup("Sale details", [
              ["Price", priceLabel(p)],
              ["Sale condition", prettyRentalValue(p.saleCondition)],
              ["Parking", prettyRentalValue(p.parking)],
              ["Outdoor space", prettyRentalValue(p.outdoorSpace)],
              ["Eircode", p.eircode]
            ]);
          }

          if(isRental){
            addDetailGroup(mode === "SHARE" ? "Rental terms" : "Rental details", [
              ["Monthly rent", shortPriceLabel(p)],
              ["Rent frequency", prettyRentalValue(p.rentFrequency)],
              ["Deposit", p.deposit ? euro(p.deposit) : ""],
              ["Available from", prettyDate(p.availableFrom)],
              ["Lease length", prettyRentalValue(p.leaseLength)],
              ["Minimum term", prettyRentalValue(p.minimumTerm)],
              ["Bills included", prettyRentalValue(p.billsIncluded)],
              ["Pets allowed", prettyRentalValue(p.petsAllowed)]
            ]);
          }

          if(mode === "SHARE"){
            addDetailGroup("Share details", [
              ["Room type", prettyRentalValue(p.roomType)],
              ["Ensuite", prettyRentalValue(p.ensuite)],
              ["Current occupants", p.currentOccupants],
              ["Couples allowed", prettyRentalValue(p.couplesAllowed)],
              ["Owner occupied", prettyRentalValue(p.ownerOccupied)]
            ]);
          }

          if(!detailSections.children.length){
            addDetailGroup("Property details", [
              ["Price", priceLabel(p)],
              ["Market", prettyMode(p.mode)],
              ["Property type", prettyType(p.propertyType || p.type)]
            ]);
          }
        }

        function locationSearchBase(p){
          return firstValue(p.eircode, [p.address, p.city || p.town, p.county, "Ireland"].filter(Boolean).join(", "));
        }

         function renderLocationIntel(p){
          if(!locationIntelGrid) return;
        
          locationIntelGrid.innerHTML = `
            <div class="intelInsightBox">
              Loading HAVN Property Intelligence…
            </div>
          `;
        }
        
        
        function formatIntelUpdated(value){
          if(!value) return "";
          const d = new Date(value);
          if(Number.isNaN(d.getTime())) return "";
          return d.toLocaleDateString("en-IE", {
            day:"numeric",
            month:"short",
            year:"numeric"
          });
        }
        
        function formatDistanceKm(value){
          const n = Number(value);
          if(!Number.isFinite(n)) return "—";
          if(n < 1) return Math.round(n * 1000) + "m";
          return n.toFixed(1) + "km";
        }
        

        function areaScoreLabelClass(label){
          const key = String(label || "").trim().toLowerCase();
          if(key.includes("excellent")) return "excellent";
          if(key.includes("strong")) return "strong";
          if(key.includes("good")) return "good";
          if(key.includes("limited") || key.includes("weak")) return "limited";
          return "";
        }

        function renderAreaIntelligenceDashboard(areaScores){
          if(!areaScores || typeof areaScores !== "object") return "";

          const items = [
            { key:"connectivity", icon:"🚆", name:"Connectivity", fallback:"Commute, transport and major destination access." },
            { key:"family", icon:"👨‍👩‍👧", name:"Family", fallback:"Schools and childcare signals." },
            { key:"convenience", icon:"🛍️", name:"Convenience", fallback:"Grocery, pharmacy, services and retail practicality." },
            { key:"healthcare", icon:"🏥", name:"Healthcare", fallback:"Hospitals, GPs, dental care, specialists and urgent care." },
            { key:"lifestyle", icon:"🌳", name:"Lifestyle", fallback:"Restaurants, cafés, leisure and recreation signals." }
          ].map(meta => {
            const raw = areaScores[meta.key] || {};
            const score = Math.max(0, Math.min(100, Math.round(Number(raw.score || 0))));
            const label = String(raw.label || "Assessing").trim();
            const summary = String(raw.summary || meta.fallback).trim();
            const breakdown = Array.isArray(raw.breakdown) ? raw.breakdown : [];
            return { ...meta, score, label, summary, breakdown };
          }).filter(item => Number.isFinite(item.score));

          if(!items.length) return "";

          const cards = items.map(item => `
            <button class="areaIntelCard" type="button" data-area-score-card="${esc(item.key)}" aria-expanded="false">
              <div class="areaIntelTop">
                <div class="areaIntelIcon" aria-hidden="true">${esc(item.icon)}</div>
                <div class="areaIntelScore">${esc(String(item.score))}<span>/100</span></div>
              </div>
              <div class="areaIntelName">${esc(item.name)}</div>
              <div class="areaIntelLabel ${esc(areaScoreLabelClass(item.label))}">${esc(item.label)}</div>
              <p class="areaIntelSummary">${esc(item.summary)}</p>
            </button>
          `).join("");

          const panels = items.map((item, index) => {
            const rows = item.breakdown.map(row => {
              const score = Math.max(0, Math.round(Number(row.score || 0)));
              const max = Math.max(1, Math.round(Number(row.max || 1)));
              const pct = Math.max(0, Math.min(100, Math.round((score / max) * 100)));
              return `
                <div class="areaIntelRow">
                  <div class="areaIntelRowLabel">${esc(row.label || "Factor")}</div>
                  <div class="areaIntelBarTrack"><div class="areaIntelBarFill" style="width:${esc(String(pct))}%;"></div></div>
                  <div class="areaIntelRowScore">${esc(String(score))}/${esc(String(max))}</div>
                  <div class="areaIntelReason">${esc(row.reason || "Calculated from HAVN area data.")}</div>
                </div>
              `;
            }).join("");

            return `
              <div class="areaIntelBreakdown ${index === 0 ? "open" : ""}" data-area-score-panel="${esc(item.key)}">
                <div class="areaIntelBreakdownHead">
                  <div>
                    <strong>${esc(item.name)} score breakdown</strong>
                    <span>${esc(item.summary)}</span>
                  </div>
                  <div class="areaIntelBreakdownScore">${esc(String(item.score))}/100 · ${esc(item.label)}</div>
                </div>
                <div class="areaIntelRows">
                  ${rows || `<div class="areaIntelReason" style="grid-column:1/-1;">Breakdown unavailable for this score.</div>`}
                </div>
              </div>
            `;
          }).join("");

          return `
            <div class="areaIntelShell">
              <div class="areaIntelHeader">
                <div>
                  <h3>HAVN Area Intelligence</h3>
                  <p>Explainable scores based on nearby transport, schools, shopping, healthcare and lifestyle signals. Click a score to see the calculation.</p>
                </div>
                <span class="areaIntelMethodBadge">✓ Explainable scoring</span>
              </div>
              <div class="areaIntelGrid">
                ${cards}
              </div>
              <div class="areaIntelPanels">
                ${panels}
              </div>
            </div>
          `;
        }

        function wireAreaIntelligenceDashboard(){
          const cards = Array.from(document.querySelectorAll("[data-area-score-card]"));
          const panels = Array.from(document.querySelectorAll("[data-area-score-panel]"));

          cards.forEach(card => {
            card.addEventListener("click", () => {
              const key = card.getAttribute("data-area-score-card");
              panels.forEach(panel => {
                panel.classList.toggle("open", panel.getAttribute("data-area-score-panel") === key);
              });
              cards.forEach(other => {
                other.setAttribute("aria-expanded", other === card ? "true" : "false");
              });
            });
          });

          const first = cards[0];
          if(first) first.setAttribute("aria-expanded", "true");
        }

        function renderIntelRows(items, label){
          const rows = Array.isArray(items) ? items.slice(0, 5) : [];
        
          if(!rows.length){
            return `
              <div class="intelDataRow">
                <span>No ${esc(label || "results")} found nearby</span>
                <span>—</span>
              </div>
            `;
          }
        
          return rows.map(item => `
            <div class="intelDataRow">
              <span>${esc(item.name || item.stop || "Nearby place")}</span>
              <span>${esc(formatDistanceKm(item.distanceKm))}</span>
            </div>
          `).join("");
        }
        
        

        function renderSchoolGroupsRows(groups, areaScores){
          const safeGroups = groups && typeof groups === "object" ? groups : {};
          const primary = Array.isArray(safeGroups.primary) ? safeGroups.primary : [];
          const secondary = Array.isArray(safeGroups.secondary) ? safeGroups.secondary : [];
          const childcare = Array.isArray(safeGroups.childcare) ? safeGroups.childcare : [];
          const familyScoreData = areaScores && areaScores.family ? areaScores.family : null;
          const familyScore = familyScoreData && Number.isFinite(Number(familyScoreData.score)) ? Math.max(0, Math.min(100, Math.round(Number(familyScoreData.score)))) : null;
          const familyLabel = familyScoreData && familyScoreData.label ? String(familyScoreData.label).trim() : "Family intelligence";

          function rowsFor(items){
            return Array.isArray(items) ? items.slice().sort((a,b) => Number(a.distanceKm || 9999) - Number(b.distanceKm || 9999)) : [];
          }

          function typeLabel(item, fallback){
            const schoolType = String((item && (item.schoolType || item.type)) || "").trim().toUpperCase();
            if(schoolType === "PRIMARY") return "Primary school";
            if(schoolType === "SECONDARY") return "Secondary school";
            if(schoolType === "CHILDCARE") return "Childcare / preschool";
            return fallback;
          }

          function renderSchoolGroup(config){
            const rows = rowsFor(config.items);
            const nearest = rows[0] || null;

            return `
              <div class="schoolsV12Group">
                <div class="schoolsV12Head">
                  <div style="display:flex;gap:10px;align-items:flex-start;min-width:0;">
                    <div class="schoolsV12Icon" aria-hidden="true">${esc(config.icon)}</div>
                    <div>
                      <h4 class="schoolsV12Title">${esc(config.title)}</h4>
                      <div class="schoolsV12Count">${esc(String(rows.length))} nearby ${esc(rows.length === 1 ? config.singular : config.plural)}</div>
                    </div>
                  </div>
                </div>

                ${nearest ? `
                  <div class="schoolsV12Nearest">
                    <div class="schoolsV12NearestLabel">Nearest</div>
                    <div class="schoolsV12NearestName">${esc(nearest.name || "Nearby school")}</div>
                    <div class="schoolsV12NearestDistance">${esc(formatDistanceKm(nearest.distanceKm))} away</div>
                  </div>
                ` : ""}

                <div class="schoolsV12Rows">
                  ${rows.length ? rows.slice(0, 8).map(item => `
                    <div class="schoolsV12Row">
                      <div>
                        <strong>${esc(item.name || "Nearby school")}</strong>
                        <span>${esc(typeLabel(item, config.fallbackType))}</span>
                      </div>
                      <em>${esc(formatDistanceKm(item.distanceKm))}</em>
                    </div>
                  `).join("") : `
                    <div class="schoolsV12Empty">
                      No ${esc(config.title.toLowerCase())} found nearby yet. HAVN will refresh this area intelligence as more data becomes available.
                    </div>
                  `}
                </div>
              </div>
            `;
          }

          const total = primary.length + secondary.length + childcare.length;
          if(!total){
            return `<div class="intelInsightBox">No school or childcare results were found nearby yet. HAVN will refresh this area intelligence as more data becomes available.</div>`;
          }

          const summaryParts = [];
          if(primary.length) summaryParts.push(primary.length + " primary");
          if(secondary.length) summaryParts.push(secondary.length + " secondary");
          if(childcare.length) summaryParts.push(childcare.length + " childcare");

          return `
            <div class="schoolsV12Shell">
              <div class="schoolsV12Intro">
                <div>
                  <strong>Schools & childcare overview</strong>
                  <span>${esc(summaryParts.join(", "))} options found nearby, grouped by type so families can quickly understand the area.</span>
                </div>
                ${familyScore !== null ? `<div class="schoolsV12Score"><strong>${esc(String(familyScore))}</strong>/100<div>${esc(familyLabel)}</div></div>` : ""}
              </div>
              <div class="schoolsV12Grid">
                ${renderSchoolGroup({title:"Primary Schools",icon:"🎒",items:primary,singular:"primary school",plural:"primary schools",fallbackType:"Primary school"})}
                ${renderSchoolGroup({title:"Secondary Schools",icon:"🏫",items:secondary,singular:"secondary school",plural:"secondary schools",fallbackType:"Secondary school"})}
                ${renderSchoolGroup({title:"Childcare & Preschool",icon:"🧸",items:childcare,singular:"childcare provider",plural:"childcare providers",fallbackType:"Childcare / preschool"})}
              </div>
            </div>
          `;
        }


        function renderConvenienceGroupsRows(groups, areaScores){
          const safeGroups = groups && typeof groups === "object" ? groups : {};
          const grocery = Array.isArray(safeGroups.grocery) ? safeGroups.grocery : [];
          const pharmacy = Array.isArray(safeGroups.pharmacy) ? safeGroups.pharmacy : [];
          const dailyServices = Array.isArray(safeGroups.dailyServices) ? safeGroups.dailyServices : [];
          const retail = Array.isArray(safeGroups.retail) ? safeGroups.retail : [];
          const convenienceScoreData = areaScores && areaScores.convenience ? areaScores.convenience : null;
          const convenienceScore = convenienceScoreData && Number.isFinite(Number(convenienceScoreData.score)) ? Math.max(0, Math.min(100, Math.round(Number(convenienceScoreData.score)))) : null;
          const convenienceLabel = convenienceScoreData && convenienceScoreData.label ? String(convenienceScoreData.label).trim() : "Convenience intelligence";

          function rowsFor(items){
            return Array.isArray(items) ? items.slice().sort((a,b) => Number(a.distanceKm || 9999) - Number(b.distanceKm || 9999)) : [];
          }

          function normaliseBrand(name){
            let s = String(name || "").trim();
            if(!s) return "";
            s = s.replace(/[-–—].*$/g, "").trim();
            s = s.replace(/\b(express|superstore|pharmacy|chemist|store|stores|shopping centre|centre|center|retail park)\b/ig, "").trim();
            s = s.replace(/\s+/g, " ").trim();
            const lower = s.toLowerCase();
            if(lower.includes("tesco")) return "Tesco";
            if(lower.includes("spar") || lower.includes("eurospar")) return lower.includes("euro") ? "Eurospar" : "Spar";
            if(lower.includes("centra")) return "Centra";
            if(lower.includes("supervalu") || lower.includes("super valu")) return "SuperValu";
            if(lower.includes("dunnes")) return "Dunnes Stores";
            if(lower.includes("boots")) return "Boots";
            if(lower.includes("mccabes") || lower.includes("mccabe")) return "McCabes Pharmacy";
            if(lower.includes("meagher")) return "Meagher's Pharmacy";
            if(lower.includes("reilly")) return "Reilly's Pharmacy";
            if(lower.includes("lloyds")) return "Lloyds Pharmacy";
            if(lower.includes("hickey")) return "Hickey's Pharmacy";
            if(lower.includes("an post") || lower.includes("post office")) return "Post Office";
            if(lower.includes("library")) return "Library";
            if(lower.includes("atm")) return "ATM";
            if(lower.includes("launderette") || lower.includes("laundrette") || lower.includes("laundry")) return "Laundry / Launderette";
            if(lower.includes("dry clean")) return "Dry Cleaner";
            if(lower.includes("collection point") || lower.includes("parcel")) return "Parcel / Collection Point";
            if(lower.includes("aib")) return "AIB";
            if(lower.includes("bank of ireland")) return "Bank of Ireland";
            if(lower.includes("permanent tsb") || lower.includes("ptsb")) return "Permanent TSB";
            if(lower.includes("credit union")) return "Credit Union";
            if(lower.includes("swan")) return "Swan Shopping Centre";
            if(lower.includes("stephen")) return "Stephen's Green";
            if(lower.includes("jervis")) return "Jervis";
            if(lower.includes("ilac")) return "ILAC";
            if(lower.includes("arnotts")) return "Arnotts";
            return s;
          }

          function dedupeDisplayRows(items){
            const rows = rowsFor(items);
            const seen = new Set();
            const out = [];

            rows.forEach(item => {
              const brand = normaliseBrand(item && item.name) || String(item && item.name || "Nearby place").trim();
              const key = brand.toLowerCase();
              if(seen.has(key)) return;
              seen.add(key);
              out.push({ ...item, displayName:brand });
            });

            return out;
          }

          function categoryLabelForItem(item, fallback){
            const name = String((item && item.name) || "").toLowerCase();
            if(name.includes("library")) return "Library";
            if(name.includes("atm")) return "ATM";
            if(name.includes("post") || name.includes("postal")) return "Post office";
            if(name.includes("launderette") || name.includes("laundrette") || name.includes("laundry")) return "Laundry";
            if(name.includes("dry clean")) return "Dry cleaner";
            if(name.includes("collection") || name.includes("parcel")) return "Collection point";
            if(name.includes("bank") || name.includes("aib") || name.includes("ptsb") || name.includes("credit union")) return "Banking";
            return fallback;
          }

          function itemMeta(item, fallback){
            const rating = Number(item && item.rating);
            const bits = [];
            if(Number.isFinite(rating) && rating > 0) bits.push("★ " + rating.toFixed(1));
            if(item && item.address) bits.push(String(item.address));
            return bits.join(" · ") || fallback;
          }

          function renderCompactRow(item, config){
            return `
              <div class="schoolsV12Row">
                <div>
                  <strong>${esc(item.displayName || item.name || "Nearby option")}</strong>
                  <span>${esc(itemMeta(item, categoryLabelForItem(item, config.fallbackType)))}</span>
                </div>
                <em>${esc(formatDistanceKm(item.distanceKm))}</em>
              </div>
            `;
          }

          function renderConvenienceGroup(config){
            const allRows = rowsFor(config.items);
            const displayRowsAll = dedupeDisplayRows(config.items);
            const nearest = allRows[0] || null;
            const nearestNameKey = nearest ? (normaliseBrand(nearest.name) || String(nearest.name || "").trim()).toLowerCase() : "";
            const displayRows = displayRowsAll.filter(item => {
              const key = String(item.displayName || item.name || "").toLowerCase();
              return !nearestNameKey || key !== nearestNameKey;
            });
            const visibleRows = displayRows.slice(0, 5);
            const hiddenRows = displayRows.slice(5);
            const uniqueCount = displayRowsAll.length;
            const resultCount = allRows.length;
            const optionWord = uniqueCount === 1 ? "option" : "options";
            const resultWord = resultCount === 1 ? "result" : "results";

            return `
              <div class="schoolsV12Group">
                <div class="schoolsV12Head">
                  <div style="display:flex;gap:10px;align-items:flex-start;min-width:0;">
                    <div class="schoolsV12Icon" aria-hidden="true">${esc(config.icon)}</div>
                    <div>
                      <h4 class="schoolsV12Title">${esc(config.title)}</h4>
                      <div class="schoolsV12Count">${esc(String(uniqueCount))} distinct ${esc(optionWord)}${resultCount !== uniqueCount ? " from " + esc(String(resultCount)) + " nearby " + esc(resultWord) : " nearby"}</div>
                    </div>
                  </div>
                </div>

                ${nearest ? `
                  <div class="schoolsV12Nearest">
                    <div class="schoolsV12NearestLabel">Nearest</div>
                    <div class="schoolsV12NearestName">${esc(nearest.name || "Nearby option")}</div>
                    <div class="schoolsV12NearestDistance">${esc(formatDistanceKm(nearest.distanceKm))} away</div>
                  </div>
                ` : ""}

                <div class="schoolsV12Rows">
                  ${visibleRows.length ? visibleRows.map(item => renderCompactRow(item, config)).join("") : (!nearest ? `
                    <div class="schoolsV12Empty">
                      No ${esc(config.title.toLowerCase())} found nearby yet. HAVN will refresh this area intelligence as more data becomes available.
                    </div>
                  ` : "")}
                </div>

                ${hiddenRows.length ? `
                  <details class="transportV2InlineDetails">
                    <summary>
                      <div class="transportV2CardButton">
                        <span class="transportOpenLabel">View all ${esc(String(uniqueCount))} ${esc(config.shortLabel)} options ▾</span>
                        <span class="transportCloseLabel" style="display:none;">Hide ${esc(config.shortLabel)} options ▲</span>
                      </div>
                    </summary>
                    <div class="transportV2InlineRows">
                      ${hiddenRows.map(item => `
                        <div class="transportV2InlineRow">
                          <div>
                            <strong>${esc(item.displayName || item.name || "Nearby option")}</strong>
                            <span>${esc(itemMeta(item, categoryLabelForItem(item, config.fallbackType)))}</span>
                          </div>
                          <em>${esc(formatDistanceKm(item.distanceKm))}</em>
                        </div>
                      `).join("")}
                    </div>
                  </details>
                ` : ""}
              </div>
            `;
          }

          function distinctCount(items){
            return dedupeDisplayRows(items).length;
          }

          function serviceCategorySummary(items){
            const rows = rowsFor(items);
            const categories = new Set();
            rows.forEach(item => {
              const label = categoryLabelForItem(item, "Daily service");
              if(label) categories.add(label);
            });
            return categories.size;
          }

          const total = grocery.length + pharmacy.length + dailyServices.length + retail.length;
          if(!total){
            return `<div class="intelInsightBox">No daily convenience results were found nearby yet. HAVN will refresh this area intelligence as more data becomes available.</div>`;
          }

          const groceryDistinct = distinctCount(grocery);
          const pharmacyDistinct = distinctCount(pharmacy);
          const dailyCategories = serviceCategorySummary(dailyServices) || distinctCount(dailyServices);
          const retailDistinct = distinctCount(retail);

          const summaryParts = [];
          if(grocery.length) summaryParts.push(groceryDistinct + " grocery brand" + (groceryDistinct === 1 ? "" : "s"));
          if(pharmacy.length) summaryParts.push(pharmacyDistinct + " pharmacy provider" + (pharmacyDistinct === 1 ? "" : "s"));
          if(dailyServices.length) summaryParts.push(dailyCategories + " daily-service categor" + (dailyCategories === 1 ? "y" : "ies"));
          if(retail.length) summaryParts.push(retailDistinct + " retail destination" + (retailDistinct === 1 ? "" : "s"));

          return `
            <div class="schoolsV12Shell">
              <div class="schoolsV12Intro">
                <div>
                  <strong>Excellent day-to-day convenience</strong>
                  <span>${esc(summaryParts.join(", "))} nearby, grouped into practical categories instead of repeated supermarket branches.</span>
                </div>
                ${convenienceScore !== null ? `<div class="schoolsV12Score"><strong>${esc(String(convenienceScore))}</strong>/100<div>${esc(convenienceLabel)}</div></div>` : ""}
              </div>
              <div class="schoolsV12Grid">
                ${renderConvenienceGroup({title:"Grocery & Essentials",shortLabel:"grocery",icon:"🛒",items:grocery,fallbackType:"Grocery / convenience"})}
                ${renderConvenienceGroup({title:"Pharmacy & Health",shortLabel:"pharmacy",icon:"💊",items:pharmacy,fallbackType:"Pharmacy / chemist"})}
                ${renderConvenienceGroup({title:"Daily Services",shortLabel:"daily service",icon:"📮",items:dailyServices,fallbackType:"Post office / daily service"})}
                ${renderConvenienceGroup({title:"Retail & Shopping",shortLabel:"retail",icon:"🛍️",items:retail,fallbackType:"Retail / shopping"})}
              </div>
            </div>
          `;
        }

        function renderHealthcareGroupsRows(groups, areaScores){
          const safeGroups = groups && typeof groups === "object" ? groups : {};
          const hospitals = Array.isArray(safeGroups.hospitals) ? safeGroups.hospitals : [];
          const gps = Array.isArray(safeGroups.gps) ? safeGroups.gps : [];
          const dental = Array.isArray(safeGroups.dental) ? safeGroups.dental : [];
          const specialists = Array.isArray(safeGroups.specialists) ? safeGroups.specialists : [];
          const urgentCare = Array.isArray(safeGroups.urgentCare) ? safeGroups.urgentCare : [];
          const healthcareScoreData = areaScores && areaScores.healthcare ? areaScores.healthcare : null;
          const healthcareScore = healthcareScoreData && Number.isFinite(Number(healthcareScoreData.score)) ? Math.max(0, Math.min(100, Math.round(Number(healthcareScoreData.score)))) : null;
          const healthcareLabel = healthcareScoreData && healthcareScoreData.label ? String(healthcareScoreData.label).trim() : "Healthcare intelligence";

          function rowsFor(items){
            return Array.isArray(items) ? items.slice().sort((a,b) => Number(a.distanceKm || 9999) - Number(b.distanceKm || 9999)) : [];
          }

          function normaliseHealthcareName(name){
            let s = String(name || "").trim();
            if(!s) return "";
            s = s.replace(/\s+/g, " ").trim();
            const lower = s.toLowerCase();

            if(lower.includes("st james")) return "St James's Hospital";
            if(lower.includes("mater misericordiae") || lower === "mater hospital" || lower.includes("mater hospital")) return "Mater Hospital";
            if(lower.includes("mater private")) return "Mater Private";
            if(lower.includes("st vincent")) return "St Vincent's University Hospital";
            if(lower.includes("temple street") || lower.includes("chi at temple")) return "Temple Street Children's Hospital";
            if(lower.includes("emergency department at ")) return s.replace(/^Emergency Department at\s+/i, "").trim();
            if(lower.includes("doctor365")) return "Doctor365 Walk-In Clinic";
            if(lower.includes("vhi 360")) return "Vhi 360 Health Centre";
            if(lower.includes("rapid injury")) return "Rapid Injury Clinic";
            if(lower.includes("gpdoc")) return "GPDOC Medical Centre";
            if(lower.includes("gp centre") || lower.includes("gp surgery")) return s;
            if(lower.includes("primary care")) return s;
            if(lower.includes("medical practice") || lower.includes("medical centre") || lower.includes("medical doctors")) return s;
            if(lower.includes("dental") || lower.includes("orthodont")) return s;
            if(lower.includes("physio") || lower.includes("physiotherapy")) return s;
            if(lower.includes("injury") || lower.includes("sports clinic")) return s;
            if(lower.includes("chiropractic")) return s;

            return s;
          }

          function dedupeHealthcareRows(items){
            const rows = rowsFor(items);
            const seen = new Set();
            const out = [];

            rows.forEach(item => {
              const displayName = normaliseHealthcareName(item && item.name) || String(item && item.name || "Nearby healthcare option").trim();
              const key = displayName.toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();
              if(seen.has(key)) return;
              seen.add(key);
              out.push({ ...item, displayName });
            });

            return out;
          }

          function healthcareTypeLabel(item, fallback){
            const name = String((item && item.name) || "").toLowerCase();
            if(name.includes("hospital") || name.includes("chi at temple") || name.includes("mater") || name.includes("st james") || name.includes("st vincent")) return "Hospital";
            if(name.includes("emergency")) return "Emergency department";
            if(name.includes("gp") || name.includes("family practice") || name.includes("medical centre") || name.includes("primary care") || name.includes("medical doctors")) return "GP / medical clinic";
            if(name.includes("dent") || name.includes("orthodont")) return "Dental care";
            if(name.includes("physio") || name.includes("injury") || name.includes("therapy") || name.includes("chiropractic") || name.includes("sports")) return "Specialist / therapy";
            if(name.includes("urgent") || name.includes("walk-in") || name.includes("walk in") || name.includes("out of hour") || name.includes("swiftcare") || name.includes("rapid injury") || name.includes("doctor365") || name.includes("24doc") || name.includes("vhi 360")) return "Urgent / out-of-hours care";
            return fallback;
          }

          function itemMeta(item, fallback){
            const rating = Number(item && item.rating);
            const bits = [];
            if(Number.isFinite(rating) && rating > 0) bits.push("★ " + rating.toFixed(1));
            bits.push(healthcareTypeLabel(item, fallback));
            if(item && item.address) bits.push(String(item.address));
            return bits.join(" · ");
          }

          function renderHealthcareCompactRow(item, config){
            return `
              <div class="schoolsV12Row">
                <div>
                  <strong>${esc(item.displayName || item.name || "Nearby healthcare option")}</strong>
                  <span>${esc(itemMeta(item, config.fallbackType))}</span>
                </div>
                <em>${esc(formatDistanceKm(item.distanceKm))}</em>
              </div>
            `;
          }

          function renderHealthcareGroup(config){
            const allRows = rowsFor(config.items);
            const displayRowsAll = dedupeHealthcareRows(config.items);
            const nearest = allRows[0] || null;
            const nearestNameKey = nearest ? (normaliseHealthcareName(nearest.name) || String(nearest.name || "").trim()).toLowerCase().replace(/[^a-z0-9]+/g, " ").trim() : "";
            const displayRows = displayRowsAll.filter(item => {
              const key = String(item.displayName || item.name || "").toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();
              return !nearestNameKey || key !== nearestNameKey;
            });
            const visibleRows = displayRows.slice(0, 5);
            const hiddenRows = displayRows.slice(5);
            const uniqueCount = displayRowsAll.length;
            const resultCount = allRows.length;

            return `
              <div class="schoolsV12Group">
                <div class="schoolsV12Head">
                  <div style="display:flex;gap:10px;align-items:flex-start;min-width:0;">
                    <div class="schoolsV12Icon" aria-hidden="true">${esc(config.icon)}</div>
                    <div>
                      <h4 class="schoolsV12Title">${esc(config.title)}</h4>
                      <div class="schoolsV12Count">${esc(String(uniqueCount))} distinct option${uniqueCount === 1 ? "" : "s"}${resultCount !== uniqueCount ? " from " + esc(String(resultCount)) + " nearby results" : " nearby"}</div>
                    </div>
                  </div>
                </div>

                ${nearest ? `
                  <div class="schoolsV12Nearest">
                    <div class="schoolsV12NearestLabel">Nearest</div>
                    <div class="schoolsV12NearestName">${esc(nearest.name || "Nearby healthcare option")}</div>
                    <div class="schoolsV12NearestDistance">${esc(formatDistanceKm(nearest.distanceKm))} away</div>
                  </div>
                ` : ""}

                <div class="schoolsV12Rows">
                  ${visibleRows.length ? visibleRows.map(item => renderHealthcareCompactRow(item, config)).join("") : (!nearest ? `
                    <div class="schoolsV12Empty">
                      No ${esc(config.title.toLowerCase())} found nearby yet. HAVN will refresh this area intelligence as more data becomes available.
                    </div>
                  ` : "")}
                </div>

                ${hiddenRows.length ? `
                  <details class="transportV2InlineDetails">
                    <summary>
                      <div class="transportV2CardButton">
                        <span class="transportOpenLabel">View all ${esc(String(uniqueCount))} ${esc(config.shortLabel)} options ▾</span>
                        <span class="transportCloseLabel" style="display:none;">Hide ${esc(config.shortLabel)} options ▲</span>
                      </div>
                    </summary>
                    <div class="transportV2InlineRows">
                      ${hiddenRows.map(item => `
                        <div class="transportV2InlineRow">
                          <div>
                            <strong>${esc(item.displayName || item.name || "Nearby healthcare option")}</strong>
                            <span>${esc(itemMeta(item, config.fallbackType))}</span>
                          </div>
                          <em>${esc(formatDistanceKm(item.distanceKm))}</em>
                        </div>
                      `).join("")}
                    </div>
                  </details>
                ` : ""}
              </div>
            `;
          }

          const total = hospitals.length + gps.length + dental.length + specialists.length + urgentCare.length;
          if(!total){
            return `<div class="intelInsightBox">No hospital, GP, dental or specialist healthcare results were found nearby yet. HAVN will refresh this area intelligence as more data becomes available.</div>`;
          }

          const summaryParts = [];
          if(hospitals.length) summaryParts.push(dedupeHealthcareRows(hospitals).length + " hospital signal" + (dedupeHealthcareRows(hospitals).length === 1 ? "" : "s"));
          if(gps.length) summaryParts.push(dedupeHealthcareRows(gps).length + " GP/clinic option" + (dedupeHealthcareRows(gps).length === 1 ? "" : "s"));
          if(dental.length) summaryParts.push(dedupeHealthcareRows(dental).length + " dental option" + (dedupeHealthcareRows(dental).length === 1 ? "" : "s"));
          if(specialists.length) summaryParts.push(dedupeHealthcareRows(specialists).length + " specialist/therapy option" + (dedupeHealthcareRows(specialists).length === 1 ? "" : "s"));
          if(urgentCare.length) summaryParts.push(dedupeHealthcareRows(urgentCare).length + " urgent-care signal" + (dedupeHealthcareRows(urgentCare).length === 1 ? "" : "s"));

          return `
            <div class="schoolsV12Shell">
              <div class="schoolsV12Intro">
                <div>
                  <strong>Healthcare infrastructure overview</strong>
                  <span>${esc(summaryParts.join(", "))} nearby. Pharmacies are handled separately under Shopping & Convenience.</span>
                </div>
                ${healthcareScore !== null ? `<div class="schoolsV12Score"><strong>${esc(String(healthcareScore))}</strong>/100<div>${esc(healthcareLabel)}</div></div>` : ""}
              </div>
              <div class="schoolsV12Grid">
                ${renderHealthcareGroup({title:"Hospitals",shortLabel:"hospital",icon:"🏥",items:hospitals,fallbackType:"Hospital"})}
                ${renderHealthcareGroup({title:"GPs & Medical Clinics",shortLabel:"GP/clinic",icon:"🩺",items:gps,fallbackType:"GP / medical clinic"})}
                ${renderHealthcareGroup({title:"Dental Care",shortLabel:"dental",icon:"🦷",items:dental,fallbackType:"Dental care"})}
                ${renderHealthcareGroup({title:"Specialists & Therapy",shortLabel:"specialist",icon:"🧑‍⚕️",items:specialists,fallbackType:"Specialist / therapy"})}
                ${renderHealthcareGroup({title:"Urgent Care",shortLabel:"urgent care",icon:"🚑",items:urgentCare,fallbackType:"Urgent / out-of-hours care"})}
              </div>
            </div>
          `;
        }


        function renderLifestyleGroupsRows(groups, areaScores){
          const safeGroups = groups && typeof groups === "object" ? groups : {};
          const parks = Array.isArray(safeGroups.parks) ? safeGroups.parks : [];
          const fitness = Array.isArray(safeGroups.fitness) ? safeGroups.fitness : [];
          const foodCoffee = Array.isArray(safeGroups.foodCoffee) ? safeGroups.foodCoffee : [];
          const culture = Array.isArray(safeGroups.culture) ? safeGroups.culture : [];
          const lifestyleScoreData = areaScores && areaScores.lifestyle ? areaScores.lifestyle : null;
          const lifestyleScore = lifestyleScoreData && Number.isFinite(Number(lifestyleScoreData.score)) ? Math.max(0, Math.min(100, Math.round(Number(lifestyleScoreData.score)))) : null;
          const lifestyleLabel = lifestyleScoreData && lifestyleScoreData.label ? String(lifestyleScoreData.label).trim() : "Lifestyle intelligence";

          function rowsFor(items){
            return Array.isArray(items) ? items.slice().sort((a,b) => Number(a.distanceKm || 9999) - Number(b.distanceKm || 9999)) : [];
          }

          function normaliseLifestyleName(name){
            let s = String(name || "").trim();
            if(!s) return "";
            s = s.replace(/\s+/g, " ").trim();
            const lower = s.toLowerCase();

            if(lower.includes("st stephen")) return "St Stephen's Green";
            if(lower.includes("merrion square")) return "Merrion Square Park";
            if(lower.includes("palmerston park")) return "Palmerston Park";
            if(lower.includes("fairview park")) return "Fairview Park";
            if(lower.includes("iconic health clubs")) return s.replace(/\s+/g, " ").trim();
            if(lower.includes("west wood")) return "West Wood Club";
            if(lower.includes("trinity college sports")) return "Trinity College Sports Centre";
            if(lower.includes("moli") || lower.includes("museum of literature")) return "MoLI – Museum of Literature Ireland";
            if(lower.includes("project arts")) return "Project Arts Centre";
            if(lower.includes("smock alley")) return "Smock Alley Theatre";
            if(lower.includes("photo museum")) return "Photo Museum Ireland";
            if(lower.includes("bewley")) return "Bewley's Grafton Street";
            if(lower.includes("brother hubbard")) return "Brother Hubbard";
            if(lower.includes("fumbally")) return "The Fumbally";
            if(lower.includes("two pups")) return "Two Pups";

            return s;
          }

          function dedupeLifestyleRows(items){
            const rows = rowsFor(items);
            const seen = new Set();
            const out = [];

            rows.forEach(item => {
              const displayName = normaliseLifestyleName(item && item.name) || String(item && item.name || "Nearby lifestyle option").trim();
              const key = displayName.toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();
              if(seen.has(key)) return;
              seen.add(key);
              out.push({ ...item, displayName });
            });

            return out;
          }

          function lifestyleTypeLabel(item, fallback){
            const name = String((item && item.name) || "").toLowerCase();
            const address = String((item && item.address) || "").toLowerCase();
            const text = name + " " + address;

            if(text.includes("park") || text.includes("green") || text.includes("beach")) return "Park / green space";
            if(text.includes("gym") || text.includes("fitness") || text.includes("leisure") || text.includes("sports") || text.includes("club")) return "Fitness / sport";
            if(text.includes("cafe") || text.includes("café") || text.includes("coffee") || text.includes("restaurant") || text.includes("bistro") || text.includes("bakery") || text.includes("brunch")) return "Food / coffee";
            if(text.includes("museum") || text.includes("gallery") || text.includes("theatre") || text.includes("arts") || text.includes("music") || text.includes("cinema") || text.includes("studio")) return "Culture / entertainment";

            return fallback;
          }

          function itemMeta(item, fallback){
            const rating = Number(item && item.rating);
            const bits = [];
            if(Number.isFinite(rating) && rating > 0) bits.push("★ " + rating.toFixed(1));
            bits.push(lifestyleTypeLabel(item, fallback));
            if(item && item.address) bits.push(String(item.address));
            return bits.join(" · ");
          }

          function renderLifestyleCompactRow(item, config){
            return `
              <div class="schoolsV12Row">
                <div>
                  <strong>${esc(item.displayName || item.name || "Nearby lifestyle option")}</strong>
                  <span>${esc(itemMeta(item, config.fallbackType))}</span>
                </div>
                <em>${esc(formatDistanceKm(item.distanceKm))}</em>
              </div>
            `;
          }

          function renderLifestyleGroup(config){
            const allRows = rowsFor(config.items);
            const displayRowsAll = dedupeLifestyleRows(config.items);
            const nearest = allRows[0] || null;
            const nearestNameKey = nearest ? (normaliseLifestyleName(nearest.name) || String(nearest.name || "").trim()).toLowerCase().replace(/[^a-z0-9]+/g, " ").trim() : "";
            const displayRows = displayRowsAll.filter(item => {
              const key = String(item.displayName || item.name || "").toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();
              return !nearestNameKey || key !== nearestNameKey;
            });
            const visibleRows = displayRows.slice(0, 5);
            const hiddenRows = displayRows.slice(5);
            const uniqueCount = displayRowsAll.length;
            const resultCount = allRows.length;

            return `
              <div class="schoolsV12Group">
                <div class="schoolsV12Head">
                  <div style="display:flex;gap:10px;align-items:flex-start;min-width:0;">
                    <div class="schoolsV12Icon" aria-hidden="true">${esc(config.icon)}</div>
                    <div>
                      <h4 class="schoolsV12Title">${esc(config.title)}</h4>
                      <div class="schoolsV12Count">${esc(String(uniqueCount))} distinct option${uniqueCount === 1 ? "" : "s"}${resultCount !== uniqueCount ? " from " + esc(String(resultCount)) + " nearby results" : " nearby"}</div>
                    </div>
                  </div>
                </div>

                ${nearest ? `
                  <div class="schoolsV12Nearest">
                    <div class="schoolsV12NearestLabel">Nearest</div>
                    <div class="schoolsV12NearestName">${esc(nearest.name || "Nearby lifestyle option")}</div>
                    <div class="schoolsV12NearestDistance">${esc(formatDistanceKm(nearest.distanceKm))} away</div>
                  </div>
                ` : ""}

                <div class="schoolsV12Rows">
                  ${visibleRows.length ? visibleRows.map(item => renderLifestyleCompactRow(item, config)).join("") : (!nearest ? `
                    <div class="schoolsV12Empty">
                      No ${esc(config.title.toLowerCase())} found nearby yet. HAVN will refresh this area intelligence as more data becomes available.
                    </div>
                  ` : "")}
                </div>

                ${hiddenRows.length ? `
                  <details class="transportV2InlineDetails">
                    <summary>
                      <div class="transportV2CardButton">
                        <span class="transportOpenLabel">View all ${esc(String(uniqueCount))} ${esc(config.shortLabel)} options ▾</span>
                        <span class="transportCloseLabel" style="display:none;">Hide ${esc(config.shortLabel)} options ▲</span>
                      </div>
                    </summary>
                    <div class="transportV2InlineRows">
                      ${hiddenRows.map(item => `
                        <div class="transportV2InlineRow">
                          <div>
                            <strong>${esc(item.displayName || item.name || "Nearby lifestyle option")}</strong>
                            <span>${esc(itemMeta(item, config.fallbackType))}</span>
                          </div>
                          <em>${esc(formatDistanceKm(item.distanceKm))}</em>
                        </div>
                      `).join("")}
                    </div>
                  </details>
                ` : ""}
              </div>
            `;
          }

          const total = parks.length + fitness.length + foodCoffee.length + culture.length;
          if(!total){
            return `<div class="intelInsightBox">No lifestyle results were found nearby yet. HAVN will refresh this area intelligence as more data becomes available.</div>`;
          }

          const summaryParts = [];
          if(parks.length) summaryParts.push(dedupeLifestyleRows(parks).length + " park/green-space option" + (dedupeLifestyleRows(parks).length === 1 ? "" : "s"));
          if(fitness.length) summaryParts.push(dedupeLifestyleRows(fitness).length + " fitness/sport option" + (dedupeLifestyleRows(fitness).length === 1 ? "" : "s"));
          if(foodCoffee.length) summaryParts.push(dedupeLifestyleRows(foodCoffee).length + " food/coffee option" + (dedupeLifestyleRows(foodCoffee).length === 1 ? "" : "s"));
          if(culture.length) summaryParts.push(dedupeLifestyleRows(culture).length + " culture/entertainment option" + (dedupeLifestyleRows(culture).length === 1 ? "" : "s"));

          return `
            <div class="schoolsV12Shell">
              <div class="schoolsV12Intro">
                <div>
                  <strong>Lifestyle overview</strong>
                  <span>${esc(summaryParts.join(", "))} nearby, grouped by how people actually use the neighbourhood.</span>
                </div>
                ${lifestyleScore !== null ? `<div class="schoolsV12Score"><strong>${esc(String(lifestyleScore))}</strong>/100<div>${esc(lifestyleLabel)}</div></div>` : ""}
              </div>
              <div class="schoolsV12Grid">
                ${renderLifestyleGroup({title:"Parks & Green Space",shortLabel:"park",icon:"🌳",items:parks,fallbackType:"Park / green space"})}
                ${renderLifestyleGroup({title:"Fitness & Sport",shortLabel:"fitness",icon:"🏋️",items:fitness,fallbackType:"Fitness / sport"})}
                ${renderLifestyleGroup({title:"Food & Coffee",shortLabel:"food/coffee",icon:"☕",items:foodCoffee,fallbackType:"Food / coffee"})}
                ${renderLifestyleGroup({title:"Culture & Entertainment",shortLabel:"culture",icon:"🎭",items:culture,fallbackType:"Culture / entertainment"})}
              </div>
            </div>
          `;
        }


        function intelCategoryHasItems(cat){
          if(!cat) return false;
          if(Array.isArray(cat.items)) return cat.items.length > 0;
          if(cat.key === "schools" && cat.items && typeof cat.items === "object"){
            return ["primary","secondary","childcare"].some(key => Array.isArray(cat.items[key]) && cat.items[key].length > 0);
          }
          if(cat.key === "convenience" && cat.items && typeof cat.items === "object"){
            return ["grocery","pharmacy","dailyServices","retail"].some(key => Array.isArray(cat.items[key]) && cat.items[key].length > 0);
          }
          if(cat.key === "healthcare" && cat.items && typeof cat.items === "object"){
            return ["hospitals","gps","dental","specialists","urgentCare"].some(key => Array.isArray(cat.items[key]) && cat.items[key].length > 0);
          }
          if(cat.key === "lifestyle" && cat.items && typeof cat.items === "object"){
            return ["parks","fitness","foodCoffee","culture"].some(key => Array.isArray(cat.items[key]) && cat.items[key].length > 0);
          }
          return false;
        }

        function renderTransportV3Rows(items, areaScores){
          const rows = Array.isArray(items) ? items : [];

          if(!rows.length){
            return `
              <div class="intelInsightBox">
                No public transport routes were found nearby yet. HAVN will refresh this area intelligence as more data becomes available.
              </div>
            `;
          }

          const groups = [];

          function normaliseProviderName(rawProvider, rawType){
            const provider = rawProvider && rawProvider !== "—"
              ? String(rawProvider).trim()
              : "";

            const providerLower = provider.toLowerCase();

            if(rawType === "Tram" && providerLower.includes("luas")) return "LUAS";
            if(rawType === "Rail") return "Irish Rail";
            if(providerLower.includes("local link")) return "TFI Local Link";
            if(providerLower.includes("citylink")) return "Citylink";
            if(providerLower.includes("healy")) return "Healy Bus";
            if(providerLower.includes("bus") && (providerLower.includes("éireann") || providerLower.includes("eireann"))) return "Bus Éireann";

            return provider || "Transport operator";
          }

          function transportTypeLabel(rawType){
            if(rawType === "Rail") return "Rail";
            if(rawType === "Bus") return "Bus";
            if(rawType === "Tram") return "Tram";
            if(rawType === "Ferry") return "Ferry";
            return "Transport";
          }

          function transportIcon(rawType, groupName){
            const name = String(groupName || "").toLowerCase();
            if(rawType === "Rail") return "🚆";
            if(rawType === "Tram") return "🚋";
            if(rawType === "Ferry") return "⛴️";
            if(name.includes("citylink")) return "✈️";
            if(rawType === "Bus") return "🚌";
            return "↗";
          }

          function groupSortRank(group){
            const name = String(group.name || "").toLowerCase();
            if(group.rawType === "Tram" && name.includes("luas")) return 1;
            if(group.rawType === "Rail" && name.includes("dart")) return 2;
            if(group.rawType === "Rail") return 3;
            if(name.includes("dublin bus") || name.includes("bus átha cliath") || name.includes("bus atha cliath")) return 4;
            if(name.includes("bus éireann") || name.includes("bus eireann")) return 5;
            if(name.includes("local link")) return 6;
            if(name.includes("citylink")) return 7;
            if(group.rawType === "Bus") return 8;
            return 9;
          }

          function cleanDestination(value){
            let s = String(value || "").trim();
            if(!s || s === "—") return "";
            s = s.replace(/^direct\s*\/\s*listed\s+towards\s+/i, "");
            s = s.replace(/\s+-\s+[^-]+$/g, "");
            s = s.replace(/\s+Station$/i, "");
            s = s.replace(/\s+Centre$/i, " Centre");
            return s.trim();
          }

          function destinationKey(value){
            return cleanDestination(value).toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();
          }

          function directLabelFromDestination(destination){
            const key = destinationKey(destination);
            if(!key) return "";

            if(key.includes("dublin airport")) return "Dublin Airport";
            if(key.includes("dublin heuston") || key === "dublin" || key.includes("dublin city")) return "Dublin City";
            if(key.includes("galway ceannt") || key === "galway" || key.includes("eyre square")) return "Galway City";
            if(key.includes("cliffs of moher")) return "Cliffs of Moher";
            if(key.includes("limerick")) return "Limerick";
            if(key.includes("ennis")) return "Ennis";
            if(key.includes("athlone")) return "Athlone";
            if(key.includes("athenry")) return "Athenry";
            if(key.includes("doolin")) return "Doolin";
            if(key.includes("gort")) return "Gort";
            if(key.includes("loughrea")) return "Loughrea";
            if(key.includes("university of galway") || key.includes("uni of galway")) return "University of Galway";

            return cleanDestination(destination);
          }

          function connectionIcon(label){
            const key = String(label || "").toLowerCase();
            if(key.includes("airport")) return "✈️";
            if(key.includes("dublin") || key.includes("galway") || key.includes("limerick") || key.includes("ennis")) return "🏙️";
            if(key.includes("cliffs") || key.includes("doolin")) return "🌊";
            return "📍";
          }

          function nearestStopLabel(group){
            const stop = String(group.nearestStop || "Nearby stop").trim();
            if(group.rawType === "Rail" && !stop.toLowerCase().includes("station")){
              return stop + " Station";
            }
            return stop;
          }

          rows.forEach(item => {
            const rawType = String(item.type || "Transport").trim();
            const typeLabel = transportTypeLabel(rawType);
            const itemRoute = String(item.route || "").trim();
            let groupName = normaliseProviderName(item.provider, rawType);

            if(rawType === "Tram" && String(groupName || "").toLowerCase().includes("luas")){
              groupName = "LUAS";
            }

            if(rawType === "Rail"){
              groupName = itemRoute.toLowerCase() === "dart" ? "DART" : "Irish Rail Commuter";
            }

            const icon = transportIcon(rawType, groupName);
            const groupKey = `${rawType}|${groupName}`;

            let group = groups.find(g => g.key === groupKey);

            if(!group){
              group = {
                key:groupKey,
                rawType,
                icon,
                type:typeLabel,
                name:groupName,
                nearestKm:Number(item.distanceKm || 9999),
                nearestStop:item.stop || "Nearby stop",
                services:[]
              };
              groups.push(group);
            }

            const dist = Number(item.distanceKm || 9999);
            if(dist < group.nearestKm){
              group.nearestKm = dist;
              group.nearestStop = item.stop || group.nearestStop;
            }

            const route = item.route && item.route !== "—"
              ? String(item.route).trim()
              : "";

            const destination = cleanDestination(item.destination);
            const stop = item.stop || "Nearby stop";
            const serviceKey = `${route}|${destination}|${stop}|${formatDistanceKm(item.distanceKm)}`;

            if(!group.services.some(s => s.key === serviceKey)){
              group.services.push({
                key:serviceKey,
                route,
                destination,
                stop,
                distanceKm:item.distanceKm
              });
            }
          });

          groups.sort((a, b) => {
            const rankDiff = groupSortRank(a) - groupSortRank(b);
            if(rankDiff !== 0) return rankDiff;
            return a.nearestKm - b.nearestKm;
          });

          groups.forEach(group => {
            group.services.sort((a,b) => Number(a.distanceKm || 9999) - Number(b.distanceKm || 9999));
          });

          const totalOptions = groups.reduce((sum, group) => sum + group.services.length, 0);

          const luasGroup = groups.find(group => {
            const name = String(group.name || "").toLowerCase();
            return group.rawType === "Tram" && name.includes("luas");
          });

          const dartGroup = groups.find(group => {
            const name = String(group.name || "").toLowerCase();
            return group.rawType === "Rail" && name.includes("dart");
          });

          const railGroup = groups.find(group => {
            const name = String(group.name || "").toLowerCase();
            return group.rawType === "Rail" && !name.includes("dart");
          });

          const busGroups = groups.filter(g => g.rawType === "Bus");

          const dublinBusGroup = busGroups.find(group => {
            const name = String(group.name || "").toLowerCase();
            return name.includes("dublin bus") || name.includes("bus átha cliath") || name.includes("bus atha cliath");
          });

          const nearestBus = busGroups.slice().sort((a,b) => a.nearestKm - b.nearestKm)[0];

          const directMap = new Map();
          rows.forEach(item => {
            const label = directLabelFromDestination(item.destination);
            if(!label) return;

            const rawType = String(item.type || "Transport").trim();
            const provider = normaliseProviderName(item.provider, rawType);
            const route = item.route && item.route !== "—" && rawType !== "Rail" ? String(item.route).trim() : "";
            const dist = Number(item.distanceKm || 9999);

            const current = directMap.get(label);
            const method = rawType === "Rail" ? "Irish Rail" : (route ? provider + " " + route : provider);

            if(!current || dist < current.distanceKm){
              directMap.set(label, {
                label,
                icon:connectionIcon(label),
                method,
                distanceKm:dist
              });
            }
          });

          const preferredConnectionOrder = [
            "Galway City",
            "Dublin City",
            "Dublin Airport",
            "Limerick",
            "Ennis",
            "Cliffs of Moher",
            "Athlone",
            "Athenry",
            "Doolin",
            "University of Galway"
          ];

          const keyConnections = preferredConnectionOrder
            .filter(label => directMap.has(label))
            .map(label => directMap.get(label))
            .concat(Array.from(directMap.values()).filter(item => !preferredConnectionOrder.includes(item.label)))
            .slice(0, 8);

          const hasLuas = !!luasGroup;
          const hasDart = !!dartGroup;
          const hasRail = !!railGroup || !!dartGroup;
          const hasBus = busGroups.length > 0;
          const hasAirport = keyConnections.some(x => String(x.label).toLowerCase().includes("airport"));
          const hasDublin = keyConnections.some(x => String(x.label).toLowerCase().includes("dublin"));
          const hasGalway = keyConnections.some(x => String(x.label).toLowerCase().includes("galway"));

          let legacyTransportScore = 52;
          legacyTransportScore += Math.min(18, totalOptions * 1.2);
          legacyTransportScore += hasRail ? 12 : 0;
          legacyTransportScore += hasBus ? 8 : 0;
          legacyTransportScore += hasAirport ? 5 : 0;
          legacyTransportScore += hasDublin ? 4 : 0;
          legacyTransportScore += hasGalway ? 4 : 0;

          const nearestDistance = Math.min.apply(null, groups.map(g => Number(g.nearestKm || 9999)));
          if(Number.isFinite(nearestDistance)){
            if(nearestDistance <= 0.7) legacyTransportScore += 6;
            else if(nearestDistance <= 1.5) legacyTransportScore += 3;
          }

          legacyTransportScore = Math.max(0, Math.min(98, Math.round(legacyTransportScore)));

          const connectivityScoreData = areaScores && areaScores.connectivity ? areaScores.connectivity : null;
          const canonicalConnectivityScore = connectivityScoreData ? Number(connectivityScoreData.score) : NaN;
          const transportScore = Number.isFinite(canonicalConnectivityScore)
            ? Math.max(0, Math.min(100, Math.round(canonicalConnectivityScore)))
            : legacyTransportScore;

          const rawConnectivityLabel = connectivityScoreData && connectivityScoreData.label
            ? String(connectivityScoreData.label).trim()
            : "";

          const fallbackConnectivityLabel = transportScore >= 88
            ? "Excellent"
            : transportScore >= 74
              ? "Strong"
              : transportScore >= 60
                ? "Good"
                : "Limited";

          const scoreLabelBase = rawConnectivityLabel || fallbackConnectivityLabel;
          const scoreLabel = scoreLabelBase.toLowerCase().includes("connectivity")
            ? scoreLabelBase
            : scoreLabelBase + " connectivity";

          function topDestinationsForGroup(group, limit){
            const seen = new Set();
            const out = [];

            group.services.forEach(service => {
              const label = directLabelFromDestination(service.destination) || cleanDestination(service.destination);
              const key = String(label || "").toLowerCase();
              if(!label || seen.has(key)) return;
              seen.add(key);
              out.push({
                label,
                route:service.route,
                distanceKm:service.distanceKm
              });
            });

            return out.slice(0, limit || 5);
          }

          function renderFullServiceRowsForGroup(group){
            const seen = new Set();
            const rowsOut = [];

            group.services.forEach(service => {
              const routeTitle = service.route ? "Route " + service.route : group.type;
              const dest = directLabelFromDestination(service.destination) || cleanDestination(service.destination) || "Nearby service";
              const stop = service.stop || nearestStopLabel(group);
              const key = String(routeTitle + "|" + dest + "|" + stop + "|" + formatDistanceKm(service.distanceKm)).toLowerCase();

              if(seen.has(key)) return;
              seen.add(key);

              rowsOut.push(`
                <div class="transportV2InlineRow">
                  <div>
                    <strong>${esc(routeTitle)} → ${esc(dest)}</strong>
                    <span>${esc(stop)}</span>
                  </div>
                  <em>${esc(formatDistanceKm(service.distanceKm))}</em>
                </div>
              `);
            });

            return rowsOut.join("") || `<div class="transportV2EmptyLine">No additional route detail available.</div>`;
          }

          const primaryGroupCandidates = [
            luasGroup,
            dartGroup,
            railGroup,
            dublinBusGroup || nearestBus
          ].filter(Boolean);

          const primaryGroups = [];
          const primarySeen = new Set();

          primaryGroupCandidates.forEach(group => {
            if(!group || primarySeen.has(group.key)) return;
            primarySeen.add(group.key);
            primaryGroups.push(group);
          });

          groups.forEach(group => {
            if(primaryGroups.length >= 4) return;
            if(primarySeen.has(group.key)) return;
            primarySeen.add(group.key);
            primaryGroups.push(group);
          });

          const additionalGroups = groups.filter(group => !primarySeen.has(group.key));

          const overviewCards = primaryGroups.map(group => {
            const count = group.services.length;
            const countWord = group.rawType === "Rail" ? (count === 1 ? "service" : "services") : (count === 1 ? "route" : "routes");
            const stopLabel = group.rawType === "Rail"
              ? "Nearest station"
              : group.rawType === "Tram"
                ? "Nearest LUAS stop"
                : "Nearest stop";
            const groupNameLower = String(group.name || "").toLowerCase();
            const badgeText = groupNameLower.includes("luas")
              ? "LUAS access"
              : groupNameLower.includes("dart")
                ? "DART access"
                : group.rawType === "Rail"
                  ? "Rail access"
                  : groupNameLower.includes("local link")
                    ? "Local connectivity"
                    : "Bus connectivity";

            return `
              <div class="transportV2OverviewCard">
                <div class="transportV2Icon">${esc(group.icon)}</div>
                <div class="transportV2Provider">${esc(group.name)}</div>
                <div class="transportV2Count">${esc(String(count))} ${esc(countWord)}</div>
                <div class="transportV2Label">${esc(stopLabel)}</div>
                <div class="transportV2Nearest">${esc(nearestStopLabel(group))}</div>
                <div class="transportV2Distance">${esc(formatDistanceKm(group.nearestKm))} away</div>
                <div class="transportV2MiniBadge">${esc(badgeText)}</div>
              </div>
            `;
          }).join("");

          const keyConnectionCards = keyConnections.length
            ? keyConnections.map(item => `
                <div class="transportV2ConnectionCard">
                  <div class="transportV2ConnectionIcon">${esc(item.icon)}</div>
                  <div class="transportV2ConnectionName">${esc(item.label)}</div>
                  <div class="transportV2ConnectionDirect">Direct</div>
                  <div class="transportV2ConnectionMethod">${esc(item.method)}</div>
                </div>
              `).join("")
            : `
                <div class="transportV2EmptyLine">Direct destination intelligence will appear here as more transport data is refreshed.</div>
              `;

          const nearbyCards = primaryGroups.map(group => {
            const destinations = topDestinationsForGroup(group, 5);
            const stopLabel = group.rawType === "Rail" ? "Nearest station" : "Nearest stop";
            const count = group.services.length;
            const buttonText = group.rawType === "Rail"
              ? "View all " + count + " services"
              : "View all " + count + " routes";
            const hideText = group.rawType === "Rail" ? "Hide services" : "Hide routes";

            return `
              <div class="transportV2NearbyCard ${group.rawType === "Rail" ? "rail" : "bus"}">
                <div class="transportV2NearbyHead">
                  <div class="transportV2NearbyIcon">${esc(group.icon)}</div>
                  <div>
                    <h4>${esc(group.name)}</h4>
                    <p>${esc(stopLabel)}</p>
                  </div>
                </div>

                <div class="transportV2StopRow">
                  <strong>${esc(nearestStopLabel(group))}</strong>
                  <span>${esc(formatDistanceKm(group.nearestKm))}</span>
                </div>

                <div class="transportV2DestinationList">
                  ${destinations.length ? destinations.map(dest => `
                    <div class="transportV2DestinationRow">
                      <span>✓</span>
                      <strong>${esc(dest.route ? "Route " + dest.route + " → " + dest.label : dest.label)}</strong>
                      <em>Direct</em>
                    </div>
                  `).join("") : `
                    <div class="transportV2EmptyLine">Nearby service details available.</div>
                  `}
                </div>

                <details class="transportV2InlineDetails">
                  <summary>
                    <div class="transportV2CardButton">
                      <span class="transportOpenLabel">${esc(buttonText)} ▾</span>
                      <span class="transportCloseLabel" style="display:none;">${esc(hideText)} ▲</span>
                    </div>
                  </summary>
                  <div class="transportV2InlineRows">
                    ${renderFullServiceRowsForGroup(group)}
                  </div>
                </details>
              </div>
            `;
          }).join("");

          const additionalCards = additionalGroups.length ? `
            <div class="transportV2Additional">
              <h4>Additional services</h4>
              <div class="transportV2AdditionalGrid">
                ${additionalGroups.map(group => {
                  const destinations = topDestinationsForGroup(group, 2).map(x => x.label).join(" and ");
                  const routeCountText = String(group.services.length) + " route" + (group.services.length === 1 ? "" : "s");
                  return `
                    <details class="transportV2AdditionalDetails">
                      <summary>
                        <div class="transportV2AdditionalCard">
                          <div>
                            <strong>${esc(group.icon)} ${esc(group.name)}</strong>
                            <span>Nearest stop: ${esc(nearestStopLabel(group))} (${esc(formatDistanceKm(group.nearestKm))})</span>
                            <p>${esc(destinations ? "Direct to " + destinations + "." : "Additional nearby transport services.")}</p>
                          </div>
                          <em>${esc(routeCountText)} ▾</em>
                        </div>
                      </summary>
                      <div class="transportV2AdditionalRouteRows">
                        ${renderFullServiceRowsForGroup(group)}
                      </div>
                    </details>
                  `;
                }).join("")}
              </div>
            </div>
          ` : "";

          const detailedGroups = groups.map(group => {
            const count = group.services.length;
            return `
              <div class="transportV2DetailGroup">
                <div class="transportV2DetailHead">
                  <div>
                    <strong>${esc(group.icon)} ${esc(group.name)}</strong>
                    <span>${esc(group.rawType === "Rail" ? "Nearest station" : "Nearest stop")}: ${esc(nearestStopLabel(group))} · ${esc(formatDistanceKm(group.nearestKm))}</span>
                  </div>
                  <em>${esc(String(count))} option${count === 1 ? "" : "s"}</em>
                </div>
                <div class="transportV2DetailRows">
                  ${group.services.map(service => {
                    const routeTitle = service.route ? "Route " + service.route : group.type;
                    const dest = directLabelFromDestination(service.destination) || cleanDestination(service.destination) || "Nearby service";
                    return `
                      <div class="transportV2DetailRow">
                        <span>${esc(routeTitle)}</span>
                        <strong>${esc(dest)} · ${esc(service.stop || nearestStopLabel(group))}</strong>
                        <em>${esc(formatDistanceKm(service.distanceKm))}</em>
                      </div>
                    `;
                  }).join("")}
                </div>
              </div>
            `;
          }).join("");

          const insightBits = [];
          if(hasLuas) insightBits.push("LUAS access");
          if(hasDart) insightBits.push("DART access");
          if(railGroup) insightBits.push("rail access");
          if(hasGalway) insightBits.push("direct Galway connections");
          if(hasDublin) insightBits.push("Dublin connectivity");
          if(hasAirport) insightBits.push("direct airport access");

          const insightText = insightBits.length
            ? "This location has " + insightBits.join(", ") + ", making it stronger than a basic car-dependent listing area."
            : "This location has nearby public transport options, with route details available below.";

          return `
            <div class="transportV2Shell">
              <div class="transportV2MainCard">
                <div class="transportV2Header">
                  <div class="transportV2HeaderIcon">🚆</div>
                  <div>
                    <h3>Public Transport Overview</h3>
                    <p>${esc(scoreLabel)} with ${esc(String(totalOptions))} nearby transport option${totalOptions === 1 ? "" : "s"}.</p>
                  </div>
                </div>

                <div class="transportV2OverviewGrid">
                  ${overviewCards}
                </div>

                <div class="transportV2ScoreBand">
                  <div class="transportV2ScoreText">
                    <span>✓</span>
                    <div>
                      <strong>${esc(scoreLabel)}</strong>
                      <p>${esc(insightText)}</p>
                    </div>
                  </div>
                  <div class="transportV2ScoreDial">
                    <strong>${esc(String(transportScore))}</strong><span>/100</span>
                    <small>Connectivity Score</small>
                  </div>
                </div>
              </div>

              <div class="transportV2ConnectionSection">
                <h3>Key Connections</h3>
                <div class="transportV2ConnectionsGrid">
                  ${keyConnectionCards}
                </div>
              </div>

              <div class="transportV2NearbySection">
                <h3>Transport Options Nearby</h3>
                <div class="transportV2NearbyGrid">
                  ${nearbyCards}
                </div>
              </div>

              ${additionalCards}

              <details class="transportV2Advanced">
                <summary>
                  <span>View all ${esc(String(totalOptions))} transport options</span>
                  <strong>Advanced routes ▼</strong>
                </summary>
                <div class="transportV2AdvancedBody">
                  ${detailedGroups}
                </div>
              </details>
            </div>
          `;
        }

        function renderIntelCategoryTable(title, items, label, key, areaScores){
          const isTransportV3 = key === "transportV3";
          const isSchools = key === "schools";
          const isConvenience = key === "convenience";
          const isHealthcare = key === "healthcare";
          const isLifestyle = key === "lifestyle";

          return `
            <div class="intelDataCard" style="grid-column:1 / -1;">
              <h3>${esc(title)}</h3>
              ${isSchools ? renderSchoolGroupsRows(items, areaScores) : isConvenience ? renderConvenienceGroupsRows(items, areaScores) : isHealthcare ? renderHealthcareGroupsRows(items, areaScores) : isLifestyle ? renderLifestyleGroupsRows(items, areaScores) : isTransportV3 ? renderTransportV3Rows(items, areaScores) : renderIntelRows(items, label)}
            </div>
          `;
        }

        async function loadPropertyIntelligence(p){
          if(!locationIntelGrid || !p || !p.id) return;
        
          try{
            const res = await fetch(API + "/api/properties/" + encodeURIComponent(String(p.id)) + "/intelligence", {
              headers:{ "Accept":"application/json" },
              cache:"no-store"
            });
        
            const data = await res.json().catch(() => null);
        
            if(!res.ok || !data || !data.ok || !data.intelligence){
              throw new Error("Could not load intelligence");
            }
        
            const intel = data.intelligence;
            const nearby = intel.nearby || {};
            const market = intel.market || {};
        
            const mode = String(market.mode || p.mode || "").toUpperCase();
            const isRental = mode === "RENT" || mode === "SHARE";
        
            const pricePerSqm = market.pricePerSqm ? euro(market.pricePerSqm) + " / sqm" : "—";
            const rentPerBedroom = market.rentPerBedroom ? euro(market.rentPerBedroom) + " / bedroom" : "—";
        
            const updatedLabel = formatIntelUpdated(data.intelligenceUpdatedAt || intel.generatedAt);
        
            const transportItems =
              Array.isArray(nearby.transportV3) && nearby.transportV3.length
                ? nearby.transportV3
                : nearby.transport || [];
            
            const transportKey =
              Array.isArray(nearby.transportV3) && nearby.transportV3.length
                ? "transportV3"
                : "transport";
            
            const schoolGroups = nearby.schoolGroups && typeof nearby.schoolGroups === "object"
              ? nearby.schoolGroups
              : {
                  primary:Array.isArray(nearby.schools) ? nearby.schools.filter(item => String(item.schoolType || item.type || "").toUpperCase() !== "SECONDARY" && String(item.schoolType || item.type || "").toUpperCase() !== "CHILDCARE") : [],
                  secondary:Array.isArray(nearby.schools) ? nearby.schools.filter(item => String(item.schoolType || item.type || "").toUpperCase() === "SECONDARY") : [],
                  childcare:Array.isArray(nearby.childcare) ? nearby.childcare : []
                };

            const convenienceGroups = nearby.convenienceGroups && typeof nearby.convenienceGroups === "object"
              ? nearby.convenienceGroups
              : {
                  grocery:Array.isArray(nearby.shopping) ? nearby.shopping : [],
                  pharmacy:Array.isArray(nearby.healthcare) ? nearby.healthcare.filter(item => String(item.name || "").toLowerCase().includes("pharmacy") || String(item.name || "").toLowerCase().includes("chemist")) : [],
                  dailyServices:[],
                  retail:[]
                };

            const healthcareGroups = nearby.healthcareGroups && typeof nearby.healthcareGroups === "object"
              ? nearby.healthcareGroups
              : {
                  hospitals:[],
                  gps:Array.isArray(nearby.healthcare) ? nearby.healthcare.filter(item => {
                    const name = String(item.name || "").toLowerCase();
                    return !name.includes("pharmacy") && !name.includes("chemist");
                  }) : [],
                  dental:[],
                  specialists:[],
                  urgentCare:[]
                };

            const lifestyleGroups = nearby.lifestyleGroups && typeof nearby.lifestyleGroups === "object"
              ? nearby.lifestyleGroups
              : {
                  parks:Array.isArray(nearby.parks) ? nearby.parks : [],
                  fitness:Array.isArray(nearby.gyms) ? nearby.gyms : [],
                  foodCoffee:Array.isArray(nearby.restaurants) ? nearby.restaurants : [],
                  culture:[]
                };

            const categories = [
              { key:"schools", label:"Schools", title:"Schools & Childcare", items:schoolGroups },
              { key:transportKey, label:"Transport", title:"Public Transport", items:transportItems },
              { key:"convenience", label:"Shopping", title:"Shopping & Daily Convenience", items:convenienceGroups },
              { key:"healthcare", label:"Healthcare", title:"Healthcare", items:healthcareGroups },
              { key:"lifestyle", label:"Lifestyle", title:"Lifestyle", items:lifestyleGroups }
            ];

            const firstCategory = categories.find(c => intelCategoryHasItems(c)) || categories[0];

            locationIntelGrid.innerHTML = `
              <div style="grid-column:1/-1;display:flex;justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:2px;">
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                  <span style="display:inline-flex;align-items:center;gap:7px;padding:7px 10px;border-radius:999px;background:rgba(22,163,74,.08);border:1px solid rgba(22,163,74,.16);color:#166534;font-size:12px;font-weight:1000;">✓ Data cached</span>
                  ${updatedLabel ? `<span style="font-size:12px;font-weight:850;color:rgba(15,23,42,.55);">Updated ${esc(updatedLabel)}</span>` : ""}
                </div>
              </div>
        
              ${renderAreaIntelligenceDashboard(intel.areaScores)}

              <div class="intelScorePanel">
                <div class="intelScoreCard">
                  <strong>${esc(priceLabel(p))}</strong>
                  <span>${isRental ? "Monthly Cost" : "Guide Price"}</span>
                </div>
        
                <div class="intelScoreCard">
                  <strong>${esc(market.ber || p.ber || p.berRating || "—")}</strong>
                  <span>BER Rating</span>
                </div>
        
                <div class="intelScoreCard">
                  <strong>${esc(isRental ? rentPerBedroom : pricePerSqm)}</strong>
                  <span>${isRental ? "Rent per Bedroom" : "Price per sq m"}</span>
                </div>
              </div>
        
              <div style="grid-column:1/-1;margin-top:4px;border:1px solid rgba(15,23,42,.08);background:#fff;border-radius:18px;padding:14px;">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:12px;">
                  <div>
                    <h3 style="margin:0;font-size:17px;font-weight:1100;">Local schools, transport, healthcare & amenities</h3>
                    <div style="margin-top:4px;color:rgba(15,23,42,.55);font-size:12px;font-weight:850;">Explore what this area has to offer.</div>
                  </div>
                  <a class="miniBtn" href="${esc(openMapsBtn ? openMapsBtn.href : "#")}" target="_blank" rel="noopener">View on map</a>
                </div>
        
                <div id="intelTabs" style="display:flex;gap:8px;overflow:auto;border-bottom:1px solid rgba(15,23,42,.08);padding-bottom:0;margin-bottom:12px;">
                  ${categories.map((cat, idx) => `
                    <button
                      type="button"
                      class="intelTabBtn"
                      data-intel-tab="${esc(cat.key)}"
                      style="border:0;background:transparent;padding:11px 10px;border-bottom:3px solid ${cat.key === firstCategory.key ? "#2563eb" : "transparent"};color:${cat.key === firstCategory.key ? "#1d4ed8" : "rgba(15,23,42,.72)"};font-weight:1000;font-size:12px;white-space:nowrap;cursor:pointer;"
                    >
                      ${esc(cat.label)}
                    </button>
                  `).join("")}
                </div>
        
                <div style="display:block;">
                  <div id="intelTabPanel">
                    ${renderIntelCategoryTable(firstCategory.title, firstCategory.items, firstCategory.label.toLowerCase(), firstCategory.key, intel.areaScores)}
                  </div>
                </div>
              </div>
        
              <div class="intelFullPanel">
                <div class="intelInsightBox">
                  <strong>HAVN Area Insight:</strong>
                  ${esc(intel.commentary || "HAVN is analysing this location using listing data and nearby amenities.")}
                </div>
        
                <div class="intelInsightBox">
                  <strong>HAVN Insight:</strong>
                  ${esc(intel.insight || "This listing has live property intelligence available. Review nearby services, transport and amenities before arranging a viewing.")}
                </div>
              </div>
            `;
        
            wireAreaIntelligenceDashboard();

            const tabPanel = document.getElementById("intelTabPanel");
            const tabButtons = Array.from(document.querySelectorAll(".intelTabBtn"));
        
            tabButtons.forEach(btn => {
              btn.addEventListener("click", () => {
                const key = btn.getAttribute("data-intel-tab");
                const selected = categories.find(cat => cat.key === key) || categories[0];
        
                tabButtons.forEach(other => {
                  const active = other === btn;
                  other.style.borderBottomColor = active ? "#2563eb" : "transparent";
                  other.style.color = active ? "#1d4ed8" : "rgba(15,23,42,.72)";
                });
        
                if(tabPanel){
                  tabPanel.innerHTML = renderIntelCategoryTable(selected.title, selected.items, selected.label.toLowerCase(), selected.key, intel.areaScores);
                }
              });
            });
        
          }catch(err){
            console.warn("Property intelligence failed:", err);
        
            locationIntelGrid.innerHTML = `
              <div class="intelInsightBox">
                HAVN Property Intelligence is temporarily unavailable for this listing.
              </div>
            `;
          }
        }

        function getAdvertiserLabel(p){
          const type = firstValue(p.advertiserType, p.sellerType, p.ownerType, p.listedByType);
          if(type) return prettyRentalValue(type);
          const mode = String(p.mode || "").toUpperCase();
          if(mode === "BUY") return "Seller / agent";
          if(mode === "RENT") return "Landlord / agent";
          if(mode === "SHARE") return "Advertiser";
          return "Listing advertiser";
        }

        function renderAdvertiser(p){
          const name = firstValue(p.agentName, p.agencyName, p.sellerName, p.ownerName, p.contactName, "HAVN advertiser");
          const type = getAdvertiserLabel(p);

          if(advertiserName) advertiserName.textContent = name;
          if(advertiserType) advertiserType.textContent = type;
          if(advertiserInitial) advertiserInitial.textContent = String(name || "H").trim().charAt(0).toUpperCase() || "H";
          if(advertiserVerification) advertiserVerification.textContent = "Contact details are handled through HAVN enquiry flow.";
          if(advertiserModeHelp){
            const mode = String(p.mode || "").toUpperCase();
            if(mode === "SHARE") advertiserModeHelp.textContent = "Ask about house rules, bills, occupants and viewing arrangements before committing.";
            else if(mode === "RENT") advertiserModeHelp.textContent = "Ask about availability, lease terms, deposit and viewing arrangements before committing.";
            else advertiserModeHelp.textContent = "Ask for viewing times, documentation and supporting details before making decisions.";
          }
        }

        function updateContactCopy(p){
          const mode = String(p.mode || "").toUpperCase();

          if(actionTitle){
            if(mode === "BUY") actionTitle.textContent = "Request a viewing";
            else if(mode === "RENT") actionTitle.textContent = "Check availability";
            else if(mode === "SHARE") actionTitle.textContent = "Enquire about this room";
            else actionTitle.textContent = "Contact advertiser";
          }

          if(actionSub){
            if(mode === "BUY") actionSub.textContent = "Contact the advertiser to arrange a viewing or ask a question about this home.";
            else if(mode === "RENT") actionSub.textContent = "Confirm availability, deposit, lease terms and viewing times before making commitments.";
            else if(mode === "SHARE") actionSub.textContent = "Confirm room details, house rules, bills and viewing times before sending any money.";
            else actionSub.textContent = "Send a direct enquiry about this property through HAVN.";
          }

          if(contactTitle){
            if(mode === "BUY") contactTitle.textContent = "Contact advertiser";
            else if(mode === "RENT") contactTitle.textContent = "Contact landlord / agent";
            else if(mode === "SHARE") contactTitle.textContent = "Contact room advertiser";
            else contactTitle.textContent = "Contact advertiser";
          }

          if(contactSub){
            if(mode === "SHARE") contactSub.textContent = "Ask about the room, bills, occupants, house rules and viewing availability.";
            else if(mode === "RENT") contactSub.textContent = "Ask about availability, deposit, lease terms or request a viewing.";
            else contactSub.textContent = "Ask a question, request a viewing, or register your interest in this property.";
          }
        }

        function scrollToContact(){
          const el = document.getElementById("contactCard");
          if(el){
            el.scrollIntoView({ behavior:"smooth", block:"start" });
            setTimeout(() => {
              try{ contactName && contactName.focus({ preventScroll:true }); }catch{}
            }, 500);
          }
        }

        function reportListing(p){
          const ref = propertyRef(p || CURRENT_PROPERTY || {});
          const subject = encodeURIComponent("Report HAVN listing " + ref);
          const body = encodeURIComponent("I want to report this listing:\n\n" + location.href + "\n\nReason:\n");
          window.location.href = "mailto:support@havn.ie?subject=" + subject + "&body=" + body;
        }

        function buildKeyDetails(p){
          if(!kdGrid) return;
        
          kdGrid.innerHTML = "";
        
          const mode = String(p.mode || "").toUpperCase();
          const isRental = mode === "RENT" || mode === "SHARE";
        
          addKd(
            isRental ? "Monthly rent" : "Price",
            isRental
              ? ((euro(p.price) || "") + " pcm")
              : euro(p.price)
          );
        
          addKd("Beds", p.bedrooms ?? "");
          addKd("Baths", p.bathrooms ?? "");
          addKd("Property type", prettyType(p.propertyType || p.type));
          addKd("Market", prettyMode(p.mode));
          addKd("BER", p.ber || p.berRating || "");
        
            if(isRental){
              addKd("Rent frequency", prettyRentalValue(p.rentFrequency));
              addKd("Deposit", p.deposit ? euro(p.deposit) : "");
              addKd("Available from", prettyDate(p.availableFrom));
              addKd("Lease length", prettyRentalValue(p.leaseLength));
              addKd("Minimum term", prettyRentalValue(p.minimumTerm));
              addKd("Bills included", prettyRentalValue(p.billsIncluded));
              addKd("Pets allowed", prettyRentalValue(p.petsAllowed));
            
              if(mode === "SHARE"){
                addKd("Room type", prettyRentalValue(p.roomType));
                addKd("Ensuite", prettyRentalValue(p.ensuite));
                addKd("Current occupants", p.currentOccupants || "");
                addKd("Couples allowed", prettyRentalValue(p.couplesAllowed));
                addKd("Owner occupied", prettyRentalValue(p.ownerOccupied));
              }
            }
        
          addKd("Eircode", p.eircode || "");
          addKd("City / Town", p.city || p.town || "");
          addKd("County", p.county || "");
        }

      function buildLocationQuery(p){
        const eir = String(p.eircode || "").trim();
        if(eir) return { q:eir, mode:"eircode" };

        const bits = [p.address1,p.address2,p.city,p.county,"Ireland"].filter(Boolean).map(x => String(x).trim());
        if(bits.length) return { q:bits.join(", "), mode:"address" };

        return { q:"", mode:"none" };
      }

      function setMap(p){
        if(!mapBlock || !mapFrame || !openMapsBtn || !directionsBtn || !copyLocBtn) return;

        const loc = buildLocationQuery(p);
        if(!loc.q){
          mapBlock.style.display = "none";
          return;
        }

        const enc = encodeURIComponent(loc.q);
        mapFrame.src = "https://www.google.com/maps?q=" + enc + "&output=embed";
        openMapsBtn.href = "https://www.google.com/maps/search/?api=1&query=" + enc;
        directionsBtn.href = "https://www.google.com/maps/dir/?api=1&destination=" + enc;

        if(mapCaption){
          mapCaption.textContent = loc.mode === "eircode"
            ? "Eircode-first location • Best accuracy."
            : "Address-based location • May be approximate if Eircode is missing.";
        }

        copyLocBtn.onclick = async () => {
          try{ await navigator.clipboard.writeText(loc.q); }catch{}
          copyLocBtn.textContent = "Copied";
          setTimeout(() => copyLocBtn.textContent = "Copy", 900);
        };

        mapBlock.style.display = "block";
      }

      function updateHeroCount(){
        if(!heroCount) return;
        if(!PHOTOS || PHOTOS.length <= 1){
          heroCount.style.display = "none";
          return;
        }
        heroCount.style.display = "inline-flex";
        heroCount.textContent = (ACTIVE + 1) + " / " + PHOTOS.length;
      }

      function setActiveIndex(i){
        if(!PHOTOS.length) return;

        ACTIVE = Math.max(0, Math.min(PHOTOS.length - 1, i | 0));

        if(heroImg) heroImg.src = PHOTOS[ACTIVE];

        if(stripRow){
          stripRow.querySelectorAll(".thumbBtn").forEach((b,n) => {
            const isActive = n === ACTIVE;
            b.classList.toggle("active", isActive);
        
            if(isActive){
              try{
                b.scrollIntoView({
                  behavior:"smooth",
                  block:"nearest",
                  inline:"center"
                });
              }catch{}
            }
          });
        }

        if(lbStripRow){
          lbStripRow.querySelectorAll(".lbThumb").forEach((b,n) => {
            const isActive = n === ACTIVE;
            b.classList.toggle("active", isActive);
        
            if(isActive){
              try{
                b.scrollIntoView({
                  behavior:"smooth",
                  block:"nearest",
                  inline:"center"
                });
              }catch{}
            }
          });
        }

        if(lbTitle) lbTitle.textContent = "Gallery • " + (ACTIVE + 1) + " / " + PHOTOS.length;
        updateHeroCount();
      }

        function buildStrip(){
          if(!galleryStrip || !stripRow) return;
        
          stripRow.innerHTML = "";
        
          if(!PHOTOS || PHOTOS.length <= 1){
            galleryStrip.style.display = "none";
            return;
          }
        
          const visibleThumbs = PHOTOS.length > 9 ? PHOTOS.slice(0, 8) : PHOTOS;
        
          visibleThumbs.forEach((u,i) => {
            const b = document.createElement("button");
            b.type = "button";
            b.className = "thumbBtn";
        
            const img = document.createElement("img");
            img.loading = "lazy";
            img.decoding = "async";
            img.alt = "";
            img.src = u;
        
            b.appendChild(img);
            b.addEventListener("click", () => setActiveIndex(i));
            stripRow.appendChild(b);
          });
        
          if(PHOTOS.length > 9){
            const moreBtn = document.createElement("button");
            moreBtn.type = "button";
            moreBtn.className = "thumbBtn";
            moreBtn.style.display = "grid";
            moreBtn.style.placeItems = "center";
            moreBtn.style.background = "linear-gradient(135deg, rgba(15,23,42,.94), rgba(37,99,235,.92))";
            moreBtn.style.color = "#fff";
            moreBtn.style.fontWeight = "1000";
            moreBtn.style.fontSize = "13px";
            moreBtn.style.lineHeight = "1.15";
            moreBtn.innerHTML = "<span>+" + (PHOTOS.length - 8) + "<br>VIEW ALL</span>";
        
            moreBtn.addEventListener("click", () => {
              setActiveIndex(0);
              openLightbox();
            });
        
            stripRow.appendChild(moreBtn);
          }
        
          galleryStrip.style.display = "block";
          setActiveIndex(0);
        }

      function buildLightboxStrip(){
        if(!lbStripRow) return;
        lbStripRow.innerHTML = "";

        PHOTOS.forEach((u,i) => {
          const d = document.createElement("div");
          d.className = "lbThumb";

          const img = document.createElement("img");
          img.loading = "lazy";
          img.decoding = "async";
          img.alt = "";
          img.src = u;

          d.appendChild(img);
          d.addEventListener("click", () => {
            setActiveIndex(i);
            if(lbImg) lbImg.src = PHOTOS[ACTIVE];
          });

          lbStripRow.appendChild(d);
        });
      }

      function openLightbox(){
        if(!PHOTOS.length || !lb || !lbImg) return;
        document.body.classList.add("lbOpen");
        lb.classList.add("open");
        lbImg.src = PHOTOS[ACTIVE] || PHOTOS[0];
        setActiveIndex(ACTIVE);
        plausibleTrack("Gallery Open", { slug:getCurrentSlug(), index:String(ACTIVE + 1) });
      }

      function closeLightbox(){
        if(!lb) return;
        lb.classList.remove("open");
        document.body.classList.remove("lbOpen");
      }

      function next(){
        if(!PHOTOS.length || !lbImg) return;
        setActiveIndex((ACTIVE + 1) % PHOTOS.length);
        lbImg.src = PHOTOS[ACTIVE];
      }

      function prev(){
        if(!PHOTOS.length || !lbImg) return;
        setActiveIndex((ACTIVE - 1 + PHOTOS.length) % PHOTOS.length);
        lbImg.src = PHOTOS[ACTIVE];
      }

        function closePropertyMobileMenu(){
        if(!propertyMobileMenu || !propertyMobileMenuBtn) return;
        propertyMobileMenu.classList.remove("open");
        propertyMobileMenu.setAttribute("aria-hidden","true");
        propertyMobileMenuBtn.setAttribute("aria-expanded","false");
      }

      function togglePropertyMobileMenu(){
        if(!propertyMobileMenu || !propertyMobileMenuBtn) return;
        const isOpen = propertyMobileMenu.classList.toggle("open");
        propertyMobileMenu.setAttribute("aria-hidden", isOpen ? "false" : "true");
        propertyMobileMenuBtn.setAttribute("aria-expanded", isOpen ? "true" : "false");
      }

      function wirePropertyMobileMenu(){
        if(!propertyMobileMenu || !propertyMobileMenuBtn) return;

        propertyMobileMenuBtn.addEventListener("click", e => {
          e.preventDefault();
          e.stopPropagation();
          togglePropertyMobileMenu();
        });

        propertyMobileMenu.querySelectorAll("a").forEach(a => {
          a.addEventListener("click", closePropertyMobileMenu);
        });

        document.addEventListener("click", e => {
          if(!propertyMobileMenu.classList.contains("open")) return;
          if(propertyMobileMenu.contains(e.target) || propertyMobileMenuBtn.contains(e.target)) return;
          closePropertyMobileMenu();
        });

        document.addEventListener("keydown", e => {
          if(e.key === "Escape") closePropertyMobileMenu();
        });
      }

      function wireLightbox(){
          let touchStartX = 0;
          let touchStartY = 0;
        
          if(hero) hero.addEventListener("click", openLightbox);
          if(lbClose) lbClose.addEventListener("click", closeLightbox);
          if(lbPrev) lbPrev.addEventListener("click", prev);
          if(lbNext) lbNext.addEventListener("click", next);
          if(lbImg) lbImg.addEventListener("click", next);
        
          if(lbMain){
            lbMain.addEventListener("touchstart", e => {
              const t = e.touches && e.touches[0];
              if(!t) return;
        
              touchStartX = t.clientX;
              touchStartY = t.clientY;
            }, { passive:true });
        
            lbMain.addEventListener("touchend", e => {
              const t = e.changedTouches && e.changedTouches[0];
              if(!t) return;
        
              const dx = t.clientX - touchStartX;
              const dy = t.clientY - touchStartY;
        
              if(Math.abs(dx) < 44 || Math.abs(dx) < Math.abs(dy)) return;
        
              if(dx < 0) next();
              else prev();
            }, { passive:true });
          }
        
          if(lb){
            lb.addEventListener("click", e => {
              if(e.target === lb) closeLightbox();
            });
          }
        
          document.addEventListener("keydown", e => {
            if(!lb || !lb.classList.contains("open")) return;
        
            if(e.key === "Escape") closeLightbox();
            if(e.key === "ArrowRight") next();
            if(e.key === "ArrowLeft") prev();
          });
        }
      function getCurrentSlug(){
        if(CURRENT_PROPERTY && CURRENT_PROPERTY.slug) return String(CURRENT_PROPERTY.slug);
        return qs("slug") || qs("id") || "unknown";
      }

      function trackPropertyViewOnce(){
        if(PROPERTY_VIEW_TRACKED) return;
        PROPERTY_VIEW_TRACKED = true;
        plausibleTrack("Property View", { slug:getCurrentSlug() });
      }

      function setContactState(type,message){
        if(!contactState) return;
        contactState.className = "contactState";
        if(!message){
          contactState.textContent = "";
          return;
        }
        contactState.classList.add(type === "ok" ? "ok" : "err");
        contactState.textContent = message;
      }

      function setContactLoading(on){
        if(contactSendBtn) contactSendBtn.disabled = on;
        if(contactAskBtn) contactAskBtn.disabled = on;
      }

      async function submitContact(intent){
        if(!CURRENT_PROPERTY || !CURRENT_PROPERTY.id){
          setContactState("err","This property is not ready to receive enquiries yet.");
          return;
        }

        const name = (contactName && contactName.value || "").trim();
        const email = (contactEmail && contactEmail.value || "").trim();
        const phone = (contactPhone && contactPhone.value || "").trim();
        let message = (contactMessage && contactMessage.value || "").trim();

        if(intent === "VIEWING" && !message){
          message = "Hi, I'm interested in this property and would like to arrange a viewing.";
          if(contactMessage) contactMessage.value = message;
        }

        if(intent === "QUESTION" && !message){
          message = "Hi, I'm interested in this property and would like some more information.";
          if(contactMessage) contactMessage.value = message;
        }

        if(!name){
          setContactState("err","Please enter your name.");
          return;
        }

        if(!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){
          setContactState("err","Please enter a valid email address.");
          return;
        }

        if(!message || message.length < 8){
          setContactState("err","Please enter a longer message.");
          return;
        }

        plausibleTrack("Contact Click", { slug:getCurrentSlug(), intent:intent === "VIEWING" ? "viewing" : "question" });

        setContactState("","");
        setContactLoading(true);

        try{
          const payload = { name,email,phone,message,intent,sourceUrl:location.href };

          const r = await fetch(API + "/api/properties/" + encodeURIComponent(String(CURRENT_PROPERTY.id)) + "/contact", {
            method:"POST",
            headers:{
              "Content-Type":"text/plain;charset=UTF-8",
              "Accept":"application/json"
            },
            body:JSON.stringify(payload)
          });

          const result = await getJson(r);

          if(!r.ok){
            setContactState("err",(result.json && result.json.message) || result.text || "Could not send your message right now.");
            return;
          }

          setContactState("ok",(result.json && result.json.message) || "Your message has been sent.");
          if(contactMessage) contactMessage.value = "";
        }catch{
          setContactState("err","Could not send your message right now.");
        }finally{
          setContactLoading(false);
        }
      }

      function wireContactActions(){
        if(contactSendBtn) contactSendBtn.addEventListener("click", () => submitContact("VIEWING"));
        if(contactAskBtn) contactAskBtn.addEventListener("click", () => submitContact("QUESTION"));
      }
      
        async function shareProperty(p){
          if(!p) return;
        
          const slug = getRecentKey(p, true);
          const shareUrl = "https://havn.ie/property.html?slug=" + encodeURIComponent(slug);
          const shareTitle = p.title || "HAVN.ie Property";
          const shareText = "View this property on HAVN.ie";
        
          plausibleTrack("Share Property", { slug });
        
          if(navigator.share){
            try{
              await navigator.share({
                title: shareTitle,
                text: shareText,
                url: shareUrl
              });
              return;
            }catch(err){}
          }
        
          try{
            await navigator.clipboard.writeText(shareUrl);
            if(shareBtn){
              const original = shareBtn.textContent;
              shareBtn.textContent = "Link copied";
              setTimeout(() => {
                shareBtn.textContent = original;
              }, 1400);
            }
          }catch{
            window.prompt("Copy this property link:", shareUrl);
          }
        }
        
        function render(p){
          const publicStatus = String(p.listingStatus || p.publicStatus || p.status || "").trim().toUpperCase();
        
          if(publicStatus !== "PUBLISHED"){
            showErr("Property not found.");
            return;
          }
        
          CURRENT_PROPERTY = p;
          hideErr();
          
         try {
            fetch("https://api.havn.ie/api/properties/" + encodeURIComponent(String(p.id)) + "/view", {
            method: "POST",
            }).catch(function () {});
            } catch (_) {} 

        PHOTOS = normalizePhotos(p);
        const cover = pickCover(p);
        const propertyKey = getRecentKey(p, true);

        if(propertyKey && !p.slug){
          p.slug = propertyKey;
        }

        updateSeo(p);

        if(cover && hero && heroImg){
          hero.style.display = "block";
          heroImg.src = cover;
        }else if(hero){
          hero.style.display = "none";
        }

        buildStrip();
        buildLightboxStrip();

        if(main) main.style.display = "block";

        if(title) title.textContent = p.title || p.address || p.slug || "Property";

        const addrBits = [p.address,p.address1,p.address2,p.city,p.town,p.county,p.eircode].filter(Boolean);
        if(addr) addr.textContent = addrBits.length ? addrBits.join(", ") : "—";

        if(commandPrice) commandPrice.textContent = priceLabel(p);
        renderPriceDropLayer(p);
        renderMarketTimingAndHistory(p);
        if(commandMode) commandMode.textContent = prettyMode(p.mode) || "Property";
        if(featuredBadge){
          const isFeatured = p.isFeatured === true || String(p.isFeatured || "").toLowerCase() === "true";
          const featuredUntil = p.featuredUntil ? new Date(p.featuredUntil) : null;
          const featuredActive = isFeatured && (!featuredUntil || Number.isNaN(featuredUntil.getTime()) || featuredUntil.getTime() > Date.now());
          featuredBadge.style.display = featuredActive ? "inline-flex" : "none";
        }

        renderFactsBar(p);
        renderTrustLayer(p);
        renderFinancialSnapshot(p);
        buildDetailSections(p);
        setMap(p);
        renderLocationIntel(p);
        loadPropertyIntelligence(p);
        renderAdvertiser(p);
        updateContactCopy(p);

        const tagBits = [];
        if(p.mode) tagBits.push({ text:String(p.mode).toUpperCase(), soft:false });
        if(p.propertyType) tagBits.push({ text:String(p.propertyType), soft:false });
        if(p.price != null && p.price !== ""){
        const mode = String(p.mode || "").toUpperCase();

        const priceText =
            mode === "RENT" || mode === "SHARE"
            ? (euro(p.price) || ("€" + String(p.price))) + " pcm"
            : (euro(p.price) || ("€" + String(p.price)));

        tagBits.push({
            text:priceText,
            soft:false
        });
        }
        
        if(p.bedrooms != null && p.bedrooms !== "") tagBits.push({ text:String(p.bedrooms) + " bed", soft:false });
        if(p.bathrooms != null && p.bathrooms !== "") tagBits.push({ text:String(p.bathrooms) + " bath", soft:false });

        const liveLabel = daysOnHavn(p.publishedAt || p.createdAt);
        if(liveLabel) tagBits.push({ text:liveLabel, soft:true });

        if(tags){
          tags.innerHTML = tagBits.map(x => `<span class="tag${x.soft ? " soft" : ""}">${esc(x.text)}</span>`).join("");
        }

        if(desc) desc.textContent = p.description || "—";
        
        if(featuresBlock && featuresGrid){
          const featureItems = Array.isArray(p.features)
            ? p.features.map(x => String(x || "").trim()).filter(Boolean)
            : [];
        
          featuresGrid.innerHTML = "";
        
          if(featureItems.length){
            featureItems.slice(0, 12).forEach(item => {
              const row = document.createElement("div");
              row.className = "featureItem";
              row.textContent = item;
              featuresGrid.appendChild(row);
            });
        
            featuresBlock.style.display = "block";
          }else{
            featuresBlock.style.display = "none";
          }
        }

        buildKeyDetails(p);

        if(publicBadge){
          publicBadge.style.display = String(p.listingStatus || p.publicStatus || p.status || "").toUpperCase() === "PUBLISHED" ? "inline-flex" : "none";
        }

        updateHeroCount();
        updateSaveButtonForProperty(p);

        loadSavedPropertyIds().then(() => {
          updateSaveButtonForProperty(p);
        }).catch(() => {});

        if(saveBtn){
          saveBtn.onclick = () => toggleSavedProperty(p);
        }
        
        if(shareBtn){
          shareBtn.onclick = () => shareProperty(p);
        }

        if(topEnquiryBtn){
          topEnquiryBtn.onclick = scrollToContact;
        }

        if(mobileEnquiryBtn){
          mobileEnquiryBtn.onclick = scrollToContact;
        }

        if(mobileSaveBtn){
          mobileSaveBtn.onclick = () => toggleSavedProperty(p);
        }

        if(mobileShareBtn){
          mobileShareBtn.onclick = () => shareProperty(p);
        }

        if(reportBtn){
          reportBtn.onclick = () => reportListing(p);
        }

        pushRecentlyViewed(p);
        renderRecentCards(propertyKey);
        loadSimilarProperties(p);
        trackPropertyViewOnce();
      }

      async function fetchJsonUrl(url, signal){
        const r = await fetch(url, {
          headers:{ "Accept":"application/json" },
          signal,
          cache:"no-store"
        });

        const result = await getJson(r);
        return { response:r, result };
      }

      async function tryDirectProperty(url, wanted, signal, allowLoose){
        const out = await fetchJsonUrl(url, signal);

        if(!out.response.ok){
          return null;
        }

        const data = out.result.json;
        const direct = normalize(data);

        if(direct && looksLikeProperty(direct)){
          if(allowLoose || itemMatchesIdentifier(direct, wanted)){
            return direct;
          }
        }

        const list = extractListFromPayload(data);
        const found = list.find(item => itemMatchesIdentifier(item, wanted));

        return found || null;
      }

      async function loadProperty(identifier){
        const wanted = String(identifier || "").trim();

        if(!wanted){
          showErr("Missing slug in URL.");
          return;
        }

        try{
          if(currentPropertyController){
            currentPropertyController.abort();
          }

          currentPropertyController = new AbortController();
          const signal = currentPropertyController.signal;

          const directUrls = [
            API + "/api/properties/" + encodeURIComponent(wanted),
            API + "/api/properties/slug/" + encodeURIComponent(wanted),
            API + "/api/properties/by-slug/" + encodeURIComponent(wanted)
          ];

          for(const url of directUrls){
            try{
              const p = await tryDirectProperty(url, wanted, signal, true);
              if(p){
                render(p);
                return;
              }
            }catch(err){
              if(err && err.name === "AbortError") return;
            }
          }

          const listUrls = [
            API + "/api/properties?limit=200&page=1",
            API + "/api/properties"
          ];

          for(const url of listUrls){
            try{
              const out = await fetchJsonUrl(url, signal);

              if(!out.response.ok){
                continue;
              }

              const list = extractListFromPayload(out.result.json);
              const found = list.find(item => itemMatchesIdentifier(item, wanted));

              if(found){
                render(found);
                return;
              }
            }catch(err){
              if(err && err.name === "AbortError") return;
            }
          }

          showErr("Property not found for: " + wanted);
        }catch(err){
          if(err && err.name === "AbortError") return;
          showErr("Network error loading property.");
        }
      }

      function init(){
        wirePropertyMobileMenu();
        wireLightbox();
        wireContactActions();
        if(priceHistoryToggle && priceHistoryBox && priceHistoryChevron){
          priceHistoryToggle.addEventListener("click", function(){
            const open = priceHistoryBox.classList.toggle("open");
            priceHistoryChevron.textContent = open ? "⌃" : "⌄";
          });
        }
        renderRecentCards("");
        if(similarGrid) similarGrid.innerHTML = "";
        if(similarEmpty){
          similarEmpty.style.display = "block";
          similarEmpty.textContent = "Similar properties will appear here.";
        }

        const identifier = qs("slug") || qs("id");

        if(!identifier){
          showErr("Missing slug in URL.");
          return;
        }

        loadProperty(identifier);
      }

      document.addEventListener("DOMContentLoaded", init);
    })();
  </script>
</body>
</html>
