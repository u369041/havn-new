{
  "name": "havn-api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && prisma migrate deploy && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "transport:build": "tsx scripts/build-transport-cache.ts",
    "geography:seed": "tsx src/geography/seed/seedLocations.ts",
    "geography:fetch:cso": "tsx src/geography/importers/fetchCsoBuiltUpAreas.ts",
    "geography:normalise:cso": "tsx src/geography/importers/normaliseCsoBuiltUpAreas.ts",
    "geography:verify:cso": "tsx src/geography/reports/verifyCsoBuiltUpAreas.ts",
     "geography:import:cso:dry": "tsx src/geography/importers/importNormalisedLocations.ts",
     "geography:import:cso": "tsx src/geography/importers/importNormalisedLocations.ts --write",
     "geography:verify:db": "tsx src/geography/reports/verifyImportedLocations.ts",
     "geography:match:properties:dry": "tsx src/geography/matchers/matchPropertyLocations.ts",
     "geography:match:properties": "tsx src/geography/matchers/matchPropertyLocations.ts --write",
     "geography:premium:dry": "tsx src/geography/importers/importPremiumLocations.ts",
     "geography:premium": "tsx src/geography/importers/importPremiumLocations.ts --write"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "adm-zip": "^0.5.17",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "resend": "^6.7.0",
    "stripe": "^22.1.0",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.3",
    "prisma": "^5.0.0",
    "typescript": "^5.6.0"
  }
}
